---
// EVFBS Footer Component - Professional Business Footer
export const prerender = true;

const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { name: 'Equipment Finance', href: '/services/equipment-finance' },
    { name: 'Commercial Loans', href: '/services/commercial-loans' },
    { name: 'Asset Finance', href: '/services/asset-finance' },
    { name: 'Business Loans', href: '/services/business-loans' },
    { name: 'Hire Purchase', href: '/services/hire-purchase' },
  ],
  company: [
    { name: 'About Us', href: '/about' },
    { name: 'Our Team', href: '/about/team' },
    { name: 'Reviews', href: '/reviews' },
    { name: 'Case Studies', href: '/case-studies' },
    { name: 'Careers', href: '/careers' },
  ],
  resources: [
    { name: 'Finance Calculator', href: '/calculator' },
    { name: 'Industry Insights', href: '/insights' },
    { name: 'FAQs', href: '/faqs' },
    { name: 'Finance Guide', href: '/guides' },
    { name: 'Blog', href: '/blog' },
  ],
  legal: [
    { name: 'Privacy Policy', href: '/privacy' },
    { name: 'Terms of Service', href: '/terms' },
    { name: 'Credit Guide', href: '/credit-guide' },
    { name: 'Complaints', href: '/complaints' },
  ]
};

const contactInfo = {
  phone: '1300 733 856',
  email: 'info@edgeviewfinance.com.au',
  address: 'Gold Coast, Queensland, Australia',
  abn: 'ABN: 12 345 678 901'
};

const socialLinks = [
  { name: 'LinkedIn', href: 'https://linkedin.com/company/edgeview-finance', icon: 'linkedin' },
  { name: 'Facebook', href: 'https://facebook.com/edgeviewfinance', icon: 'facebook' },
  { name: 'Google Business', href: 'https://maps.google.com/edgeviewfinance', icon: 'map-pin' },
];
---

<footer class="footer-section">
  <div class="container-default">
    <!-- Main Footer Content -->
    <div class="section-padding border-b border-brand-primary-light">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">
        
        <!-- Company Information -->
        <div class="lg:col-span-2">
          <!-- Logo -->
          <div class="flex items-center space-x-2 mb-6">
            <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center">
              <span class="text-brand-primary font-bold text-xl">E</span>
            </div>
            <span class="font-heading font-bold text-xl text-white">
              Edgeview Finance
            </span>
          </div>
          
          <!-- Company Description -->
          <p class="text-brand-grey-300 text-lg leading-relaxed mb-6">
            Trusted commercial finance specialists helping Australian businesses secure equipment finance, 
            commercial loans, and asset finance solutions for over 15 years.
          </p>
          
          <!-- Contact Information -->
          <div class="space-y-3">
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-brand-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href={`tel:${contactInfo.phone.replace(/\s/g, '')}`} class="footer-link font-medium">
                {contactInfo.phone}
              </a>
            </div>
            
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-brand-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href={`mailto:${contactInfo.email}`} class="footer-link">
                {contactInfo.email}
              </a>
            </div>
            
            <div class="flex items-start space-x-3">
              <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-brand-grey-300">
                {contactInfo.address}
              </span>
            </div>
          </div>
          
          <!-- Social Links -->
          <div class="flex items-center space-x-4 mt-6">
            {socialLinks.map((social) => (
              <a 
                href={social.href}
                class="w-10 h-10 bg-brand-primary-light rounded-lg flex items-center justify-center text-white hover:bg-brand-accent transition-colors duration-200"
                aria-label={`Follow us on ${social.name}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                {social.icon === 'linkedin' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                )}
                {social.icon === 'facebook' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                )}
                {social.icon === 'map-pin' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                )}
              </a>
            ))}
          </div>
        </div>
        
        <!-- Services Links -->
        <div>
          <h3 class="footer-title">Services</h3>
          <ul class="space-y-3">
            {footerLinks.services.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        
        <!-- Company Links -->
        <div>
          <h3 class="footer-title">Company</h3>
          <ul class="space-y-3">
            {footerLinks.company.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        
        <!-- Resources Links -->
        <div>
          <h3 class="footer-title">Resources</h3>
          <ul class="space-y-3">
            {footerLinks.resources.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
    
    <!-- Bottom Footer -->
    <div class="py-8">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between space-y-4 lg:space-y-0">
        
        <!-- Copyright & Legal -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:space-x-6 space-y-2 sm:space-y-0">
          <p class="text-brand-grey-300 text-sm">
            © {currentYear} Edgeview Finance. All rights reserved.
          </p>
          <span class="text-brand-grey-300 text-sm">
            {contactInfo.abn}
          </span>
        </div>
        
        <!-- Legal Links -->
        <div class="flex flex-wrap items-center space-x-6">
          {footerLinks.legal.map((link) => (
            <a href={link.href} class="footer-link text-sm">
              {link.name}
            </a>
          ))}
        </div>
      </div>
      
      <!-- Compliance & Disclaimers -->
      <div class="mt-6 pt-6 border-t border-brand-primary-light">
        <div class="text-brand-grey-300 text-xs leading-relaxed space-y-2">
          <p>
            <strong>Australian Credit Licence:</strong> Edgeview Finance is a credit representative of ABC Finance Group Pty Ltd (Australian Credit Licence 123456).
          </p>
          <p>
            <strong>Important:</strong> This website contains general information only and does not constitute financial advice. 
            We recommend seeking professional advice before making any financial decisions. 
            Terms and conditions apply to all finance products.
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Footer specific styles */
  .footer-section {
    background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-primary-dark) 100%);
  }
  
  /* Ensure proper spacing and typography hierarchy */
  .footer-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: white;
    margin-bottom: 1rem;
  }
  
  .footer-link {
    color: var(--brand-grey-300);
    transition: color 0.2s ease;
    font-size: 0.875rem;
  }
  
  .footer-link:hover {
    color: white;
  }
  
  /* Social link hover effects */
  .social-link {
    transition: all 0.2s ease;
  }
  
  .social-link:hover {
    transform: translateY(-1px);
  }
</style>