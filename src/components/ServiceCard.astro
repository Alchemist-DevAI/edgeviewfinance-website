---
// EVFBS Service Card Component - Reusable Service Display
export const prerender = true;

interface Props {
  title: string;
  description: string;
  features?: string[];
  icon?: string;
  href: string;
  variant?: 'default' | 'featured' | 'minimal';
  ctaText?: string;
  priceRange?: string;
  approvalTime?: string;
}

const {
  title,
  description,
  features = [],
  icon = 'briefcase',
  href,
  variant = 'default',
  ctaText = 'Learn More',
  priceRange,
  approvalTime
} = Astro.props;

// Icon mapping for common service types
const iconMap = {
  'equipment': 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  'loan': 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1',
  'asset': 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  'business': 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  'hire': 'M9 5H7a2 2 0 00-2 2v6a2 2 0 002 2h2m0-8v8m0-8V3m0 0h2M7 3h2m2 0h2m2 8v6a2 2 0 01-2 2H9',
  'briefcase': 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10a2 2 0 01-2 2H6a2 2 0 01-2-2V7m16 0H4'
};

const svgPath = iconMap[icon] || iconMap['briefcase'];
---

<div class={`service-card group ${variant === 'featured' ? 'border-2 border-brand-accent shadow-accent' : ''}`}>
  
  <!-- Service Icon -->
  <div class="icon-wrapper group-hover:bg-brand-primary transition-colors duration-200">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={svgPath} />
    </svg>
  </div>
  
  <!-- Service Content -->
  <div class="flex-1">
    
    <!-- Header -->
    <div class="mb-4">
      <h3 class="text-2xl font-semibold text-brand-grey-900 mb-2 group-hover:text-brand-primary transition-colors duration-200">
        {title}
      </h3>
      
      {(priceRange || approvalTime) && (
        <div class="flex items-center space-x-4 text-sm text-brand-grey-600 mb-3">
          {priceRange && (
            <div class="flex items-center space-x-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
              </svg>
              <span>{priceRange}</span>
            </div>
          )}
          
          {approvalTime && (
            <div class="flex items-center space-x-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{approvalTime}</span>
            </div>
          )}
        </div>
      )}
      
      <p class="text-brand-grey-700 leading-relaxed">
        {description}
      </p>
    </div>
    
    <!-- Features List -->
    {features.length > 0 && (
      <div class="mb-6">
        <h4 class="text-sm font-semibold text-brand-grey-900 mb-3">Key Features:</h4>
        <ul class="space-y-2">
          {features.slice(0, 4).map((feature) => (
            <li class="flex items-center space-x-2 text-sm text-brand-grey-700">
              <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span>{feature}</span>
            </li>
          ))}
          {features.length > 4 && (
            <li class="text-sm text-brand-grey-500 font-medium">
              + {features.length - 4} more features
            </li>
          )}
        </ul>
      </div>
    )}
  </div>
  
  <!-- CTA Footer -->
  <div class="mt-auto pt-6">
    <a 
      href={href}
      class="btn-primary w-full text-center group-hover:bg-brand-primary-dark group-hover:border-brand-primary-dark transition-all duration-200"
    >
      {ctaText}
      <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </a>
  </div>
</div>

<style>
  /* Service card specific enhancements */
  .service-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 400px;
    transition: all 0.2s ease;
  }
  
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }
  
  /* Featured variant styling */
  .service-card.border-brand-accent {
    position: relative;
  }
  
  .service-card.border-brand-accent::before {
    content: 'Most Popular';
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--brand-accent);
    color: white;
    padding: 4px 16px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  /* Icon wrapper enhanced */
  .icon-wrapper {
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-accent);
    color: white;
    border-radius: 1rem;
    margin-bottom: 1.5rem;
    transition: all 0.2s ease;
  }
  
  /* Responsive adjustments */
  @media (max-width: 768px) {
    .service-card {
      min-height: 350px;
    }
    
    .icon-wrapper {
      width: 3rem;
      height: 3rem;
      margin-bottom: 1rem;
    }
  }
</style>