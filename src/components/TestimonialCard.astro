---
// EVFBS Testimonial Card Component - Social Proof Display
export const prerender = true;

interface Props {
  quote: string;
  author: string;
  position?: string;
  company: string;
  location?: string;
  rating?: number;
  avatar?: string;
  variant?: 'default' | 'featured' | 'minimal';
  loanAmount?: string;
  serviceType?: string;
}

const {
  quote,
  author,
  position,
  company,
  location,
  rating = 5,
  avatar,
  variant = 'default',
  loanAmount,
  serviceType
} = Astro.props;

// Generate star rating
const stars = Array.from({ length: 5 }, (_, i) => i < rating);

// Generate initials for avatar if no image provided
const initials = author.split(' ').map(name => name.charAt(0)).join('').toUpperCase().slice(0, 2);
---

<div class={`testimonial-card ${variant === 'featured' ? 'border-2 border-brand-accent' : ''}`}>
  
  <!-- Rating Stars -->
  <div class="flex items-center mb-4">
    {stars.map((filled) => (
      <svg 
        class={`w-5 h-5 ${filled ? 'text-yellow-400' : 'text-brand-grey-300'}`} 
        fill="currentColor" 
        viewBox="0 0 24 24"
      >
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    ))}
    <span class="ml-2 text-sm text-brand-grey-600 font-medium">{rating}/5</span>
  </div>
  
  <!-- Quote -->
  <blockquote class="testimonial-quote">
    <div class="relative">
      <!-- Quote marks -->
      <svg class="absolute -top-2 -left-1 w-8 h-8 text-brand-accent opacity-50" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h4v10h-10z"/>
      </svg>
      <p class="relative z-10">"{quote}"</p>
    </div>
  </blockquote>
  
  <!-- Author Information -->
  <div class="testimonial-author">
    
    <!-- Avatar -->
    <div class="testimonial-avatar">
      {avatar ? (
        <img 
          src={avatar} 
          alt={`${author} avatar`}
          class="w-full h-full object-cover rounded-full"
        />
      ) : (
        <span class="text-sm font-semibold">{initials}</span>
      )}
    </div>
    
    <!-- Author Details -->
    <div class="flex-1">
      <div class="font-semibold text-brand-grey-900">{author}</div>
      
      {position && (
        <div class="text-sm text-brand-grey-600">{position}</div>
      )}
      
      <div class="text-sm text-brand-grey-600 font-medium">{company}</div>
      
      {location && (
        <div class="text-xs text-brand-grey-500">{location}</div>
      )}
    </div>
  </div>
  
  <!-- Additional Details -->
  {(loanAmount || serviceType) && (
    <div class="mt-4 pt-4 border-t border-brand-grey-300">
      <div class="flex flex-wrap gap-3 text-xs">
        {serviceType && (
          <div class="flex items-center space-x-1 text-brand-accent">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="font-medium">{serviceType}</span>
          </div>
        )}
        
        {loanAmount && (
          <div class="flex items-center space-x-1 text-brand-grey-600">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
            </svg>
            <span class="font-medium">{loanAmount}</span>
          </div>
        )}
      </div>
    </div>
  )}
</div>

<style>
  /* Testimonial card specific styling */
  .testimonial-card {
    height: 100%;
    transition: all 0.2s ease;
  }
  
  .testimonial-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }
  
  /* Featured variant */
  .testimonial-card.border-brand-accent {
    position: relative;
    box-shadow: 0 10px 25px -3px rgba(0, 102, 204, 0.1);
  }
  
  .testimonial-card.border-brand-accent::before {
    content: 'Featured Review';
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--brand-accent);
    color: white;
    padding: 2px 12px;
    border-radius: 12px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  /* Quote styling */
  .testimonial-quote {
    margin-bottom: 1.5rem;
    line-height: 1.6;
    font-style: italic;
    color: var(--brand-grey-700);
  }
  
  /* Author section */
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .testimonial-avatar {
    width: 3rem;
    height: 3rem;
    background: var(--brand-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
    overflow: hidden;
  }
  
  /* Responsive adjustments */
  @media (max-width: 640px) {
    .testimonial-card {
      padding: 1.5rem;
    }
    
    .testimonial-avatar {
      width: 2.5rem;
      height: 2.5rem;
    }
    
    .testimonial-quote {
      font-size: 0.95rem;
    }
  }
</style>