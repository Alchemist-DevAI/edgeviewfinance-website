---
// EVFBS Hero Component - Hormozi-Aligned Messaging
export const prerender = true;

interface Props {
  headline?: string;
  subheadline?: string;
  description?: string;
  primaryCTA?: {
    text: string;
    href: string;
  };
  secondaryCTA?: {
    text: string;
    href: string;
  };
  trustSignals?: string[];
  backgroundImage?: string;
  variant?: 'default' | 'minimal' | 'centered';
}

const {
  headline = "Expert Commercial Finance Solutions",
  subheadline = "Professional commercial finance tailored to your business needs",
  description = "Access competitive commercial finance solutions with expert guidance. Our experienced team specialises in equipment finance, asset finance, and business loans for established Australian businesses. Zero upfront fees.",
  primaryCTA = {
    text: "Get Quote in 60 Seconds",
    href: "/get-quote"
  },
  secondaryCTA = {
    text: "Call 1300 733 856",
    href: "tel:1300733856"
  },
  trustSignals = [
    "15+ Years Experience",
    "98% Approval Rate", 
    "$500M+ Funded",
    "Zero Upfront Fees"
  ],
  backgroundImage,
  variant = 'default'
} = Astro.props;
---

<section class={`hero-section section-padding ${variant === 'minimal' ? 'py-16 lg:py-20' : ''}`}>
  {backgroundImage && (
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-10" style={`background-image: url(${backgroundImage})`}></div>
  )}
  
  <div class="container-default relative z-10">
    <div class={`grid grid-cols-1 ${variant === 'centered' ? 'text-center' : 'lg:grid-cols-2'} gap-12 lg:gap-16 items-center`}>
      
      <!-- Hero Content -->
      <div class={variant === 'centered' ? 'max-w-4xl mx-auto' : ''}>
        
        <!-- Problem Hook (Hormozi Framework) -->
        <div class="mb-6">
          <h1 class="hero-title text-white">
            {headline}
          </h1>
          
          <p class="hero-subtitle">
            {subheadline}
          </p>
        </div>
        
        <!-- Value Proposition -->
        <div class="mb-8">
          <p class="text-lg lg:text-xl text-brand-grey-100 leading-relaxed max-w-2xl">
            {description}
          </p>
        </div>
        
        <!-- Trust Signals -->
        <div class="mb-8">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            {trustSignals.map((signal) => (
              <div class="text-center lg:text-left">
                <div class="text-brand-accent font-semibold text-sm lg:text-base">
                  {signal}
                </div>
              </div>
            ))}
          </div>
        </div>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row sm:items-center gap-4">
          <a href={primaryCTA.href} class="btn-accent btn-large inline-flex items-center justify-center group">
            <span>{primaryCTA.text}</span>
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          
          <a href={secondaryCTA.href} class="btn-secondary btn-large text-white border-white hover:bg-white hover:text-brand-primary inline-flex items-center justify-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>{secondaryCTA.text}</span>
          </a>
        </div>
        
        <!-- Social Proof / Credibility -->
        <div class="mt-8 pt-8 border-t border-brand-primary-light">
          <div class="flex flex-col sm:flex-row sm:items-center sm:space-x-8 space-y-4 sm:space-y-0 text-sm text-brand-grey-200">
            <div class="flex items-center space-x-2">
              <svg class="w-5 h-5 text-brand-accent" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <span>4.9/5 Google Reviews</span>
            </div>
            
            <div class="flex items-center space-x-2">
              <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>Australian Credit Licence</span>
            </div>
            
            <div class="flex items-center space-x-2">
              <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
              <span>Bank-Level Security</span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Hero Visual (when not centered) -->
      {variant !== 'centered' && (
        <div class="relative">
          <!-- Feature Highlight Cards -->
          <div class="grid grid-cols-1 gap-6">
            
            <!-- Speed Card -->
            <div class="bg-white bg-opacity-10 backdrop-blur-sm border border-white border-opacity-20 rounded-xl p-6">
              <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-brand-accent rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold text-lg">Expert Assessment</h3>
                  <p class="text-brand-grey-200 text-sm">Professional evaluation process</p>
                </div>
              </div>
            </div>
            
            <!-- Cost Card -->
            <div class="bg-white bg-opacity-10 backdrop-blur-sm border border-white border-opacity-20 rounded-xl p-6">
              <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-brand-accent rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold text-lg">Zero Upfront Fees</h3>
                  <p class="text-brand-grey-200 text-sm">No hidden costs or surprises</p>
                </div>
              </div>
            </div>
            
            <!-- Support Card -->
            <div class="bg-white bg-opacity-10 backdrop-blur-sm border border-white border-opacity-20 rounded-xl p-6">
              <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-brand-accent rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M12 2.25a9.75 9.75 0 100 19.5 9.75 9.75 0 000-19.5z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold text-lg">Personal Service</h3>
                  <p class="text-brand-grey-200 text-sm">Real people, real support</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* Hero specific enhancements */
  .hero-section {
    position: relative;
    overflow: hidden;
  }
  
  /* Gradient overlay for better text readability */
  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 51, 102, 0.95) 0%, rgba(0, 34, 68, 0.9) 100%);
    z-index: 1;
  }
  
  /* Ensure content stays above overlay */
  .hero-section > .container-default {
    position: relative;
    z-index: 10;
  }
  
  /* Button hover animations */
  .btn-accent:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -3px rgba(0, 102, 204, 0.3);
  }
  
  .btn-secondary:hover {
    transform: translateY(-1px);
  }
  
  /* Trust signals responsive layout */
  @media (max-width: 640px) {
    .trust-signals {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
  }
  
  /* Feature cards responsive */
  @media (max-width: 1024px) {
    .feature-cards {
      display: none;
    }
  }
</style>