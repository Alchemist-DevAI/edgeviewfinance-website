---
// EVFBS Header Component - Professional Navigation
export const prerender = true;

const currentPath = Astro.url.pathname;

const navigation = [
  { name: 'Home', href: '/', active: currentPath === '/' },
  { name: 'Services', href: '/services', active: currentPath === '/services' },
  { name: 'About', href: '/about', active: currentPath === '/about' },
  { name: 'Contact', href: '/contact', active: currentPath === '/contact' },
];
---

<header class="bg-white shadow-soft sticky top-0 z-50">
  <div class="container-default">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center hover:opacity-80 transition-opacity duration-200">
          <img 
            src="/images/edgeview-finance-logo.png" 
            alt="Edgeview Finance" 
            class="h-8 sm:h-10 w-auto"
          />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center space-x-8">
        {navigation.map((item) => (
          <a 
            href={item.href}
            class={item.active ? 'nav-link-active' : 'nav-link'}
          >
            {item.name}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA Buttons -->
      <div class="hidden lg:flex items-center space-x-4">
        <a href="/calculator" class="nav-link">
          Calculator
        </a>
        <a href="/get-quote" class="btn-primary">
          Get Quote
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <div class="lg:hidden">
        <button 
          id="mobile-menu-button"
          class="p-2 rounded-md text-brand-grey-700 hover:text-brand-accent hover:bg-brand-grey-50 transition-all duration-200"
          aria-label="Open mobile menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-brand-grey-300">
    <div class="container-default py-4">
      <nav class="flex flex-col space-y-4">
        {navigation.map((item) => (
          <a 
            href={item.href}
            class={`block px-4 py-2 rounded-md transition-all duration-200 ${
              item.active 
                ? 'text-brand-primary bg-brand-grey-50 font-medium' 
                : 'text-brand-grey-700 hover:text-brand-accent hover:bg-brand-grey-50'
            }`}
          >
            {item.name}
          </a>
        ))}
        <div class="pt-4 border-t border-brand-grey-300 space-y-3">
          <a href="/calculator" class="block px-4 py-2 text-brand-grey-700 hover:text-brand-accent">
            Calculator
          </a>
          <a href="/get-quote" class="btn-primary w-full text-center">
            Get Quote
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle functionality
  document.addEventListener('DOMContentLoaded', function() {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', function() {
        const isHidden = mobileMenu.classList.contains('hidden');
        
        if (isHidden) {
          mobileMenu.classList.remove('hidden');
          mobileMenu.classList.add('animate-fade-in');
          mobileMenuButton.setAttribute('aria-expanded', 'true');
        } else {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('animate-fade-in');
          mobileMenuButton.setAttribute('aria-expanded', 'false');
        }
      });
    }
    
    // Close mobile menu when clicking on a link
    const mobileNavLinks = mobileMenu?.querySelectorAll('a');
    mobileNavLinks?.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('animate-fade-in');
        mobileMenuButton?.setAttribute('aria-expanded', 'false');
      });
    });
    
    // Close mobile menu when clicking outside
    document.addEventListener('click', function(event) {
      const target = event.target as Element;
      if (mobileMenu && !mobileMenu.contains(target) && !mobileMenuButton?.contains(target)) {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('animate-fade-in');
        mobileMenuButton?.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>

<style>
  /* Ensure header stays above all content */
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    background-color: rgba(255, 255, 255, 0.95);
  }
  
  /* Mobile menu animation */
  #mobile-menu {
    animation-duration: 0.2s;
    animation-timing-function: ease-out;
  }
  
  /* Logo hover effect */
  .logo-hover:hover {
    transform: scale(1.05);
    transition: transform 0.2s ease;
  }
</style>