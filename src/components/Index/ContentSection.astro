---
import { Image } from "astro:assets";
import ContentArea1 from "./ContentArea1.astro";
import ContentArea2 from "./ContentArea2.astro";
---

<section class='section-content'>
  <div class='relative z-10'>
    <div class='section-space'>
      <div class='container-default'>
        <div class='flex flex-col gap-y-20 lg:gap-y-[100px] xl:gap-y-[120px]'>
          <ContentArea1 />
          <ContentArea2 />
        </div>
      </div>
    </div>
    <div
      class='absolute hidden xl:inline-block right-[60px] top-1/3 -z-10 rotate-[29deg]'>
      <Image
        src='/assets/img/elements/home-8-dot-shape.svg'
        alt='home-8-dot-shape'
        width='126'
        height='275'
      />
    </div>
  </div>
</section>
