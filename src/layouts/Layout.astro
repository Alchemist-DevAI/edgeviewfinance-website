---
// EVFBS Base Layout - Professional Business Layout
export const prerender = true;

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
}

const { 
  title, 
  description = "Fast commercial finance solutions for Australian businesses. Equipment finance, commercial loans, and asset finance with 24-hour approvals and zero upfront fees.",
  keywords = "commercial finance Australia, equipment finance, business loans, fast approval",
  ogImage = "/images/evfbs-og-image.jpg",
  canonical
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site);
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon.png" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="en_AU" />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImage} />
  
  <!-- Preload critical resources -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  
  <!-- Schema.org markup for Australian business -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "@id": "https://edgeviewfinance.com.au/#organization",
    "name": "Edgeview Finance Business Solutions",
    "alternateName": "EVFBS",
    "description": "Fast commercial finance solutions for Australian businesses. Equipment finance, commercial loans, and asset finance with 24-hour approvals.",
    "url": "https://edgeviewfinance.com.au",
    "logo": "https://edgeviewfinance.com.au/images/edgeview-finance-logo.png",
    "image": "https://edgeviewfinance.com.au/images/evfbs-og-image.jpg",
    "telephone": "+61-1300-733-856",
    "email": "info@edgeviewfinance.com.au",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "AU",
      "addressRegion": "Queensland",
      "addressLocality": "Gold Coast"
    },
    "areaServed": {
      "@type": "Country",
      "name": "Australia"
    },
    "serviceType": "Commercial Finance Brokerage",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Commercial Finance Solutions",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Equipment Finance",
            "description": "24-hour equipment finance approvals for commercial trades and businesses"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service", 
            "name": "Commercial Loans",
            "description": "Fast working capital and business loans with same-day pre-approval"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Asset Finance", 
            "description": "100% asset financing for vehicles, machinery, and technology"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Hire Purchase",
            "description": "Equipment hire purchase with ownership at the end of the term"
          }
        }
      ]
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "150",
      "bestRating": "5",
      "worstRating": "1"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+61-1300-733-856",
      "contactType": "customer service",
      "areaServed": "AU",
      "availableLanguage": "English",
      "hoursAvailable": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "08:00",
        "closes": "18:00"
      }
    },
    "sameAs": [
      "https://www.linkedin.com/company/edgeview-finance",
      "https://www.facebook.com/edgeviewfinance"
    ]
  }
  </script>
  
  <title>{title}</title>
</head>

<body>
  <slot />
  
  <!-- Analytics and tracking scripts would go here -->
  <!-- Google Analytics, Facebook Pixel, etc. -->
  
  <!-- Performance monitoring -->
  <script>
    // Basic performance monitoring
    window.addEventListener('load', function() {
      if ('performance' in window) {
        setTimeout(function() {
          const perfData = performance.getEntriesByType('navigation')[0];
          if (perfData) {
            console.log('Page load time:', perfData.loadEventEnd - perfData.loadEventStart, 'ms');
          }
        }, 0);
      }
    });
  </script>
</body>
</html>