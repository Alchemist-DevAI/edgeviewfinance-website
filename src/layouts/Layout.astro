---
// EVFBS Layout with Agency11 Theme Integration
import "../styles/tailwind.css";
import "../styles/menu.css";
import "../styles/custom.css";
import Header from "../components/ui/Header.astro";
import Footer from "../components/ui/Footer.astro";
import "jos-animation/dist/jos.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/plus-jakarta-sans/800.css";
import "@fontsource/public-sans/800.css";
import "@fortawesome/fontawesome-free/css/all.css";

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
}

const { 
  title, 
  description = "Expert commercial finance solutions for Australian businesses. Equipment finance, commercial loans, and asset finance with 24-hour approvals.",
  keywords = "commercial finance Australia, equipment finance, business loans, fast approval",
  ogImage = "/images/evfbs-og-image.jpg",
  canonical
} = Astro.props;

const siteName = "Edgeview Finance Business Solutions";
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site || 'https://edgeviewfinance-website.vercel.app');
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{siteName} | {title}</title>
    <meta name='description' content={description} />
    <meta name="keywords" content={keywords} />
    <link rel='icon' type="image/png" href='/favicon.png' />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${siteName} | ${title}`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_AU" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${siteName} | ${title}`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    
    <!-- Preload critical resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Schema.org markup for Australian business -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FinancialService",
      "@id": "https://edgeviewfinance.com.au/#organization",
      "name": "Edgeview Finance Business Solutions",
      "alternateName": "EVFBS",
      "description": "Expert commercial finance solutions for Australian businesses. Equipment finance, commercial loans, and asset finance with 24-hour approvals.",
      "url": "https://edgeviewfinance.com.au",
      "logo": "https://edgeviewfinance.com.au/logo.png",
      "image": "https://edgeviewfinance.com.au/images/evfbs-og-image.jpg",
      "telephone": "+61-1300-733-856",
      "email": "info@edgeviewfinance.com.au",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "AU",
        "addressRegion": "Queensland",
        "addressLocality": "Gold Coast"
      },
      "areaServed": {
        "@type": "Country",
        "name": "Australia"
      },
      "serviceType": "Commercial Finance Brokerage",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "150",
        "bestRating": "5",
        "worstRating": "1"
      }
    }
    </script>
  </head>
  <body>
    <div class=`page-wrapper relative z-[1] ${Astro.url.pathname==='/'?'bg-[#FDFBF9]':'bg-white'}`>
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    
    <!-- Agency11 JavaScript -->
    <script src='/assets/js/menu.js' is:inline></script>
    <script src='/assets/js/main.js' is:inline></script>
  </body>
</html>

<script>
  import JOS from "jos-animation";
  
  // Initialize JOS animations for Agency11 theme
  JOS.init({
    passive: false,
    once: true,
    animation: "fade-up",
    timingFunction: "ease",
    threshold: 0,
    delay: 0.5,
    duration: 0.7,
    scrollDirection: "down",
    rootMargin: "0% 0% 15% 0%",
  });
  
  // Performance monitoring
  window.addEventListener('load', function() {
    if ('performance' in window) {
      setTimeout(function() {
        const perfData = performance.getEntriesByType('navigation')[0];
        if (perfData) {
          console.log('Page load time:', perfData.loadEventEnd - perfData.loadEventStart, 'ms');
        }
      }, 0);
    }
  });
</script>

<style is:global>
  /* Import Agency11 base styles */
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
  
  /* EVFBS Brand Overrides for Agency11 Theme */
  .btn.is-lime {
    @apply border-brand-accent bg-brand-accent text-white hover:bg-brand-accent-dark hover:border-brand-accent-dark;
  }
  
  .btn.is-blue {
    @apply border-brand-primary bg-brand-primary text-white hover:bg-brand-primary-dark hover:border-brand-primary-dark;
  }
  
  .text-ColorLime {
    @apply text-brand-accent;
  }
  
  .text-ColorBlue {
    @apply text-brand-primary;
  }
  
  .bg-ColorLime {
    @apply bg-brand-accent;
  }
  
  .bg-ColorBlue {
    @apply bg-brand-primary;
  }
  
  .bg-ColorDenimDarkBlue {
    @apply bg-brand-primary;
  }
  
  .hover\:text-ColorLime:hover {
    @apply hover:text-brand-accent;
  }
  
  .hover\:bg-ColorLime:hover {
    @apply hover:bg-brand-accent;
  }
  
  /* Override Agency11 primary colors with EVFBS brand */
  :root {
    --color-primary: #003366;
    --color-accent: #0066CC;
  }
</style>