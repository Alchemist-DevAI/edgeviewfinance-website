---
// EVFBS Equipment Finance Service Page - Hormozi Framework Implementation
// Tier 1: Human-facing conversion page optimized for persuasion
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import Footer from '../../components/Footer.astro';

const pageData = {
  title: "Equipment Finance | 24-Hour Approvals | Edgeview Finance",
  description: "Get equipment finance approved in 24 hours, not 6 weeks. $20K to $500K+ funding for new or used equipment. Zero upfront fees. 98% approval rate for Australian businesses.",
  keywords: "equipment finance Australia, equipment loans, machinery finance, 24 hour approval, trade equipment funding, construction equipment finance"
};

// Equipment types and financing options
const equipmentTypes = [
  {
    title: "Construction Equipment",
    description: "Excavators, loaders, cranes, compactors, and heavy machinery.",
    examples: ["Excavators", "Bulldozers", "Cranes", "Compactors", "Concrete pumps"],
    priceRange: "$50K - $500K+",
    approvalTime: "24 hours"
  },
  {
    title: "Trade Equipment", 
    description: "Tools and machinery for electricians, plumbers, and skilled trades.",
    examples: ["Work vehicles", "Power tools", "Testing equipment", "Workshop machinery"],
    priceRange: "$20K - $200K",
    approvalTime: "Same day"
  },
  {
    title: "Manufacturing Equipment",
    description: "Production machinery, CNC machines, and industrial equipment.",
    examples: ["CNC machines", "Production lines", "Quality testing", "Packaging equipment"],
    priceRange: "$100K - $1M+",
    approvalTime: "48 hours"
  },
  {
    title: "Technology & IT",
    description: "Computers, servers, software, and business technology.",
    examples: ["Computer systems", "Servers", "Software licences", "Point of sale systems"],
    priceRange: "$10K - $100K",
    approvalTime: "24 hours"
  }
];

// Success stories with real value demonstrations
const successStories = [
  {
    quote: "Got my excavator approved in one day. Banks wanted 6 weeks and endless paperwork. These guys just get it done.",
    author: "Mark Thompson",
    company: "Thompson Earthworks",
    location: "Gold Coast, QLD", 
    rating: 5,
    serviceType: "Equipment Finance",
    loanAmount: "$185K",
    variant: "featured"
  },
  {
    quote: "Zero upfront fees meant I could invest everything into the business. The extra cash flow made all the difference.",
    author: "Sarah Chen", 
    company: "Precision Plumbing",
    location: "Brisbane, QLD",
    rating: 5,
    serviceType: "Trade Equipment",
    loanAmount: "$75K"
  },
  {
    quote: "Fast, professional, no runaround. Got three new vans financed while my competitor was still waiting for bank approval.",
    author: "David Wilson",
    company: "Wilson Electrical", 
    location: "Sunshine Coast, QLD",
    rating: 5,
    serviceType: "Vehicle Finance",
    loanAmount: "$120K"
  }
];

// FAQ data specific to equipment finance
const faqs = [
  {
    question: "What equipment can I finance?",
    answer: "Almost any business equipment including vehicles, machinery, technology, tools, and industrial equipment. New or used, we can finance it if it helps your business make money."
  },
  {
    question: "How much can I borrow?",
    answer: "Equipment finance from $20,000 to $500,000+. Larger amounts available for established businesses with strong cash flow."
  },
  {
    question: "Do I need a deposit?",
    answer: "No deposit required in most cases. We can finance 100% of the equipment cost plus any associated setup or delivery fees."
  },
  {
    question: "What if the equipment breaks down?",
    answer: "You own the equipment, so normal warranty and insurance applies. We can help arrange extended warranties and insurance if needed."
  },
  {
    question: "Can I pay out the loan early?",
    answer: "Yes, early payouts are allowed. Some lenders charge early payout fees, others don't. We'll find you the most flexible terms available."
  }
];
---

<Layout title={pageData.title} description={pageData.description} keywords={pageData.keywords}>
  <Header />
  
  <main>
    
    <!-- Service-Specific Hero -->
    <Hero 
      headline="Equipment Finance That Actually Works"
      subheadline="Get the equipment you need in 24 hours, not 6 weeks"
      description="Stop waiting for bank approval while opportunities slip away. Our proven system gets Australian trades and businesses approved for equipment finance faster than competitors can even apply."
      primaryCTA={{
        text: "Get Quote in 60 Seconds",
        href: "/get-quote"
      }}
      secondaryCTA={{
        text: "Call 1300 733 856", 
        href: "tel:1300733856"
      }}
      trustSignals={[
        "$20K to $500K+ Available",
        "24-Hour Approvals",
        "Zero Upfront Fees",
        "98% Approval Rate"
      ]}
    />

    <!-- Problem Agitation (Hormozi Framework) -->
    <section class="section-padding bg-brand-grey-50">
      <div class="container-default">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-4xl lg:text-5xl font-bold text-brand-grey-900 mb-8">
            Equipment Finance Horror Stories
          </h2>
          <p class="text-xl text-brand-grey-700 mb-12">
            Every day, Australian businesses lose money because banks make equipment finance harder than it needs to be.
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
            <div class="text-center p-6">
              <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-brand-grey-900 mb-3">6+ Week Delays</h3>
              <p class="text-brand-grey-700">Your competitor gets the job because they had equipment ready. You're still waiting for approval.</p>
            </div>
            
            <div class="text-center p-6">
              <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 3h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-brand-grey-900 mb-3">Hidden Costs</h3>
              <p class="text-brand-grey-700">Application fees, establishment fees, early exit fees. Banks nickel and dime you to death.</p>
            </div>
            
            <div class="text-center p-6">
              <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-brand-grey-900 mb-3">Paperwork Nightmare</h3>
              <p class="text-brand-grey-700">Forms, documents, meetings, more forms. Banks make simple things complicated.</p>
            </div>
          </div>
          
          <div class="bg-white p-8 rounded-xl border-l-4 border-red-500">
            <p class="text-lg font-medium text-brand-grey-900 mb-2">The Real Cost:</p>
            <p class="text-brand-grey-700">
              Every week you wait costs your business money. Equipment prices rise. Interest rates change. 
              Opportunities disappear. While you're stuck in bank bureaucracy, smarter businesses are already making money with their new equipment.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution - Equipment Types -->
    <section class="section-padding">
      <div class="container-default">
        <div class="text-center mb-16">
          <h2 class="text-4xl lg:text-5xl font-bold text-brand-grey-900 mb-6">
            Any Equipment. Fast Approval. Zero Hassle.
          </h2>
          <p class="text-xl text-brand-grey-700 max-w-3xl mx-auto">
            We finance any equipment that makes your business money. From small tools to heavy machinery, 
            our streamlined process gets you approved while banks are still asking for more paperwork.
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {equipmentTypes.map((type) => (
            <div class="bg-white p-8 rounded-xl border border-brand-grey-300 hover:border-brand-accent transition-colors duration-200">
              <h3 class="text-2xl font-semibold text-brand-grey-900 mb-4">{type.title}</h3>
              <p class="text-brand-grey-700 mb-6">{type.description}</p>
              
              <div class="mb-6">
                <h4 class="text-sm font-semibold text-brand-grey-900 mb-3">Common Examples:</h4>
                <div class="flex flex-wrap gap-2">
                  {type.examples.map((example) => (
                    <span class="px-3 py-1 bg-brand-grey-100 text-brand-grey-700 rounded-full text-sm">
                      {example}
                    </span>
                  ))}
                </div>
              </div>
              
              <div class="flex items-center justify-between text-sm">
                <div class="flex items-center space-x-1 text-brand-accent">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
                  </svg>
                  <span class="font-medium">{type.priceRange}</span>
                </div>
                
                <div class="flex items-center space-x-1 text-brand-grey-600">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="font-medium">{type.approvalTime}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Value Stack - What You Get -->
    <section class="section-content bg-brand-grey-50">
      <div class="container-default">
        <div class="text-center mb-16">
          <h2 class="text-4xl lg:text-5xl font-bold text-brand-grey-900 mb-6">
            Everything You Get (Worth $12,500+)
          </h2>
          <p class="text-xl text-brand-grey-700 max-w-3xl mx-auto">
            We don't just approve loans. You get a complete equipment finance system that saves time, money, and stress.
          </p>
        </div>
        
        <div class="max-w-4xl mx-auto">
          <div class="space-y-6">
            
            <!-- Speed -->
            <div class="flex items-start space-x-4 p-6 bg-white border border-brand-grey-300 rounded-xl">
              <div class="w-8 h-8 bg-brand-accent rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-brand-grey-900 mb-2">24-Hour Approval System (Worth $5,000)</h3>
                <p class="text-brand-grey-700">Get decisions in 24 hours, not 6 weeks. Strike while opportunities are hot.</p>
              </div>
            </div>
            
            <!-- Zero Fees -->
            <div class="flex items-start space-x-4 p-6 bg-white border border-brand-grey-300 rounded-xl">
              <div class="w-8 h-8 bg-brand-accent rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-brand-grey-900 mb-2">Zero Upfront Fees (Worth $2,500)</h3>
                <p class="text-brand-grey-700">No application fees, no establishment costs. Keep your cash for the business.</p>
              </div>
            </div>
            
            <!-- 100% Financing -->
            <div class="flex items-start space-x-4 p-6 bg-white border border-brand-grey-300 rounded-xl">
              <div class="w-8 h-8 bg-brand-accent rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-brand-grey-900 mb-2">100% Equipment Financing (Worth $3,000)</h3>
                <p class="text-brand-grey-700">Finance the full equipment cost. No deposits, no cash flow impact.</p>
              </div>
            </div>
            
            <!-- Expert Guidance -->
            <div class="flex items-start space-x-4 p-6 bg-white border border-brand-grey-300 rounded-xl">
              <div class="w-8 h-8 bg-brand-accent rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-brand-grey-900 mb-2">Equipment Finance Expertise (Worth $2,000)</h3>
                <p class="text-brand-grey-700">15+ years experience. We know what works and guide you to the best solution.</p>
              </div>
            </div>
            
          </div>
          
          <div class="text-center mt-12 p-8 bg-brand-accent text-white rounded-xl">
            <h3 class="text-2xl font-bold mb-2">Total Value: $12,500+</h3>
            <p class="text-xl mb-4">Your Cost: $0 Upfront</p>
            <p class="text-brand-grey-100">We only get paid when you get approved. No approval = no fees.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof -->
    <section class="section-content">
      <div class="container-default">
        <div class="text-center mb-16">
          <h2 class="text-4xl lg:text-5xl font-bold text-brand-grey-900 mb-6">
            Real Equipment Finance Success Stories
          </h2>
          <p class="text-xl text-brand-grey-700">
            See what happens when businesses choose speed over bureaucracy.
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {successStories.map((story) => (
            <TestimonialCard {...story} />
          ))}
        </div>
      </div>
    </section>

    <!-- Process - How It Works -->
    <section class="section-content bg-brand-primary text-white">
      <div class="container-default">
        <div class="text-center mb-16">
          <h2 class="text-4xl lg:text-5xl font-bold mb-6">
            How Fast Equipment Finance Actually Works
          </h2>
          <p class="text-xl text-brand-grey-100 max-w-3xl mx-auto">
            Simple, fast, no runaround. Here's exactly what happens when you choose the smart way.
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          
          <!-- Step 1 -->
          <div class="text-center">
            <div class="w-16 h-16 bg-brand-accent rounded-full flex items-center justify-center mx-auto mb-6">
              <span class="text-2xl font-bold text-white">1</span>
            </div>
            <h3 class="text-2xl font-semibold mb-4">Apply in 60 Seconds</h3>
            <p class="text-brand-grey-100 leading-relaxed">
              Quick online form or phone call. Tell us what equipment you need and we'll handle the rest.
            </p>
          </div>
          
          <!-- Step 2 -->
          <div class="text-center">
            <div class="w-16 h-16 bg-brand-accent rounded-full flex items-center justify-center mx-auto mb-6">
              <span class="text-2xl font-bold text-white">2</span>
            </div>
            <h3 class="text-2xl font-semibold mb-4">Get Approved Fast</h3>
            <p class="text-brand-grey-100 leading-relaxed">
              We assess your application and get you approved within 24 hours. No committees, no delays.
            </p>
          </div>
          
          <!-- Step 3 -->
          <div class="text-center">
            <div class="w-16 h-16 bg-brand-accent rounded-full flex items-center justify-center mx-auto mb-6">
              <span class="text-2xl font-bold text-white">3</span>
            </div>
            <h3 class="text-2xl font-semibold mb-4">Get Your Equipment</h3>
            <p class="text-brand-grey-100 leading-relaxed">
              We pay the supplier directly. You get your equipment and start making money immediately.
            </p>
          </div>
          
        </div>
        
        <!-- CTA -->
        <div class="text-center mt-16">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-center gap-6">
            <a href="/get-quote" class="btn-accent btn-large inline-flex items-center justify-center group">
              <span>Start Your Application</span>
              <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="tel:1300733856" class="btn-secondary btn-large text-white border-white hover:bg-white hover:text-brand-primary inline-flex items-center justify-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span>Call 1300 733 856</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="section-padding">
      <div class="container-default">
        <div class="text-center mb-16">
          <h2 class="text-4xl lg:text-5xl font-bold text-brand-grey-900 mb-6">
            Equipment Finance Questions (Honest Answers)
          </h2>
        </div>
        
        <div class="max-w-4xl mx-auto space-y-6">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-question w-full text-left">
                <span>{faq.question}</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-answer">
                {faq.answer}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="section-padding bg-brand-grey-50">
      <div class="container-default text-center">
        <h2 class="text-4xl lg:text-5xl font-bold text-brand-grey-900 mb-6">
          Stop Waiting. Start Growing.
        </h2>
        <p class="text-xl text-brand-grey-700 max-w-3xl mx-auto mb-8">
          Every day you wait is money lost. Equipment prices rise. Opportunities disappear. 
          Get the equipment you need today, not next month.
        </p>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-center gap-6">
          <a href="/get-quote" class="btn-primary btn-large inline-flex items-center justify-center group">
            <span>Get Equipment Finance Quote</span>
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="tel:1300733856" class="btn-secondary btn-large inline-flex items-center justify-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>Call 1300 733 856</span>
          </a>
        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>

<style>
  /* FAQ Interactive Styles */
  .faq-item {
    border-bottom: 1px solid var(--brand-grey-300);
    padding: 1.5rem 0;
  }
  
  .faq-question {
    display: flex;
    align-items: center;
    justify-content: between;
    font-weight: 600;
    color: var(--brand-grey-900);
    transition: color 0.2s ease;
  }
  
  .faq-question:hover {
    color: var(--brand-accent);
  }
  
  .faq-question svg {
    margin-left: auto;
    transition: transform 0.2s ease;
  }
  
  .faq-answer {
    margin-top: 1rem;
    color: var(--brand-grey-700);
    line-height: 1.6;
    display: none;
  }
  
  .faq-item.active .faq-answer {
    display: block;
  }
  
  .faq-item.active .faq-question svg {
    transform: rotate(180deg);
  }
</style>

<script>
  // FAQ Interactive Functionality
  document.addEventListener('DOMContentLoaded', function() {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question');
      
      question?.addEventListener('click', () => {
        const isActive = item.classList.contains('active');
        
        // Close all other FAQ items
        faqItems.forEach(otherItem => {
          otherItem.classList.remove('active');
        });
        
        // Toggle current item
        if (!isActive) {
          item.classList.add('active');
        }
      });
    });
  });
</script>