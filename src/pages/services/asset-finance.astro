---
// Asset Finance Service Page - Edgeview Finance
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';

const pageData = {
  title: "Asset Finance Australia | 100% Vehicle & Equipment Finance | Edgeview Finance",
  description: "100% asset financing for vehicles, machinery, and technology. Fast approval with no deposit required. Compare rates and get approved in 24 hours.",
  keywords: "asset finance Australia, vehicle finance, machinery finance, equipment loans, 100% financing",
  canonical: "/services/asset-finance"
};

// Value Equation: (Dream Outcome × Perceived Likelihood) ÷ (Time Delay + Effort & Sacrifice)
const heroData = {
  headline: "100% Asset Finance - No Deposit Required",
  subheadline: "Finance vehicles, machinery, and technology with zero deposit. Get approved in 24 hours with rates from 6.9%.",
  description: "Keep your cash flow strong while getting the assets your business needs. We finance 100% of the asset value so you can preserve working capital for growth.",
  primaryCta: {
    text: "Get Asset Finance Quote",
    href: "/get-quote?service=asset-finance"
  },
  secondaryCta: {
    text: "Calculate Payments",
    href: "/calculator?type=asset-finance"
  },
  image: "/images/asset-finance-hero.jpg",
  imageAlt: "Business vehicles and machinery being financed"
};

const benefitsData = {
  title: "Why Choose Our Asset Finance?",
  subtitle: "100% financing with zero deposit required",
  benefits: [
    {
      icon: "dollar-sign",
      title: "100% Finance Available",
      description: "Finance the full asset value with no deposit. Preserve your cash flow for operations."
    },
    {
      icon: "trending-down",
      title: "Rates from 6.9%",
      description: "Competitive rates with flexible terms from 1-7 years to suit your budget."
    },
    {
      icon: "clock",
      title: "24-Hour Approval",
      description: "Fast approval process so you can secure assets quickly before opportunities pass."
    },
    {
      icon: "shield-check",
      title: "Zero Upfront Costs",
      description: "No application fees, no valuation costs. Only pay when your finance is approved."
    },
    {
      icon: "truck",
      title: "All Asset Types",
      description: "Vehicles, machinery, technology, medical equipment - we finance it all."
    },
    {
      icon: "calculator",
      title: "Tax Benefits",
      description: "Asset finance payments are 100% tax deductible, improving your cash flow position."
    }
  ]
};

const assetTypesData = {
  title: "What Assets Can We Finance?",
  subtitle: "From vehicles to heavy machinery - we finance them all",
  categories: [
    {
      title: "Commercial Vehicles",
      description: "Cars, vans, trucks, trailers, and specialty vehicles",
      assets: ["Cars & SUVs", "Vans & Utilities", "Trucks & Prime Movers", "Trailers & Tankers", "Buses & Coaches", "Specialty Vehicles"]
    },
    {
      title: "Heavy Machinery",
      description: "Construction, mining, and agricultural equipment",
      assets: ["Excavators", "Bulldozers", "Cranes", "Forklifts", "Tractors", "Mining Equipment"]
    },
    {
      title: "Technology & Equipment",
      description: "IT equipment, medical devices, and manufacturing tools",
      assets: ["Computer Systems", "Medical Equipment", "Manufacturing Tools", "Solar Systems", "Kitchen Equipment", "Printing Equipment"]
    }
  ]
};

const processData = {
  title: "Get Asset Finance in 3 Steps",
  subtitle: "Simple process, fast approval",
  steps: [
    {
      number: "01",
      title: "Choose Your Asset",
      description: "Select the vehicle, machinery, or equipment you need. Get quotes from suppliers.",
      time: "Same day"
    },
    {
      number: "02",
      title: "Apply for Finance",
      description: "Submit your application with asset details. We'll assess and provide pre-approval.",
      time: "24 hours"
    },
    {
      number: "03",
      title: "Complete Purchase",
      description: "We pay the supplier directly and you take possession of your new asset.",
      time: "2-5 days"
    }
  ]
};

const faqData = {
  title: "Asset Finance Questions Answered",
  subtitle: "Everything you need to know",
  faqs: [
    {
      question: "Can I finance 100% of the asset value?",
      answer: "Yes. We can finance up to 100% of the asset value with no deposit required. This preserves your working capital for business operations."
    },
    {
      question: "What types of assets can be financed?",
      answer: "We finance all types of business assets including vehicles, machinery, equipment, technology, and more. If it's used for business purposes, we can likely finance it."
    },
    {
      question: "How quickly can I get approved?",
      answer: "Most applications receive pre-approval within 24 hours. Full approval and settlement typically takes 2-5 business days."
    },
    {
      question: "What are the interest rates?",
      answer: "Asset finance rates start from 6.9% depending on the asset type, loan amount, and your business profile. We'll provide exact rates in your quote."
    },
    {
      question: "Are there any upfront fees?",
      answer: "No. We don't charge application fees or upfront costs. You only pay our fee when your finance settles successfully."
    },
    {
      question: "Can I claim tax benefits?",
      answer: "Yes. Asset finance payments are 100% tax deductible, and you may be eligible for instant asset write-offs. Consult your accountant for specific advice."
    }
  ]
};
---

<Layout {...pageData}>
  <Header />
  
  <!-- Hero Section -->
  <Hero {...heroData} />
  
  <!-- Benefits Section -->
  <section class="section-content bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{benefitsData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{benefitsData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefitsData.benefits.map((benefit) => (
          <ServiceCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="benefit"
          />
        ))}
      </div>
    </div>
  </section>
  
  <!-- Asset Types Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{assetTypesData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{assetTypesData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {assetTypesData.categories.map((category) => (
          <div class="bg-white rounded-xl p-8 shadow-soft">
            <h3 class="text-xl font-semibold text-brand-primary mb-4">{category.title}</h3>
            <p class="text-brand-grey-600 mb-6">{category.description}</p>
            <ul class="space-y-2">
              {category.assets.map((asset) => (
                <li class="flex items-center text-brand-grey-700">
                  <svg class="w-4 h-4 text-brand-accent mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {asset}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Process Section -->
  <section class="section-content bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{processData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{processData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {processData.steps.map((step, index) => (
          <div class="relative">
            {index < processData.steps.length - 1 && (
              <div class="hidden lg:block absolute top-16 left-full w-full h-0.5 bg-brand-accent transform -translate-x-1/2 z-0"></div>
            )}
            <div class="bg-white rounded-xl p-8 shadow-soft text-center relative z-10">
              <div class="w-16 h-16 bg-brand-accent rounded-full flex items-center justify-center text-white font-bold text-xl mx-auto mb-6">
                {step.number}
              </div>
              <h3 class="text-xl font-semibold text-brand-primary mb-4">{step.title}</h3>
              <p class="text-brand-grey-600 mb-4">{step.description}</p>
              <div class="text-brand-accent font-medium text-sm">{step.time}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Problem/Solution Section -->
  <section class="section-content bg-brand-primary text-white">
    <div class="container-default">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="heading-large mb-6">Don't Let Cash Flow Stop Your Growth</h2>
          <div class="space-y-6 text-lg">
            <p>Your business needs new assets to grow, but large cash purchases destroy your working capital.</p>
            <p>Without proper cash flow, you can't handle unexpected expenses or take advantage of new opportunities.</p>
            <p><strong>Asset finance solves both problems at once.</strong></p>
          </div>
        </div>
        <div class="bg-white text-brand-primary rounded-xl p-8">
          <h3 class="text-2xl font-semibold mb-6">Asset Finance Benefits</h3>
          <div class="space-y-4">
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Preserve working capital</span>
            </div>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>100% tax deductible payments</span>
            </div>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Fixed monthly payments</span>
            </div>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Fast approval process</span>
            </div>
            <div class="pt-4">
              <a href="/get-quote?service=asset-finance" class="btn-accent w-full text-center">
                Get Asset Finance Quote
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- FAQ Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{faqData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{faqData.subtitle}</p>
      </div>
      
      <div class="max-w-4xl mx-auto space-y-6">
        {faqData.faqs.map((faq) => (
          <div class="bg-white rounded-xl p-6 shadow-soft">
            <h3 class="text-lg font-semibold text-brand-primary mb-3">{faq.question}</h3>
            <p class="text-brand-grey-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Final CTA Section -->
  <section class="section-content bg-brand-accent text-white">
    <div class="container-default text-center">
      <h2 class="heading-large mb-6">Ready to Finance Your Assets?</h2>
      <p class="text-xl mb-8 max-w-2xl mx-auto">
        Get the equipment you need with 100% financing and preserve your working capital.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/get-quote?service=asset-finance" class="btn-white">
          Get Asset Finance Quote
        </a>
        <a href="tel:1300733856" class="btn-outline-white">
          Call 1300 733 856
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>