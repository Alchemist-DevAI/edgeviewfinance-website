---
// Commercial Loans Service Page - Edgeview Finance
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';

const pageData = {
  title: "Commercial Loans Australia | Fast Business Finance | Edgeview Finance",
  description: "Get commercial loans with same-day pre-approval. Fast working capital solutions for Australian businesses. Compare rates and get approved in 24 hours.",
  keywords: "commercial loans Australia, business loans, working capital, fast approval commercial finance",
  canonical: "/services/commercial-loans"
};

// Value Equation: (Dream Outcome × Perceived Likelihood) ÷ (Time Delay + Effort & Sacrifice)
const heroData = {
  headline: "Get Working Capital in 24 Hours",
  subheadline: "Same-day pre-approval on commercial loans up to $5 million. Zero upfront fees. No paperwork delays.",
  description: "Stop losing deals because you're waiting for finance. Get the working capital you need to grow your business with Australia's fastest commercial loan approval process.",
  primaryCta: {
    text: "Get Pre-Approved Today",
    href: "/get-quote?service=commercial-loans"
  },
  secondaryCta: {
    text: "Calculate Repayments",
    href: "/calculator?type=commercial-loan"
  },
  image: "/images/commercial-loans-hero.jpg",
  imageAlt: "Business owner celebrating commercial loan approval"
};

const benefitsData = {
  title: "Why Choose Our Commercial Loans?",
  subtitle: "Fast finance without the bank delays",
  benefits: [
    {
      icon: "clock",
      title: "24-Hour Approval",
      description: "Get pre-approved in 24 hours, not weeks. We understand business moves fast."
    },
    {
      icon: "dollar-sign",
      title: "Up to $5 Million",
      description: "Access working capital from $50,000 to $5 million for any business purpose."
    },
    {
      icon: "shield-check",
      title: "Zero Upfront Fees",
      description: "No application fees, no valuation costs. You only pay when you get approved."
    },
    {
      icon: "trending-up",
      title: "Flexible Terms",
      description: "Terms from 1-7 years with repayment options that match your cash flow."
    },
    {
      icon: "phone",
      title: "Expert Support",
      description: "Direct access to your finance specialist throughout the entire process."
    },
    {
      icon: "check-circle",
      title: "Simple Process",
      description: "Online application takes 10 minutes. We handle all the bank negotiations."
    }
  ]
};

const processData = {
  title: "Get Your Commercial Loan in 3 Simple Steps",
  subtitle: "We make business finance simple",
  steps: [
    {
      number: "01",
      title: "10-Minute Application",
      description: "Tell us about your business and funding needs. No lengthy forms or complex paperwork.",
      time: "10 minutes"
    },
    {
      number: "02",
      title: "Same-Day Pre-Approval",
      description: "Our finance specialists review your application and provide pre-approval within 24 hours.",
      time: "24 hours"
    },
    {
      number: "03",
      title: "Funds in Your Account",
      description: "Once documents are signed, funds are transferred directly to your business account.",
      time: "2-5 days"
    }
  ]
};

const faqData = {
  title: "Commercial Loan Questions Answered",
  subtitle: "Everything you need to know about business finance",
  faqs: [
    {
      question: "What can I use a commercial loan for?",
      answer: "Commercial loans can be used for any legitimate business purpose including working capital, stock purchases, business expansion, equipment, property deposits, debt consolidation, or cash flow management."
    },
    {
      question: "How quickly can I get approved?",
      answer: "We provide same-day pre-approval for most applications. Full approval typically takes 2-5 business days depending on documentation requirements."
    },
    {
      question: "What are the eligibility requirements?",
      answer: "Your business needs to be trading for at least 6 months with annual turnover of $100,000+. We assess based on cash flow, not just credit scores."
    },
    {
      question: "Do you charge application fees?",
      answer: "No. We don't charge application fees, valuation fees, or upfront costs. You only pay our fee when your loan settles successfully."
    },
    {
      question: "What interest rates can I expect?",
      answer: "Rates start from 8.5% depending on your business profile, loan amount, and security offered. We'll provide exact rates in your pre-approval."
    },
    {
      question: "Can I get a loan with bad credit?",
      answer: "Yes. We specialise in alternative lending solutions and assess based on business cash flow, not just credit history."
    }
  ]
};
---

<Layout {...pageData}>
  <Header />
  
  <!-- Hero Section -->
  <Hero {...heroData} />
  
  <!-- Benefits Section -->
  <section class="section-padding bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{benefitsData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{benefitsData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefitsData.benefits.map((benefit) => (
          <ServiceCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="benefit"
          />
        ))}
      </div>
    </div>
  </section>
  
  <!-- Process Section -->
  <section class="section-padding">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{processData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{processData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {processData.steps.map((step, index) => (
          <div class="relative">
            {index < processData.steps.length - 1 && (
              <div class="hidden lg:block absolute top-16 left-full w-full h-0.5 bg-brand-accent transform -translate-x-1/2 z-0"></div>
            )}
            <div class="bg-white rounded-xl p-8 shadow-soft text-center relative z-10">
              <div class="w-16 h-16 bg-brand-accent rounded-full flex items-center justify-center text-white font-bold text-xl mx-auto mb-6">
                {step.number}
              </div>
              <h3 class="text-xl font-semibold text-brand-primary mb-4">{step.title}</h3>
              <p class="text-brand-grey-600 mb-4">{step.description}</p>
              <div class="text-brand-accent font-medium text-sm">{step.time}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Problem/Solution Section -->
  <section class="section-padding bg-brand-primary text-white">
    <div class="container-default">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="heading-large mb-6">Stop Losing Deals to Cash Flow Problems</h2>
          <div class="space-y-6 text-lg">
            <p>Every day you wait for finance approval, your competitors are winning the deals you should be getting.</p>
            <p>Bank loans take 6-12 weeks. By then, the opportunity is gone and your business has missed out on growth.</p>
            <p><strong>What if you could get pre-approved in 24 hours instead?</strong></p>
          </div>
        </div>
        <div class="bg-white text-brand-primary rounded-xl p-8">
          <h3 class="text-2xl font-semibold mb-6">The Cost of Waiting</h3>
          <div class="space-y-4">
            <div class="flex justify-between items-center border-b border-brand-grey-200 pb-2">
              <span>Lost sales opportunities</span>
              <span class="font-semibold">$50,000+</span>
            </div>
            <div class="flex justify-between items-center border-b border-brand-grey-200 pb-2">
              <span>Delayed business growth</span>
              <span class="font-semibold">6-12 months</span>
            </div>
            <div class="flex justify-between items-center border-b border-brand-grey-200 pb-2">
              <span>Competitor advantage</span>
              <span class="font-semibold">Priceless</span>
            </div>
            <div class="pt-4">
              <a href="/get-quote?service=commercial-loans" class="btn-accent w-full text-center">
                Get Pre-Approved Today
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- FAQ Section -->
  <section class="section-padding">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{faqData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{faqData.subtitle}</p>
      </div>
      
      <div class="max-w-4xl mx-auto space-y-6">
        {faqData.faqs.map((faq) => (
          <div class="bg-white rounded-xl p-6 shadow-soft">
            <h3 class="text-lg font-semibold text-brand-primary mb-3">{faq.question}</h3>
            <p class="text-brand-grey-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Final CTA Section -->
  <section class="section-padding bg-brand-accent text-white">
    <div class="container-default text-center">
      <h2 class="heading-large mb-6">Ready to Get Your Commercial Loan?</h2>
      <p class="text-xl mb-8 max-w-2xl mx-auto">
        Join thousands of Australian businesses who've secured fast finance through Edgeview Finance.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/get-quote?service=commercial-loans" class="btn-white">
          Get Pre-Approved Now
        </a>
        <a href="tel:1300733856" class="btn-outline-white">
          Call 1300 733 856
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>