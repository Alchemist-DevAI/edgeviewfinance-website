---
// Business Loans Service Page - Edgeview Finance
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';

const pageData = {
  title: "Business Loans Australia | Fast Unsecured Business Finance | Edgeview Finance",
  description: "Get unsecured business loans up to $500k with same-day approval. No security required. Fast working capital for Australian businesses.",
  keywords: "business loans Australia, unsecured business loans, fast business finance, working capital loans",
  canonical: "/services/business-loans"
};

// Value Equation: (Dream Outcome × Perceived Likelihood) ÷ (Time Delay + Effort & Sacrifice)
const heroData = {
  headline: "Unsecured Business Loans Up to $500k",
  subheadline: "Same-day approval on unsecured business loans. No security, no property risk. Get working capital in 48 hours.",
  description: "Access fast business finance without putting your home or business property at risk. Perfect for immediate cash flow needs and growth opportunities.",
  primaryCta: {
    text: "Get Business Loan Quote",
    href: "/get-quote?service=business-loans"
  },
  secondaryCta: {
    text: "Check Eligibility",
    href: "/calculator?type=business-loan"
  },
  image: "/images/business-loans-hero.jpg",
  imageAlt: "Business owner receiving unsecured business loan approval"
};

const benefitsData = {
  title: "Why Choose Our Business Loans?",
  subtitle: "Fast, unsecured financing without the risk",
  benefits: [
    {
      icon: "shield-check",
      title: "No Security Required",
      description: "Unsecured loans mean no property risk. Your home and business assets stay protected."
    },
    {
      icon: "clock",
      title: "Same-Day Approval",
      description: "Get approved in hours, not weeks. Perfect for urgent business opportunities."
    },
    {
      icon: "dollar-sign",
      title: "Up to $500,000",
      description: "Access substantial working capital from $10,000 to $500,000 for any business purpose."
    },
    {
      icon: "trending-up",
      title: "Flexible Terms",
      description: "Choose terms from 3 months to 3 years with flexible repayment options."
    },
    {
      icon: "calculator",
      title: "Simple Application",
      description: "Online application takes 10 minutes. Minimal documentation required."
    },
    {
      icon: "phone",
      title: "Expert Support",
      description: "Personal service from application to settlement with no hidden fees."
    }
  ]
};

const useCasesData = {
  title: "What Can You Use Business Loans For?",
  subtitle: "Flexible funding for any business purpose",
  useCases: [
    {
      title: "Cash Flow Management",
      description: "Bridge temporary cash flow gaps and maintain operations during slow periods",
      icon: "trending-up"
    },
    {
      title: "Growth Opportunities", 
      description: "Fund expansion, new products, marketing campaigns, or staff hiring",
      icon: "rocket"
    },
    {
      title: "Stock & Inventory",
      description: "Purchase inventory, raw materials, or seasonal stock for peak periods",
      icon: "package"
    },
    {
      title: "Business Expenses",
      description: "Cover rent, wages, supplier payments, or unexpected business costs",
      icon: "receipt"
    },
    {
      title: "Debt Consolidation",
      description: "Consolidate multiple debts into one manageable payment with better terms",
      icon: "layers"
    },
    {
      title: "Emergency Funding",
      description: "Access funds quickly for unexpected repairs, equipment failure, or emergencies",
      icon: "alert-circle"
    }
  ]
};

const processData = {
  title: "Get Your Business Loan in 3 Steps",
  subtitle: "Simple process, fast funding",
  steps: [
    {
      number: "01",
      title: "Quick Application",
      description: "Complete our 10-minute online application with basic business information.",
      time: "10 minutes"
    },
    {
      number: "02",
      title: "Instant Assessment",
      description: "Our technology assesses your application and provides same-day approval decision.",
      time: "Same day"
    },
    {
      number: "03",
      title: "Receive Funds",
      description: "Once approved, funds are transferred directly to your business account.",
      time: "24-48 hours"
    }
  ]
};

const comparisonData = {
  title: "Business Loans vs Bank Loans",
  subtitle: "See why businesses choose us over traditional banks",
  comparison: [
    {
      feature: "Approval Time",
      businessLoan: "Same day",
      bankLoan: "4-8 weeks"
    },
    {
      feature: "Security Required",
      businessLoan: "None",
      bankLoan: "Property/assets"
    },
    {
      feature: "Documentation",
      businessLoan: "Minimal",
      bankLoan: "Extensive"
    },
    {
      feature: "Credit Requirements",
      businessLoan: "Flexible",
      bankLoan: "Strict"
    },
    {
      feature: "Funding Speed",
      businessLoan: "24-48 hours",
      bankLoan: "2-4 weeks"
    }
  ]
};

const faqData = {
  title: "Business Loan Questions Answered",
  subtitle: "Everything you need to know about unsecured business finance",
  faqs: [
    {
      question: "How much can I borrow with an unsecured business loan?",
      answer: "You can borrow between $10,000 and $500,000 depending on your business turnover, trading history, and cash flow capacity."
    },
    {
      question: "Do I need to provide security or guarantee?",
      answer: "No. Our business loans are unsecured, meaning you don't need to put up property or assets as security. However, a personal guarantee may be required."
    },
    {
      question: "How quickly can I get the money?",
      answer: "Once approved, funds are typically transferred within 24-48 hours. Some applications can be funded the same day."
    },
    {
      question: "What are the eligibility requirements?",
      answer: "Your business needs to be trading for at least 6 months with minimum turnover of $10,000 per month. We assess based on cash flow and business performance."
    },
    {
      question: "What interest rates can I expect?",
      answer: "Interest rates vary from 12% to 35% depending on loan amount, term, and your business risk profile. We'll provide exact rates in your quote."
    },
    {
      question: "Are there any upfront fees?",
      answer: "No application fees or upfront costs. We only charge an establishment fee when your loan is approved and funded."
    }
  ]
};
---

<Layout {...pageData}>
  <Header />
  
  <!-- Hero Section -->
  <Hero {...heroData} />
  
  <!-- Benefits Section -->
  <section class="section-content bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{benefitsData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{benefitsData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefitsData.benefits.map((benefit) => (
          <ServiceCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="benefit"
          />
        ))}
      </div>
    </div>
  </section>
  
  <!-- Use Cases Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{useCasesData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{useCasesData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {useCasesData.useCases.map((useCase) => (
          <div class="bg-white rounded-xl p-6 shadow-soft hover:shadow-hover transition-shadow duration-200">
            <div class="w-12 h-12 bg-brand-accent rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                {useCase.icon === 'trending-up' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                )}
                {useCase.icon === 'rocket' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                )}
                {useCase.icon === 'package' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                )}
                {useCase.icon === 'receipt' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                )}
                {useCase.icon === 'layers' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
                )}
                {useCase.icon === 'alert-circle' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.464 0L4.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
                )}
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-brand-primary mb-3">{useCase.title}</h3>
            <p class="text-brand-grey-600">{useCase.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Comparison Section -->
  <section class="section-content bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{comparisonData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{comparisonData.subtitle}</p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-xl shadow-soft overflow-hidden">
          <div class="grid grid-cols-3 bg-brand-primary text-white p-6">
            <div class="font-semibold">Feature</div>
            <div class="font-semibold text-center">Our Business Loans</div>
            <div class="font-semibold text-center">Traditional Banks</div>
          </div>
          {comparisonData.comparison.map((item, index) => (
            <div class={`grid grid-cols-3 p-6 ${index % 2 === 0 ? 'bg-brand-grey-50' : 'bg-white'}`}>
              <div class="font-medium text-brand-grey-700">{item.feature}</div>
              <div class="text-center text-brand-accent font-semibold">{item.businessLoan}</div>
              <div class="text-center text-brand-grey-500">{item.bankLoan}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  
  <!-- Process Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{processData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{processData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {processData.steps.map((step, index) => (
          <div class="relative">
            {index < processData.steps.length - 1 && (
              <div class="hidden lg:block absolute top-16 left-full w-full h-0.5 bg-brand-accent transform -translate-x-1/2 z-0"></div>
            )}
            <div class="bg-white rounded-xl p-8 shadow-soft text-center relative z-10">
              <div class="w-16 h-16 bg-brand-accent rounded-full flex items-center justify-center text-white font-bold text-xl mx-auto mb-6">
                {step.number}
              </div>
              <h3 class="text-xl font-semibold text-brand-primary mb-4">{step.title}</h3>
              <p class="text-brand-grey-600 mb-4">{step.description}</p>
              <div class="text-brand-accent font-medium text-sm">{step.time}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Problem/Solution Section -->
  <section class="section-content bg-brand-primary text-white">
    <div class="container-default">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="heading-large mb-6">Banks Say No, We Say Yes</h2>
          <div class="space-y-6 text-lg">
            <p>Traditional banks require extensive paperwork, property security, and perfect credit scores.</p>
            <p>Their approval process takes weeks, and by then your business opportunity has passed.</p>
            <p><strong>We approve based on your business performance, not just credit history.</strong></p>
          </div>
        </div>
        <div class="bg-white text-brand-primary rounded-xl p-8">
          <h3 class="text-2xl font-semibold mb-6">Why Businesses Choose Us</h3>
          <div class="space-y-4">
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>No property at risk</span>
            </div>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Same-day approval</span>
            </div>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Minimal documentation</span>
            </div>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Flexible eligibility</span>
            </div>
            <div class="pt-4">
              <a href="/get-quote?service=business-loans" class="btn-accent w-full text-center">
                Get Business Loan Quote
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- FAQ Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{faqData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{faqData.subtitle}</p>
      </div>
      
      <div class="max-w-4xl mx-auto space-y-6">
        {faqData.faqs.map((faq) => (
          <div class="bg-white rounded-xl p-6 shadow-soft">
            <h3 class="text-lg font-semibold text-brand-primary mb-3">{faq.question}</h3>
            <p class="text-brand-grey-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Final CTA Section -->
  <section class="section-content bg-brand-accent text-white">
    <div class="container-default text-center">
      <h2 class="heading-large mb-6">Ready for Your Business Loan?</h2>
      <p class="text-xl mb-8 max-w-2xl mx-auto">
        Get the working capital you need without putting your property at risk.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/get-quote?service=business-loans" class="btn-white">
          Get Business Loan Quote
        </a>
        <a href="tel:1300733856" class="btn-outline-white">
          Call 1300 733 856
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>