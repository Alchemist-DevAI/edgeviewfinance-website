---
// Hire Purchase Service Page - Edgeview Finance
export const prerender = true;

import Agency11Layout from '../../layouts/Agency11Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';

const pageData = {
  title: "Hire Purchase Australia | Own Equipment with Fixed Payments | Edgeview Finance",
  description: "Hire purchase agreements with ownership at end. Fixed monthly payments for vehicles and equipment. Tax benefits and 100% financing available.",
  keywords: "hire purchase Australia, equipment hire purchase, vehicle hire purchase, fixed payment finance",
  canonical: "/services/hire-purchase"
};

// Value Equation: (Dream Outcome × Perceived Likelihood) ÷ (Time Delay + Effort & Sacrifice)
const heroData = {
  headline: "Own Your Equipment with Hire Purchase",
  subheadline: "Fixed monthly payments with ownership guaranteed at the end. Perfect for vehicles, machinery, and essential business equipment.",
  description: "Get the certainty of ownership with predictable monthly payments. Hire purchase gives you control over your assets while preserving cash flow for operations.",
  primaryCta: {
    text: "Get Hire Purchase Quote",
    href: "/get-quote?service=hire-purchase"
  },
  secondaryCta: {
    text: "Calculate Payments",
    href: "/calculator?type=hire-purchase"
  },
  image: "/images/hire-purchase-hero.jpg",
  imageAlt: "Business owner taking ownership of equipment through hire purchase"
};

const benefitsData = {
  title: "Why Choose Hire Purchase?",
  subtitle: "Predictable payments with guaranteed ownership",
  benefits: [
    {
      icon: "check-circle",
      title: "Guaranteed Ownership",
      description: "Own the equipment at the end of the term. No balloon payments or buy-back worries."
    },
    {
      icon: "calculator",
      title: "Fixed Monthly Payments",
      description: "Lock in your monthly payments for the entire term. Perfect for budgeting and cash flow."
    },
    {
      icon: "trending-down",
      title: "Tax Advantages", 
      description: "Claim payments as tax deductions and depreciation benefits throughout the term."
    },
    {
      icon: "shield-check",
      title: "Asset Protection",
      description: "Build equity in valuable business assets while maintaining strong cash flow."
    },
    {
      icon: "dollar-sign",
      title: "100% Financing",
      description: "Finance up to 100% of the equipment value with no deposit required in many cases."
    },
    {
      icon: "clock",
      title: "Fast Approval",
      description: "Get approved quickly and secure your equipment before opportunities pass."
    }
  ]
};

const comparisonData = {
  title: "Hire Purchase vs Leasing vs Buying",
  subtitle: "See why hire purchase might be right for your business",
  options: [
    {
      title: "Hire Purchase",
      features: [
        "Own the asset at the end",
        "Fixed monthly payments",
        "Tax deductible payments",
        "Build asset equity",
        "No balloon payment"
      ],
      highlight: true
    },
    {
      title: "Operating Lease",
      features: [
        "Never own the asset",
        "Fixed monthly payments",
        "100% tax deductible",
        "No asset risk",
        "Return at end"
      ],
      highlight: false
    },
    {
      title: "Cash Purchase",
      features: [
        "Immediate ownership",
        "No monthly payments",
        "Depreciation benefits",
        "Major cash outlay",
        "Opportunity cost"
      ],
      highlight: false
    }
  ]
};

const processData = {
  title: "Hire Purchase in 4 Simple Steps",
  subtitle: "From application to ownership",
  steps: [
    {
      number: "01",
      title: "Choose Equipment",
      description: "Select the vehicles, machinery, or equipment your business needs from any supplier.",
      time: "Same day"
    },
    {
      number: "02",
      title: "Apply for Finance",
      description: "Submit your hire purchase application with equipment details and business information.",
      time: "10 minutes"
    },
    {
      number: "03",
      title: "Get Approved",
      description: "Receive approval and fixed payment schedule. We handle all supplier arrangements.",
      time: "24-48 hours"
    },
    {
      number: "04",
      title: "Start Using & Owning",
      description: "Take possession immediately and start making fixed payments until you own it outright.",
      time: "Ongoing"
    }
  ]
};

const suitabilityData = {
  title: "Is Hire Purchase Right for You?",
  subtitle: "Perfect for businesses that want to own their equipment",
  ideal: [
    "Want guaranteed ownership at the end",
    "Prefer predictable fixed payments",
    "Plan to keep equipment long-term",
    "Want to build asset equity",
    "Need equipment for core operations"
  ],
  notIdeal: [
    "Want latest technology upgrades",
    "Prefer 100% tax deductions",
    "Don't want asset ownership risk",
    "Need short-term equipment use",
    "Want maximum cash flow flexibility"
  ]
};

const faqData = {
  title: "Hire Purchase Questions Answered", 
  subtitle: "Everything you need to know about hire purchase agreements",
  faqs: [
    {
      question: "What happens at the end of a hire purchase agreement?",
      answer: "You automatically own the equipment once all payments are made. There's no balloon payment or additional fees - the asset becomes yours outright."
    },
    {
      question: "Can I pay out a hire purchase early?",
      answer: "Yes, you can pay out your hire purchase agreement early at any time. We'll provide a payout figure that may include early termination savings."
    },
    {
      question: "What are the tax benefits of hire purchase?",
      answer: "You can claim hire purchase payments as tax deductions, plus depreciation benefits on the asset. This can significantly reduce your effective cost."
    },
    {
      question: "Do I need a deposit for hire purchase?",
      answer: "Not necessarily. We can often arrange 100% financing depending on the equipment type and your business profile."
    },
    {
      question: "What types of equipment can be hire purchased?",
      answer: "Almost any business equipment including vehicles, machinery, technology, medical equipment, and more. The equipment must have a useful business life."
    },
    {
      question: "How are hire purchase payments calculated?",
      answer: "Payments are fixed monthly amounts calculated over your chosen term (typically 1-7 years) including principal and interest. You'll know exactly what you'll pay each month."
    }
  ]
};
---

<Agency11Layout {...pageData}>
  <Header />
  
  <!-- Hero Section -->
  <Hero {...heroData} />
  
  <!-- Benefits Section -->
  <section class="section-content bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{benefitsData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{benefitsData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefitsData.benefits.map((benefit) => (
          <ServiceCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="benefit"
          />
        ))}
      </div>
    </div>
  </section>
  
  <!-- Comparison Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{comparisonData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{comparisonData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {comparisonData.options.map((option) => (
          <div class={`rounded-xl p-8 shadow-soft ${option.highlight ? 'bg-brand-primary text-white' : 'bg-white'}`}>
            <h3 class={`text-xl font-semibold mb-6 text-center ${option.highlight ? 'text-white' : 'text-brand-primary'}`}>
              {option.title}
            </h3>
            <ul class="space-y-3">
              {option.features.map((feature) => (
                <li class="flex items-center">
                  <svg class={`w-5 h-5 mr-3 flex-shrink-0 ${option.highlight ? 'text-brand-accent' : 'text-brand-accent'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class={option.highlight ? 'text-white' : 'text-brand-grey-700'}>{feature}</span>
                </li>
              ))}
            </ul>
            {option.highlight && (
              <div class="mt-6 pt-6 border-t border-brand-accent">
                <a href="/get-quote?service=hire-purchase" class="btn-accent w-full text-center">
                  Get Hire Purchase Quote
                </a>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Process Section -->
  <section class="section-content bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{processData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{processData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        {processData.steps.map((step, index) => (
          <div class="relative">
            {index < processData.steps.length - 1 && (
              <div class="hidden lg:block absolute top-16 left-full w-full h-0.5 bg-brand-accent transform -translate-x-1/2 z-0"></div>
            )}
            <div class="bg-white rounded-xl p-6 shadow-soft text-center relative z-10">
              <div class="w-16 h-16 bg-brand-accent rounded-full flex items-center justify-center text-white font-bold text-lg mx-auto mb-4">
                {step.number}
              </div>
              <h3 class="text-lg font-semibold text-brand-primary mb-3">{step.title}</h3>
              <p class="text-brand-grey-600 mb-3 text-sm">{step.description}</p>
              <div class="text-brand-accent font-medium text-xs">{step.time}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Suitability Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{suitabilityData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{suitabilityData.subtitle}</p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        <!-- Ideal For -->
        <div class="bg-green-50 rounded-xl p-8">
          <div class="flex items-center mb-6">
            <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-green-800">Ideal if you...</h3>
          </div>
          <ul class="space-y-3">
            {suitabilityData.ideal.map((item) => (
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-green-800">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        
        <!-- Not Ideal For -->
        <div class="bg-orange-50 rounded-xl p-8">
          <div class="flex items-center mb-6">
            <div class="w-12 h-12 bg-orange-500 rounded-full flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.464 0L4.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-orange-800">Consider alternatives if you...</h3>
          </div>
          <ul class="space-y-3">
            {suitabilityData.notIdeal.map((item) => (
              <li class="flex items-start">
                <svg class="w-5 h-5 text-orange-500 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.464 0L4.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
                <span class="text-orange-800">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Problem/Solution Section -->
  <section class="section-content bg-brand-primary text-white">
    <div class="container-default">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="heading-large mb-6">Leasing vs Buying vs Hire Purchase</h2>
          <div class="space-y-6 text-lg">
            <p>Leasing means you never own anything. Cash purchases drain your working capital.</p>
            <p>Hire purchase gives you the best of both worlds - predictable payments AND guaranteed ownership.</p>
            <p><strong>Build equity while preserving cash flow.</strong></p>
          </div>
        </div>
        <div class="bg-white text-brand-primary rounded-xl p-8">
          <h3 class="text-2xl font-semibold mb-6">Hire Purchase Advantages</h3>
          <div class="space-y-4">
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Own equipment at the end</span>
            </div>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Fixed monthly budgeting</span>
            </div>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Tax deductible payments</span>
            </div>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-brand-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Build business assets</span>
            </div>
            <div class="pt-4">
              <a href="/get-quote?service=hire-purchase" class="btn-accent w-full text-center">
                Get Hire Purchase Quote
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- FAQ Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-16">
        <h2 class="heading-large text-brand-primary mb-4">{faqData.title}</h2>
        <p class="text-xl text-brand-grey-600 max-w-2xl mx-auto">{faqData.subtitle}</p>
      </div>
      
      <div class="max-w-4xl mx-auto space-y-6">
        {faqData.faqs.map((faq) => (
          <div class="bg-white rounded-xl p-6 shadow-soft">
            <h3 class="text-lg font-semibold text-brand-primary mb-3">{faq.question}</h3>
            <p class="text-brand-grey-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Final CTA Section -->
  <section class="section-content bg-brand-accent text-white">
    <div class="container-default text-center">
      <h2 class="heading-large mb-6">Ready for Hire Purchase?</h2>
      <p class="text-xl mb-8 max-w-2xl mx-auto">
        Get predictable payments with guaranteed ownership. Perfect for building business assets.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/get-quote?service=hire-purchase" class="btn-white">
          Get Hire Purchase Quote
        </a>
        <a href="tel:1300733856" class="btn-outline-white">
          Call 1300 733 856
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Agency11Layout>