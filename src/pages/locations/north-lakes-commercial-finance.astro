        "name": "North Lakes Commercial Finance Solutions",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "North Lakes Equipment Finance",
              "description": "Strategic equipment finance for North Lakes commercial trades, logistics operators, and industrial businesses"
            }
          },
          {
            "@type": "Offer", 
            "itemOffered": {
              "@type": "Service",
              "name": "North Lakes Commercial Property Finance",
