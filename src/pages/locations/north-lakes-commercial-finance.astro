---
// North Lakes Commercial Finance - Location-Specific Page
// Optimized for "Ben the Business Builder" ICP in North Lakes growth corridor
export const prerender = true;

const siteData = {
  title: "Commercial Finance North Lakes | Equipment & Business Loans QLD",
  description: "Strategic commercial finance solutions for North Lakes industrial and commercial businesses. Equipment finance, commercial property, working capital specialist. ASIC licensed broker serving Brisbane's northern growth corridor.",
  keywords: "commercial finance North Lakes, equipment finance QLD, business loans North Lakes, industrial finance, working capital Brisbane north, commercial property finance"
};

const locationData = {
  city: "North Lakes",
  state: "QLD", 
  serviceAreas: [
    "North Lakes Industrial", "Mango Hill Business Park", "Griffin Industrial", "Kallangur Industrial",
    "Petrie Industrial", "Lawnton Commercial", "Strathpine Industrial", "Brendale Industrial",
    "Bray Park Commercial", "Warner Industrial", "Eatons Hill Business", "Albany Creek Commercial",
    "Aura Business Park", "Caloundra Industrial", "Caboolture Industrial", "Morayfield Industrial",
    "Narangba Industrial", "Burpengary Industrial", "Deception Bay Industrial", "Rothwell Industrial",
    "Redcliffe Industrial", "Kippa-Ring Commercial", "Margate Industrial", "Sandgate Commercial"
  ]
};
---

<html lang="en-AU">
<head>
