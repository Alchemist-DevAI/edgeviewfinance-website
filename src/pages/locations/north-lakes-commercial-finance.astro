    <meta name="keywords" content={siteData.keywords} />
    
    <!-- Local SEO Tags -->
    <meta name="geo.region" content="AU-QLD" />
    <meta name="geo.placename" content="North Lakes" />
    <meta name="geo.position" content="-27.2308,153.0169" />
    <meta name="ICBM" content="-27.2308,153.0169" />
    
