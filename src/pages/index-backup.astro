---
// EVFBS Homepage with Agency11 Theme Integration
export const prerender = true;

import Agency11Layout from '../layouts/Agency11Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// EVFBS brand images will be added later

const siteData = {
  title: "Expert Commercial Finance Solutions | Edgeview Finance",
  description: "Professional commercial finance solutions for Australian businesses. Specialising in equipment finance, asset finance, and business loans with competitive rates and expert guidance. Zero upfront fees.",
  keywords: "commercial finance Australia, equipment finance, business loans, asset finance, trade finance, professional finance broker"
};

// Hero section data for Agency11 theme
const heroData = {
  data: {
    header: "Expert Commercial Finance Solutions",
    description: "Access competitive commercial finance solutions with expert guidance. Our experienced team specialises in equipment finance, asset finance, and business loans for established Australian businesses. Zero upfront fees.",
    buttonPrimary: {
      text: "Get Quote in 60 Seconds",
      link: "/get-quote"
    },
    buttonSecondary: {
      text: "Call 1300 733 856",
      link: "tel:1300733856"
    }
  }
};
---

<Agency11Layout title={siteData.title} description={siteData.description} keywords={siteData.keywords}>
  <Header />
  
  <main>
    <!-- Hero Section with Agency11 Styling -->
    <section class='section-hero'>
      <div class='relative z-10 overflow-hidden'>
        <div class='pt-[105px] sm:pt-[145px] lg:pt-[185px]'>
          <div class='container-default relative z-10'>
            <div class='text-center'>
              <h1 class='jos -trackig-[1px] mx-auto mb-6 font-PublicSans text-5xl font-bold leading-[1.06] text-secondary-dark md:max-w-[80%] md:text-[60px] lg:max-w-[70%] lg:text-[70px] xl:max-w-[856px] xl:text-[90px]'>
                {heroData.data.header}
              </h1>
              <p class='jos mx-auto mb-8 max-w-[658px] lg:mb-[50px] text-gray-700'>
                {heroData.data.description}
              </p>
              <div class='jos flex flex-wrap justify-center gap-[18px]'>
                <a href={heroData.data.buttonPrimary.link} class='btn is-primary is-large btn-animation group rounded-[3px] bg-primary-orange hover:bg-primary-orange-dark text-white px-8 py-4 font-semibold'>
                  <span>{heroData.data.buttonPrimary.text}</span>
                </a>
                <a href={heroData.data.buttonSecondary.link} class='btn is-outline-black is-large btn-animation group rounded-[3px] border-2 border-secondary-dark text-secondary-dark hover:bg-secondary-dark hover:text-white px-8 py-4 font-semibold'>
                  <span>{heroData.data.buttonSecondary.text}</span>
                </a>
              </div>
            </div>
            
            <!-- Trust Signals -->
            <div class="mt-12 flex flex-wrap justify-center gap-8 text-center">
              <div class="flex flex-col items-center">
                <span class="text-3xl font-bold text-primary-orange">15+</span>
                <span class="text-sm text-gray-600">Years Experience</span>
              </div>
              <div class="flex flex-col items-center">
                <span class="text-3xl font-bold text-primary-orange">98%</span>
                <span class="text-sm text-gray-600">Approval Rate</span>
              </div>
              <div class="flex flex-col items-center">
                <span class="text-3xl font-bold text-primary-orange">$500M+</span>
                <span class="text-sm text-gray-600">Funded</span>
              </div>
              <div class="flex flex-col items-center">
                <span class="text-3xl font-bold text-primary-orange">Zero</span>
                <span class="text-sm text-gray-600">Upfront Fees</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section with Agency11 Cards -->
    <section class="section-padding bg-neutral-light">
      <div class="container-default">
        <div class="text-center mb-16">
          <h2 class="text-4xl lg:text-5xl font-bold text-secondary-dark mb-6">
            Professional Commercial Finance Solutions
          </h2>
          <p class="text-xl text-gray-700 max-w-3xl mx-auto">
            Our experienced team provides professional commercial finance solutions. 
            Transparent processes, competitive rates, expert guidance.
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Equipment Finance Card -->
          <div class="bg-white rounded-lg p-8 shadow-lg hover:shadow-xl transition-shadow border-t-4 border-primary-orange">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 bg-primary-orange rounded-full flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-secondary-dark">Equipment Finance</h3>
            </div>
            <p class="text-gray-700 mb-4">
              Access competitive equipment finance solutions tailored to your business needs. 
              Professional service with flexible terms and comprehensive support.
            </p>
            <div class="space-y-2 mb-6">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">$20K to $500K+ funding</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">Zero upfront fees</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">Flexible payment terms</span>
              </div>
            </div>
            <a href="/services/equipment-finance" class="inline-flex items-center text-primary-orange font-semibold hover:text-primary-orange-dark transition-colors">
              Learn More 
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>

          <!-- Commercial Loans Card -->
          <div class="bg-white rounded-lg p-8 shadow-lg hover:shadow-xl transition-shadow border-t-4 border-secondary-dark">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 bg-secondary-dark rounded-full flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-secondary-dark">Commercial Loans</h3>
            </div>
            <p class="text-gray-700 mb-4">
              Comprehensive working capital solutions designed for established businesses. 
              Expert guidance through streamlined processes.
            </p>
            <div class="space-y-2 mb-6">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">Working capital up to $250K</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">Streamlined application</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">Use funds for anything</span>
              </div>
            </div>
            <a href="/services/commercial-loans" class="inline-flex items-center text-secondary-dark font-semibold hover:text-primary-orange transition-colors">
              Learn More 
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>

          <!-- Asset Finance Card -->
          <div class="bg-white rounded-lg p-8 shadow-lg hover:shadow-xl transition-shadow border-t-4 border-primary-orange">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 bg-gradient-to-r from-primary-orange to-secondary-dark rounded-full flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-secondary-dark">Asset Finance</h3>
            </div>
            <p class="text-gray-700 mb-4">
              Own your equipment, don't rent it. Build business equity while you use the assets that make you money.
            </p>
            <div class="space-y-2 mb-6">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">100% asset financing available</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">Build business equity</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">Tax benefits included</span>
              </div>
            </div>
            <a href="/services/asset-finance" class="inline-flex items-center text-primary-orange font-semibold hover:text-primary-orange-dark transition-colors">
              Learn More 
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>

          <!-- Hire Purchase Card -->
          <div class="bg-white rounded-lg p-8 shadow-lg hover:shadow-xl transition-shadow border-t-4 border-secondary-dark">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 bg-secondary-dark rounded-full flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-secondary-dark">Hire Purchase</h3>
            </div>
            <p class="text-gray-700 mb-4">
              Get equipment now, own it later. Spread costs over time while your new equipment pays for itself.
            </p>
            <div class="space-y-2 mb-6">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">Own the asset at the end</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">Low deposit options</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-primary-orange mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm">Simple approval process</span>
              </div>
            </div>
            <a href="/services/hire-purchase" class="inline-flex items-center text-secondary-dark font-semibold hover:text-primary-orange transition-colors">
              Learn More 
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section with Figma Gradient -->
    <section class="py-16 bg-gradient-to-r from-primary-orange via-primary-orange-light to-secondary-dark">
      <div class="container-default text-center">
        <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
          Ready to Explore Your Finance Options?
        </h2>
        <p class="text-xl text-white/90 max-w-3xl mx-auto mb-8">
          Make informed decisions about your business finance needs. Our expert team is ready to discuss competitive solutions tailored to your specific requirements.
        </p>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-center gap-6">
          <a href="/get-quote" class="bg-white hover:bg-neutral-light text-secondary-dark px-8 py-4 rounded-[3px] font-semibold inline-flex items-center justify-center group transition-all shadow-lg hover:shadow-xl">
            <span>Get Your Quote Now</span>
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="tel:1300733856" class="bg-white/10 backdrop-blur border-2 border-white text-white hover:bg-white hover:text-secondary-dark px-8 py-4 rounded-[3px] font-semibold inline-flex items-center justify-center transition-all">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>Call 1300 733 856</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Agency11Layout>

<style>
  /* Agency11 inspired animations and utilities */
  .btn-animation {
    transition: all 0.3s ease;
  }
  
  .btn-animation:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }
  
  .container-default {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  .section-padding {
    padding: 4rem 0;
  }
  
  @media (min-width: 768px) {
    .section-padding {
      padding: 6rem 0;
    }
  }
</style>