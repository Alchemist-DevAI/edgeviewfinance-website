---
import Agency11Layout from '../layouts/Agency11Layout.astro';

const pageTitle = 'Commercial Finance FAQs Australia | Equipment Finance Questions | EVFBS';
const pageDescription = 'Comprehensive FAQ covering equipment finance, commercial property, working capital, invoice financing, and application processes for Australian commercial trades and civil contractors.';

const faqCategories = [
  {
    category: "Equipment Finance",
    faqs: [
      {
        question: "What types of equipment can be financed?",
        answer: "We finance virtually all types of business equipment including machinery, vehicles, trucks, trailers, excavators, loaders, IT equipment, medical equipment, and industrial tools. From $10,000 to $5M+ per asset."
      },
      {
        question: "Can I finance used equipment?",
        answer: "Yes, we finance both new and used equipment. Used equipment typically needs to be less than 10 years old at the end of the loan term. We have specialized programs for older equipment in certain industries."
      },
      {
        question: "What deposit is required for equipment finance?",
        answer: "Many of our equipment finance options offer 100% financing with no deposit required. However, providing a 10-20% deposit can often secure better rates and terms."
      }
    ]
  },
  {
    category: "Commercial Property Finance",
    faqs: [
      {
        question: "What types of commercial properties can be financed?",
        answer: "We finance industrial warehouses, retail shops, office buildings, medical centers, childcare centers, manufacturing facilities, and mixed-use developments. LVR up to 80% for most properties."
      },
      {
        question: "What are typical commercial property loan terms?",
        answer: "Commercial property loans typically range from 5 to 30 years, with options for interest-only periods. We offer both variable and fixed rate options to suit your cash flow needs."
      },
      {
        question: "Can I use residential property as security?",
        answer: "Yes, you can use residential property as additional security for commercial loans, which often results in better rates and higher borrowing capacity."
      }
    ]
  },
  {
    category: "Working Capital & Cash Flow",
    faqs: [
      {
        question: "How quickly can I access working capital?",
        answer: "Working capital facilities can be approved within 24-48 hours, with funds available immediately upon approval. We offer both secured and unsecured options from $50K to $2M."
      },
      {
        question: "What is invoice financing and how does it work?",
        answer: "Invoice financing allows you to access up to 80% of your outstanding invoice value immediately. You get paid within 24 hours instead of waiting 30-90 days for customer payment."
      },
      {
        question: "Do I need to provide security for working capital?",
        answer: "Unsecured working capital is available up to $250K based on business cash flow. Larger amounts may require security such as property, equipment, or a general security agreement."
      }
    ]
  },
  {
    category: "Application Process",
    faqs: [
      {
        question: "What documents do I need to apply?",
        answer: "Basic requirements include: 2 years of financial statements, 6 months of bank statements, driver's license, and equipment quotes (for equipment finance). We'll guide you through any additional requirements."
      },
      {
        question: "How long does approval take?",
        answer: "Pre-approval within 4 business hours, formal approval within 24-48 hours for most applications. Complex or large transactions may take 3-5 business days."
      },
      {
        question: "Can I apply if I'm a new business?",
        answer: "Yes, we have start-up business finance options. You'll need a solid business plan, relevant industry experience, and potentially additional security or a guarantor."
      }
    ]
  },
  {
    category: "Eligibility & Credit",
    faqs: [
      {
        question: "What if I have defaults or bad credit?",
        answer: "We have specialized lenders for credit-impaired applications. Paid defaults over 6 months old and credit scores above 500 can still be considered with the right structure."
      },
      {
        question: "Do you finance for sole traders?",
        answer: "Yes, we finance sole traders, partnerships, companies, and trusts. ABN required for at least 6 months (12 months for unsecured finance)."
      },
      {
        question: "What industries do you specialize in?",
        answer: "We specialize in construction, civil contracting, earthmoving, transport, manufacturing, healthcare, and professional services. We understand industry-specific needs and seasonal cash flows."
      }
    ]
  }
];
---

<Agency11Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="section-hero bg-gradient-to-br from-brand-primary to-brand-primary-dark text-white">
    <div class="container-default">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="heading-primary text-white mb-6">
          Frequently Asked Questions
        </h1>
        <p class="body-large text-brand-grey-100 mb-8">
          Get instant answers to common questions about commercial finance, equipment loans, and our application process
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="max-w-4xl mx-auto">
        {faqCategories.map((category, categoryIndex) => (
          <div class="mb-12" key={categoryIndex}>
            <h2 class="heading-tertiary text-brand-primary mb-6">
              {category.category}
            </h2>
            <div class="space-y-4">
              {category.faqs.map((faq, faqIndex) => (
                <div class="bg-white rounded-xl p-6 shadow-soft border border-brand-grey-200 hover:shadow-medium transition-shadow duration-200" key={faqIndex}>
                  <button 
                    class="w-full text-left flex items-start justify-between gap-4 focus:outline-none group"
                    onclick={`this.parentElement.classList.toggle('expanded')`}
                  >
                    <h3 class="text-lg font-semibold text-brand-grey-900 group-hover:text-brand-accent transition-colors duration-200">
                      {faq.question}
                    </h3>
                    <svg class="w-6 h-6 text-brand-accent flex-shrink-0 transform transition-transform duration-200 expand-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="faq-answer mt-4 text-brand-grey-700 leading-relaxed hidden">
                    <p>{faq.answer}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- CTA Section -->
      <div class="mt-16 bg-gradient-to-br from-brand-accent to-brand-primary rounded-2xl p-8 lg:p-12 text-center text-white">
        <h2 class="heading-tertiary text-white mb-4">
          Still Have Questions?
        </h2>
        <p class="body-large text-brand-grey-100 mb-8 max-w-2xl mx-auto">
          Our finance specialists are here to help. Get expert advice tailored to your business needs.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="btn-primary bg-white text-brand-primary hover:bg-brand-grey-50">
            Contact Us
          </a>
          <a href="/get-quote" class="btn-secondary border-white text-white hover:bg-white hover:text-brand-primary">
            Get Quick Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .expanded .expand-icon {
      transform: rotate(180deg);
    }
    
    .expanded .faq-answer {
      display: block !important;
    }
  </style>
</Agency11Layout>