            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }
        
        .step {
            text-align: center;
            padding: 2rem;
        }
        
        .step-number {
            background: #e67e22;
            color: white;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: bold;
            margin: 0 auto 1rem;
        }
        
        .step h3 {
            color: #8e44ad;
            margin-bottom: 1rem;
        }
        
        /* Benefits Section */
        .benefits-section {
            padding: 80px 20px;
            background: #f8f9fa;
        }
        
        .benefits-section h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 3rem;
            color: #8e44ad;
        }
        
        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }
        
        .benefit {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .benefit h3 {
            color: #e67e22;
            margin-bottom: 1rem;
        }
        
        /* Property Focus */
        .property-focus {
            padding: 80px 20px;
        }
        
        .property-focus h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 3rem;
            color: #8e44ad;
        }
        
        .focus-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }
        
        .focus-item {
            background: #f8f9fa;
            padding: 2rem;
            border-radius: 10px;
            text-align: center;
        }
        
        .focus-item h3 {
            color: #8e44ad;
            margin-bottom: 1rem;
        }
        
        /* CTA Section */
        .cta-section {
            background: #8e44ad;
            color: white;
            padding: 80px 20px;
            text-align: center;
        }
        
        .cta-section h2 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        
        .cta-section p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
        }
        
        .cta-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 2rem;
        }
        
        .large {
            font-size: 1.2rem;
            padding: 18px 36px;
        }
        
        .contact-info {
            font-size: 1.1rem;
            opacity: 0.9;
        }
        
        /* Footer */
        footer {
            background: #333;
            color: white;
            padding: 40px 20px 20px;
        }
        
        .footer-content {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }
        
        .footer-section h4 {
            color: #e67e22;
            margin-bottom: 1rem;
        }
        
        .footer-section ul {
            list-style: none;
        }
        
        .footer-section a {
            color: #ccc;
            text-decoration: none;
            transition: color 0.3s;
        }
        
        .footer-section a:hover {
            color: white;
        }
        
        .footer-bottom {
            border-top: 1px solid #555;
            padding-top: 1rem;
            text-align: center;
            color: #ccc;
        }
        
        /* Responsive Design */
        @media (max-width: 768px) {
            .service-hero h1 {
                font-size: 2rem;
            }
            
            .hero-subtitle {
                font-size: 1.1rem;
            }
            
            .nav-menu {
                display: none;
            }
            
            .property-grid,
            .stories-grid,
            .options-grid,
            .process-steps,
            .benefits-grid,
            .focus-grid {
                grid-template-columns: 1fr;
            }
            
            .trust-indicators {
                flex-direction: column;
                gap: 1rem;
            }
            
            .cta-buttons {
                flex-direction: column;
                align-items: center;
            }
        }
    </style>
</body>
