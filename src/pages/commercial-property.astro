---
// Commercial Property Finance Page - Strategic Property Investment & Business Premises
// Optimized for Ben the Business Builder ICP (excluding residential builders)
import Agency11Layout from '../layouts/Agency11Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const siteData = {
  title: "Commercial Property Finance | Business Premises & Investment | EVFBS Australia",
  description: "Strategic commercial property finance for business premises and investment properties. Competitive rates from $300K to $10M+ for commercial trades, civil contractors, and growing businesses.",
  keywords: "commercial property finance Australia, business premises loans, commercial investment property, industrial property finance, warehouse finance"
