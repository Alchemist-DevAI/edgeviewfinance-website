---

<Agency11Layout title={siteData.title} description={siteData.description} keywords={siteData.keywords}>
  <!-- Commercial Property Service Schema -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://edgeviewfinance.com.au/commercial-property",
    "name": "Commercial Property Finance",
    "alternateName": "Business Property Investment Finance",
    "description": "Strategic commercial property finance for business premises and investment properties, with competitive rates and flexible terms",
    "serviceType": "Commercial Property Finance",
    "provider": {
      "@type": "FinancialService",
      "@id": "https://edgeviewfinance.com.au/#organization",
      "name": "Edgeview Finance Business Solutions",
      "areaServed": {
        "@type": "Country",
        "name": "Australia"
      }
    },
    "offers": {
      "@type": "Offer",
      "name": "Commercial Property Finance Solutions",
      "description": "Flexible commercial property financing from $300K to $10M+ for business premises and investment properties",
      "itemOffered": {
        "@type": "Service",
        "name": "Commercial Property Finance",
