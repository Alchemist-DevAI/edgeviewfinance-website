---
// EVFBS About Page - Professional Commercial Finance Partnership
// Optimized for "Ben the Business Builder" ICP
export const prerender = true;

const siteData = {
  title: "About Edgeview Finance Business Solutions | Strategic Commercial Finance Partnership",
  description: "Meet the strategic commercial finance partnership team specializing in Australian trades and service businesses. Professional assessment, AI-enhanced approach, and expert credentials for sustainable business growth.",
  keywords: "about EVFBS, commercial finance broker Australia, finance partnership, trade finance specialist, professional credentials ACL"
};
---

<html lang="en-AU">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteData.description} />
    <meta name="keywords" content={siteData.keywords} />
    
    <!-- About Page Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "@id": "https://edgeviewfinance.com.au/about#aboutpage",
      "mainEntity": {
        "@type": "FinancialService",
        "@id": "https://edgeviewfinance.com.au/#organization",
        "name": "Edgeview Finance Business Solutions",
        "alternateName": "EVFBS",
        "description": "Strategic commercial finance brokerage specializing in equipment finance, commercial property, and business growth solutions for Australian trades and service businesses",
        "url": "https://edgeviewfinance.com.au",
        "foundingDate": "2024",
        "serviceType": "Commercial Finance Brokerage",
        "areaServed": {
          "@type": "Country",
          "name": "Australia"
        },
        "knowsAbout": [
          "Equipment Finance",
          "Commercial Property Finance", 
          "Working Capital Solutions",
          "Invoice Financing",
          "AI-Enhanced Financial Analysis",
