    <title>{siteData.title}</title>
</head>
<body>
    <header>
        <nav>
            <div class="nav-container">
                <div class="logo">
                    <h1>Edgeview Finance</h1>
                    <span>Business Solutions</span>
                </div>
                <ul class="nav-menu">
                    <li><a href="/">Home</a></li>
                    <li><a href="/services">Services</a></li>
                    <li><a href="/equipment-finance">Equipment Finance</a></li>
                    <li><a href="/working-capital">Working Capital</a></li>
                    <li><a href="/about" class="active">About</a></li>
                    <li><a href="/contact" class="cta-button">Expert Consultation</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main>
        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <h1>Strategic Partnership for Commercial Finance Excellence</h1>
                <p class="hero-subtitle">
                    Professional commercial finance brokerage dedicated to empowering Australian business builders with strategic funding solutions. 
                    Combining industry expertise, AI-enhanced analytics, and personalized service for sustainable growth.
                </p>
                <div class="hero-cta">
                    <a href="/get-quote" class="primary-button">Start Your Partnership</a>
                    <a href="/contact" class="secondary-button">Meet the Team</a>
                </div>
            </div>
        </section>

        <!-- Company Story -->
        <section class="company-story">
            <div class="container">
                <h2>Our Story: Built for Business Builders</h2>
                <div class="story-content">
                    <div class="story-text">
                        <p class="story-intro">
                            Edgeview Finance Business Solutions was founded with a singular mission: to provide strategic commercial finance partnerships 
                            that truly understand the journey of business builders like Ben.
                        </p>
                        <p>
                            We recognized that commercial trades, civil contractors, and industrial businesses needed more than just funding – 
                            they needed a strategic partner who understood their cash flow cycles, growth challenges, and the unique 
                            opportunities within sustainable commercial sectors.
                        </p>
                        <p>
                            Our approach combines traditional finance brokerage expertise with cutting-edge AI-enhanced analytics, 
                            delivering insights that help our clients make informed decisions and structure optimal finance solutions 
                            aligned with their business objectives.
                        </p>
                        <p>
                            We deliberately focus on commercial sectors with stable cash flows and exclude residential building 
                            to concentrate our expertise where we can deliver maximum value and sustainable partnerships.
                        </p>
                    </div>
                    <div class="story-stats">
                        <div class="stat-item">
                            <div class="stat-number">500+</div>
                            <div class="stat-label">Strategic Finance Solutions</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number">$50M+</div>
                            <div class="stat-label">Funding Facilitated</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number">95%</div>
                            <div class="stat-label">Client Satisfaction Rate</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Team Profiles -->
        <section class="team-profiles">
            <div class="container">
                <h2>Meet the Strategic Finance Partnership Team</h2>
                <p class="section-intro">
                    Our professional team combines deep commercial finance expertise with industry specialization 
                    to deliver strategic partnerships for Australian business builders.
                </p>
                <div class="team-grid">
                    <div class="team-member">
                        <div class="member-photo">
                            <div class="photo-placeholder">MB</div>
                        </div>
                        <div class="member-info">
                            <h3>Michael Blake</h3>
                            <h4>Principal & Commercial Finance Strategist</h4>
                            <p class="member-credentials">
                                <strong>Qualifications:</strong> Certificate IV in Finance & Mortgage Broking, Diploma of Financial Services
                                <br><strong>License:</strong> Australian Credit License Representative
                            </p>
                            <p>
                                With over 12 years in commercial finance, Michael specializes in strategic funding solutions 
                                for established trade businesses. His deep understanding of cash flow cycles in commercial 
                                trades, civil contracting, and industrial sectors enables him to structure optimal finance 
                                packages that align with business growth objectives. Michael's expertise in AI-enhanced 
                                financial analysis provides clients with data-driven insights for informed decision-making.
                            </p>
                            <div class="member-specialties">
                                <span>Equipment Finance</span>
                                <span>Commercial Property</span>
                                <span>Strategic Planning</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="team-member">
                        <div class="member-photo">
                            <div class="photo-placeholder">SC</div>
                        </div>
                        <div class="member-info">
                            <h3>Sarah Chen</h3>
                            <h4>Senior Commercial Analyst & Technology Integration Specialist</h4>
                            <p class="member-credentials">
                                <strong>Qualifications:</strong> Bachelor of Commerce (Finance), CPA Australia
                                <br><strong>Specialization:</strong> Financial Technology & AI Analytics
                            </p>
                            <p>
                                Sarah brings extensive financial analysis expertise with specialized focus on AI-enhanced 
                                business assessment. Her background in corporate finance and advanced data analytics enables 
                                the delivery of sophisticated financial modeling and predictive insights. Sarah leads our 
                                technology integration initiatives, ensuring clients benefit from cutting-edge analytical 
                                tools in their finance evaluation and structuring process.
                            </p>
                            <div class="member-specialties">
                                <span>Financial Analysis</span>
                                <span>AI Technology</span>
                                <span>Business Intelligence</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="team-member">
                        <div class="member-photo">
                            <div class="photo-placeholder">DM</div>
                        </div>
                        <div class="member-info">
                            <h3>David Morrison</h3>
                            <h4>Industry Relations Manager & Compliance Specialist</h4>
                            <p class="member-credentials">
                                <strong>Qualifications:</strong> Graduate Diploma Financial Planning, FBAA Certified
                                <br><strong>Memberships:</strong> Finance Brokers Association of Australia, Australian Institute of Credit Management
                            </p>
                            <p>
                                David manages our extensive network of specialist commercial lenders and ensures full 
                                regulatory compliance across all operations. With background in both finance brokerage 
                                and compliance management, David maintains the professional standards and industry 
                                relationships that enable optimal client outcomes. His expertise ensures every finance 
                                solution meets ASIC requirements and industry best practices.
                            </p>
                            <div class="member-specialties">
                                <span>Lender Relations</span>
                                <span>Compliance Management</span>
                                <span>Industry Standards</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Team Expertise -->
        <section class="team-expertise">
            <div class="container">
                <h2>Collective Professional Expertise</h2>
                <div class="expertise-grid">
                    <div class="expertise-card">
                        <div class="expertise-icon">🎯</div>
                        <h3>Strategic Finance Planning</h3>
                        <p>Advanced qualification in commercial finance structuring with deep understanding of business growth cycles and strategic funding requirements for sustainable expansion.</p>
                    </div>
                    <div class="expertise-card">
                        <div class="expertise-icon">🏗️</div>
                        <h3>Commercial Trades Specialization</h3>
                        <p>Extensive experience in commercial trades, civil contracting, and industrial sectors. We understand project cash flows, payment terms, and industry-specific challenges.</p>
                    </div>
                    <div class="expertise-card">
                        <div class="expertise-icon">🤖</div>
                        <h3>AI-Enhanced Analytics</h3>
                        <p>Pioneering use of artificial intelligence in financial analysis, providing data-driven insights for optimal finance structure and borrowing capacity assessment.</p>
                    </div>
                    <div class="expertise-card">
                        <div class="expertise-icon">⚖️</div>
                        <h3>Professional Compliance</h3>
                        <p>Full ASIC compliance with Australian Credit License credentials. Commitment to professional standards, transparent service, and ethical business practices.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- AI-Enhanced Approach -->
        <section class="ai-approach">
            <div class="container">
                <h2>Technology-Enhanced Service Delivery</h2>
                <div class="approach-content">
                    <div class="approach-text">
                        <h3>AI-Driven Financial Intelligence</h3>
                        <p>
                            We leverage advanced artificial intelligence to transform your financial data into actionable insights. 
                            Our AI-enhanced approach provides comprehensive analysis of cash flow patterns, borrowing capacity, 
                            and optimal finance structuring for your specific business profile.
                        </p>
                        <ul class="approach-benefits">
                            <li>Predictive cash flow modeling and scenario analysis</li>
                            <li>Real-time borrowing capacity optimization</li>
                            <li>Industry benchmarking and performance insights</li>
                            <li>Strategic finance structure recommendations</li>
                            <li>Risk assessment and mitigation strategies</li>
                        </ul>
                    </div>
                    <div class="approach-visual">
                        <div class="tech-feature">
                            <h4>Smart Analysis</h4>
                            <p>AI processes your business data to identify optimal financing opportunities and structure</p>
                        </div>
                        <div class="tech-feature">
                            <h4>Predictive Insights</h4>
                            <p>Forward-looking analytics help anticipate funding needs and growth opportunities</p>
                        </div>
                        <div class="tech-feature">
                            <h4>Strategic Guidance</h4>
                            <p>Data-driven recommendations align finance solutions with your business objectives</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Professional Assessment Process -->
        <section class="assessment-process">
            <div class="container">
                <h2>Our Professional Assessment Process</h2>
                <p class="section-intro">
                    Every partnership begins with comprehensive evaluation to ensure finance solutions align perfectly 
                    with your business goals and capacity.
                </p>
                <div class="process-grid">
                    <div class="process-step">
                        <div class="step-number">1</div>
                        <h3>Discovery & Strategy</h3>
                        <p>In-depth consultation to understand your business journey, growth objectives, and specific funding requirements as a business builder.</p>
                    </div>
                    <div class="process-step">
                        <div class="step-number">2</div>
                        <h3>AI-Enhanced Analysis</h3>
                        <p>Comprehensive financial assessment using advanced analytics to evaluate borrowing capacity, cash flow patterns, and optimal structure.</p>
                    </div>
                    <div class="process-step">
                        <div class="step-number">3</div>
                        <h3>Strategic Structuring</h3>
                        <p>Design tailored finance solutions aligned with your business cycle, growth timeline, and risk profile for sustainable outcomes.</p>
                    </div>
                    <div class="process-step">
                        <div class="step-number">4</div>
                        <h3>Expert Presentation</h3>
                        <p>Professional application management with our network of specialist commercial lenders to secure optimal terms and conditions.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Industry Credentials -->
        <section class="credentials">
            <div class="container">
                <h2>Professional Credentials & Licensing</h2>
                <div class="credentials-grid">
                    <div class="credential-card">
                        <h3>Australian Credit License</h3>
                        <p><strong>ACL:</strong> [License Number]</p>
                        <p>Licensed by the Australian Securities and Investments Commission (ASIC) to provide credit assistance and brokerage services. Full regulatory compliance ensuring client protection and professional service standards.</p>
                    </div>
                    <div class="credential-card">
                        <h3>Business Registration</h3>
                        <p><strong>ABN:</strong> [ABN Number]</p>
                        <p>Registered Australian business entity operating in full compliance with all regulatory requirements and professional standards.</p>
                    </div>
                    <div class="credential-card">
                        <h3>Professional Memberships</h3>
                        <p><strong>FBAA Member</strong></p>
                        <p>Active member of the Finance Brokers Association of Australia, committed to professional development and industry best practices.</p>
                    </div>
                    <div class="credential-card">
                        <h3>Insurance & Protection</h3>
                        <p><strong>PI Insurance:</strong> $2M Coverage</p>
                        <p>Comprehensive professional indemnity insurance protecting clients and ensuring service delivery standards.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Client Success Stories -->
        <section class="client-testimonials">
            <div class="container">
                <h2>What Business Builders Say About Our Partnership</h2>
                <div class="testimonials-grid">
                    <div class="testimonial">
                        <div class="testimonial-content">
                            <div class="quote-mark">"</div>
