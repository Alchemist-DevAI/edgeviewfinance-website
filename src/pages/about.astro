---
// EVFBS About Page - Professional Commercial Finance Partnership
// Optimized for "Ben the Business Builder" ICP
import Agency11Layout from '../layouts/Agency11Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const siteData = {
  title: "About Edgeview Finance Business Solutions | Strategic Commercial Finance Partnership",
  description: "Meet the strategic commercial finance partnership team specializing in Australian trades and service businesses. Professional assessment, AI-enhanced approach, and expert credentials for sustainable business growth.",
  keywords: "about EVFBS, commercial finance broker Australia, finance partnership, trade finance specialist, professional credentials ACL"
};
---

<Agency11Layout title={siteData.title} description={siteData.description} keywords={siteData.keywords}>
  <!-- About Page Schema -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": "https://edgeviewfinance.com.au/about#aboutpage",
    "mainEntity": {
      "@type": "FinancialService",
      "@id": "https://edgeviewfinance.com.au/#organization",
      "name": "Edgeview Finance Business Solutions",
      "alternateName": "EVFBS",
      "description": "Strategic commercial finance brokerage specializing in equipment finance, commercial property, and business growth solutions for Australian trades and service businesses",
      "url": "https://edgeviewfinance.com.au",
      "foundingDate": "2024",
      "serviceType": "Commercial Finance Brokerage",
      "areaServed": {
        "@type": "Country",
        "name": "Australia"
      },
      "knowsAbout": [
        "Equipment Finance",
        "Commercial Property Finance", 
        "Working Capital Solutions",
        "Invoice Financing",
        "AI-Enhanced Financial Analysis",
        "Commercial Trade Finance"
      ],
      "hasCredential": [
        {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "Australian Credit License",
          "recognizedBy": {
            "@type": "Organization",
            "name": "Australian Securities and Investments Commission"
          }
        }
      ],
      "memberOf": {
        "@type": "Organization",
        "name": "Finance Brokers Association of Australia"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+61-XXX-XXX-XXX",
        "contactType": "customer service",
        "areaServed": "AU",
        "availableLanguage": "English"
      },
      "employee": [
        {
          "@type": "Person",
          "name": "Michael Blake",
          "jobTitle": "Principal & Commercial Finance Strategist",
          "hasCredential": "Certificate IV in Finance & Mortgage Broking, Diploma of Financial Services",
          "knowsAbout": ["Equipment Finance", "Commercial Property", "Strategic Planning"]
        },
        {
          "@type": "Person",
          "name": "Sarah Chen",
          "jobTitle": "Senior Commercial Analyst & Technology Integration Specialist",
          "hasCredential": "Bachelor of Commerce (Finance), CPA Australia",
          "knowsAbout": ["Financial Analysis", "AI Technology", "Business Intelligence"]
        },
        {
          "@type": "Person",
          "name": "David Morrison", 
          "jobTitle": "Industry Relations Manager & Compliance Specialist",
          "hasCredential": "Graduate Diploma Financial Planning, FBAA Certified",
          "knowsAbout": ["Lender Relations", "Compliance Management", "Industry Standards"]
        }
      ]
    }
  }
  </script>
  
  <!-- Open Graph for Social Sharing -->
  <meta property="og:title" content={siteData.title} slot="head" />
  <meta property="og:description" content={siteData.description} slot="head" />
  <meta property="og:type" content="website" slot="head" />
  <meta property="og:url" content="https://edgeviewfinance.com.au/about" slot="head" />
  <meta property="og:locale" content="en_AU" slot="head" />

  <Header />
  <main>
        <!-- Hero Section -->
        <section class="section-hero hero-section">
            <div class="container-default">
                <div class="text-center">
                    <h1 class="heading-primary text-white mb-6">Strategic Partnership for Commercial Finance Excellence</h1>
                    <p class="hero-subtitle text-xl lg:text-2xl font-light mb-8 text-gray-100 max-w-4xl mx-auto">
                        Professional commercial finance brokerage dedicated to empowering Australian business builders with strategic funding solutions. 
                        Combining industry expertise, AI-enhanced analytics, and personalized service for sustainable growth.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center button-gap">
                        <a href="/get-quote" class="btn-primary btn-large">Start Your Partnership</a>
                        <a href="/contact" class="btn-secondary btn-large text-white border-white hover:bg-white hover:text-secondary-dark">Meet the Team</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Company Story -->
        <section class="section-content bg-neutral-light">
            <div class="container-default">
                <h2 class="heading-secondary text-center mb-16">Our Story: Built for Business Builders</h2>
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12 items-start">
                    <div class="lg:col-span-2">
                        <p class="body-large font-semibold text-primary-orange mb-6">
                            Edgeview Finance Business Solutions was founded with a singular mission: to provide strategic commercial finance partnerships 
                            that truly understand the journey of business builders like Ben.
                        </p>
                        <p class="body-medium mb-6">
                            We recognized that commercial trades, civil contractors, and industrial businesses needed more than just funding – 
                            they needed a strategic partner who understood their cash flow cycles, growth challenges, and the unique 
                            opportunities within sustainable commercial sectors.
                        </p>
                        <p class="body-medium mb-6">
                            Our approach combines traditional finance brokerage expertise with cutting-edge AI-enhanced analytics, 
                            delivering insights that help our clients make informed decisions and structure optimal finance solutions 
                            aligned with their business objectives.
                        </p>
                        <p class="body-medium">
                            We deliberately focus on commercial sectors with stable cash flows and exclude residential building 
                            to concentrate our expertise where we can deliver maximum value and sustainable partnerships.
                        </p>
                    </div>
                    <div class="flex flex-col gap-6">
                        <div class="text-center card-padding-lg bg-white rounded-xl shadow-lg">
                            <div class="text-4xl font-bold text-primary-orange mb-2">500+</div>
                            <div class="text-gray-600 font-semibold">Strategic Finance Solutions</div>
                        </div>
                        <div class="text-center card-padding-lg bg-white rounded-xl shadow-lg">
                            <div class="text-4xl font-bold text-primary-orange mb-2">$50M+</div>
                            <div class="text-gray-600 font-semibold">Funding Facilitated</div>
                        </div>
                        <div class="text-center card-padding-lg bg-white rounded-xl shadow-lg">
                            <div class="text-4xl font-bold text-primary-orange mb-2">95%</div>
                            <div class="text-gray-600 font-semibold">Client Satisfaction Rate</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Team Profiles -->
        <section class="section-content">
            <div class="container-default">
                <h2 class="heading-secondary text-center mb-6">Meet the Strategic Finance Partnership Team</h2>
                <p class="body-large text-center max-w-4xl mx-auto mb-16">
                    Our professional team combines deep commercial finance expertise with industry specialization 
                    to deliver strategic partnerships for Australian business builders.
                </p>
                <div class="space-y-12">
                    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 items-start service-card-consistent">
                        <div class="text-center">
                            <div class="w-32 h-32 bg-gradient-to-br from-secondary-dark to-primary-orange rounded-full flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4 shadow-lg">
                                MB
                            </div>
                        </div>
                        <div class="lg:col-span-3">
                            <h3 class="heading-tertiary text-secondary-dark mb-2">Michael Blake</h3>
                            <h4 class="text-primary-orange text-xl font-semibold mb-4">Principal & Commercial Finance Strategist</h4>
                            <div class="bg-neutral-light card-padding-sm rounded-lg border-l-4 border-primary-orange mb-6">
                                <p class="body-medium mb-2">
                                    <strong class="text-secondary-dark">Qualifications:</strong> Certificate IV in Finance & Mortgage Broking, Diploma of Financial Services
                                </p>
                                <p class="body-medium">
                                    <strong class="text-secondary-dark">License:</strong> Australian Credit License Representative
                                </p>
                            </div>
                            <p class="body-medium mb-6">
                                With over 12 years in commercial finance, Michael specializes in strategic funding solutions 
                                for established trade businesses. His deep understanding of cash flow cycles in commercial 
                                trades, civil contracting, and industrial sectors enables him to structure optimal finance 
                                packages that align with business growth objectives. Michael's expertise in AI-enhanced 
                                financial analysis provides clients with data-driven insights for informed decision-making.
                            </p>
                            <div class="flex flex-wrap gap-2">
                                <span class="bg-secondary-dark text-white px-3 py-1 rounded-full text-sm font-semibold">Equipment Finance</span>
                                <span class="bg-secondary-dark text-white px-3 py-1 rounded-full text-sm font-semibold">Commercial Property</span>
                                <span class="bg-secondary-dark text-white px-3 py-1 rounded-full text-sm font-semibold">Strategic Planning</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 items-start service-card-consistent">
                        <div class="text-center">
                            <div class="w-32 h-32 bg-gradient-to-br from-secondary-dark to-primary-orange rounded-full flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4 shadow-lg">
                                SC
                            </div>
                        </div>
                        <div class="lg:col-span-3">
                            <h3 class="heading-tertiary text-secondary-dark mb-2">Sarah Chen</h3>
                            <h4 class="text-primary-orange text-xl font-semibold mb-4">Senior Commercial Analyst & Technology Integration Specialist</h4>
                            <div class="bg-neutral-light card-padding-sm rounded-lg border-l-4 border-primary-orange mb-6">
                                <p class="body-medium mb-2">
                                    <strong class="text-secondary-dark">Qualifications:</strong> Bachelor of Commerce (Finance), CPA Australia
                                </p>
                                <p class="body-medium">
                                    <strong class="text-secondary-dark">Specialization:</strong> Financial Technology & AI Analytics
                                </p>
                            </div>
                            <p class="body-medium mb-6">
                                Sarah brings extensive financial analysis expertise with specialized focus on AI-enhanced 
                                business assessment. Her background in corporate finance and advanced data analytics enables 
                                the delivery of sophisticated financial modeling and predictive insights. Sarah leads our 
                                technology integration initiatives, ensuring clients benefit from cutting-edge analytical 
                                tools in their finance evaluation and structuring process.
                            </p>
                            <div class="flex flex-wrap gap-2">
                                <span class="bg-secondary-dark text-white px-3 py-1 rounded-full text-sm font-semibold">Financial Analysis</span>
                                <span class="bg-secondary-dark text-white px-3 py-1 rounded-full text-sm font-semibold">AI Technology</span>
                                <span class="bg-secondary-dark text-white px-3 py-1 rounded-full text-sm font-semibold">Business Intelligence</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 items-start service-card-consistent">
                        <div class="text-center">
                            <div class="w-32 h-32 bg-gradient-to-br from-secondary-dark to-primary-orange rounded-full flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4 shadow-lg">
                                DM
                            </div>
                        </div>
                        <div class="lg:col-span-3">
                            <h3 class="heading-tertiary text-secondary-dark mb-2">David Morrison</h3>
                            <h4 class="text-primary-orange text-xl font-semibold mb-4">Industry Relations Manager & Compliance Specialist</h4>
                            <div class="bg-neutral-light card-padding-sm rounded-lg border-l-4 border-primary-orange mb-6">
                                <p class="body-medium mb-2">
                                    <strong class="text-secondary-dark">Qualifications:</strong> Graduate Diploma Financial Planning, FBAA Certified
                                </p>
                                <p class="body-medium">
                                    <strong class="text-secondary-dark">Memberships:</strong> Finance Brokers Association of Australia, Australian Institute of Credit Management
                                </p>
                            </div>
                            <p class="body-medium mb-6">
                                David manages our extensive network of specialist commercial lenders and ensures full 
                                regulatory compliance across all operations. With background in both finance brokerage 
                                and compliance management, David maintains the professional standards and industry 
                                relationships that enable optimal client outcomes. His expertise ensures every finance 
                                solution meets ASIC requirements and industry best practices.
                            </p>
                            <div class="flex flex-wrap gap-2">
                                <span class="bg-secondary-dark text-white px-3 py-1 rounded-full text-sm font-semibold">Lender Relations</span>
                                <span class="bg-secondary-dark text-white px-3 py-1 rounded-full text-sm font-semibold">Compliance Management</span>
                                <span class="bg-secondary-dark text-white px-3 py-1 rounded-full text-sm font-semibold">Industry Standards</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Team Expertise -->
        <section class="section-content bg-neutral-light">
            <div class="container-default">
                <div class="text-center mb-16">
                    <h2 class="heading-secondary mb-6">Collective Professional Expertise</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="feature-card">
                        <div class="icon-wrapper text-4xl mb-6">🎯</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Strategic Finance Planning</h3>
                        <p class="body-medium">Advanced qualification in commercial finance structuring with deep understanding of business growth cycles and strategic funding requirements for sustainable expansion.</p>
                    </div>
                    <div class="feature-card">
                        <div class="icon-wrapper text-4xl mb-6">🏗️</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Commercial Trades Specialization</h3>
                        <p class="body-medium">Extensive experience in commercial trades, civil contracting, and industrial sectors. We understand project cash flows, payment terms, and industry-specific challenges.</p>
                    </div>
                    <div class="feature-card">
                        <div class="icon-wrapper text-4xl mb-6">🤖</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">AI-Enhanced Analytics</h3>
                        <p class="body-medium">Pioneering use of artificial intelligence in financial analysis, providing data-driven insights for optimal finance structure and borrowing capacity assessment.</p>
                    </div>
                    <div class="feature-card">
                        <div class="icon-wrapper text-4xl mb-6">⚖️</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Professional Compliance</h3>
                        <p class="body-medium">Full ASIC compliance with Australian Credit License credentials. Commitment to professional standards, transparent service, and ethical business practices.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- AI-Enhanced Approach -->
        <section class="section-content">
            <div class="container-default">
                <div class="text-center mb-16">
                    <h2 class="heading-secondary mb-6">Technology-Enhanced Service Delivery</h2>
                </div>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                    <div>
                        <h3 class="heading-tertiary text-secondary-dark mb-6">AI-Driven Financial Intelligence</h3>
                        <p class="body-large mb-8">
                            We leverage advanced artificial intelligence to transform your financial data into actionable insights. 
                            Our AI-enhanced approach provides comprehensive analysis of cash flow patterns, borrowing capacity, 
                            and optimal finance structuring for your specific business profile.
                        </p>
                        <ul class="space-y-4">
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-3">✓</span>
                                <span class="body-medium">Predictive cash flow modeling and scenario analysis</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-3">✓</span>
                                <span class="body-medium">Real-time borrowing capacity optimization</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-3">✓</span>
                                <span class="body-medium">Industry benchmarking and performance insights</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-3">✓</span>
                                <span class="body-medium">Strategic finance structure recommendations</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-3">✓</span>
                                <span class="body-medium">Risk assessment and mitigation strategies</span>
                            </li>
                        </ul>
                    </div>
                    <div class="space-y-6">
                        <div class="service-card-consistent">
                            <div class="icon-wrapper text-4xl mb-4">🧠</div>
                            <h4 class="heading-tertiary text-secondary-dark mb-3">Smart Analysis</h4>
                            <p class="body-medium">AI processes your business data to identify optimal financing opportunities and structure</p>
                        </div>
                        <div class="service-card-consistent">
                            <div class="icon-wrapper text-4xl mb-4">📊</div>
                            <h4 class="heading-tertiary text-secondary-dark mb-3">Predictive Insights</h4>
                            <p class="body-medium">Forward-looking analytics help anticipate funding needs and growth opportunities</p>
                        </div>
                        <div class="service-card-consistent">
                            <div class="icon-wrapper text-4xl mb-4">🎯</div>
                            <h4 class="heading-tertiary text-secondary-dark mb-3">Strategic Guidance</h4>
                            <p class="body-medium">Data-driven recommendations align finance solutions with your business objectives</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Professional Assessment Process -->
        <section class="section-content bg-neutral-light">
            <div class="container-default">
                <div class="text-center mb-16">
                    <h2 class="heading-secondary mb-6">Our Professional Assessment Process</h2>
                    <p class="body-large max-w-4xl mx-auto">
                        Every partnership begins with comprehensive evaluation to ensure finance solutions align perfectly 
                        with your business goals and capacity.
                    </p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">1</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Discovery & Strategy</h3>
                        <p class="body-medium">In-depth consultation to understand your business journey, growth objectives, and specific funding requirements as a business builder.</p>
                    </div>
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">2</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">AI-Enhanced Analysis</h3>
                        <p class="body-medium">Comprehensive financial assessment using advanced analytics to evaluate borrowing capacity, cash flow patterns, and optimal structure.</p>
                    </div>
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">3</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Strategic Structuring</h3>
                        <p class="body-medium">Design tailored finance solutions aligned with your business cycle, growth timeline, and risk profile for sustainable outcomes.</p>
                    </div>
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">4</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Expert Presentation</h3>
                        <p class="body-medium">Professional application management with our network of specialist commercial lenders to secure optimal terms and conditions.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Industry Credentials -->
        <section class="section-content">
            <div class="container-default">
                <div class="text-center mb-16">
                    <h2 class="heading-secondary mb-6">Professional Credentials & Licensing</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="service-card-consistent">
                        <div class="icon-wrapper text-4xl mb-6">🏆</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Australian Credit License</h3>
                        <p class="body-medium mb-4"><strong class="text-primary-orange">ACL:</strong> [License Number]</p>
                        <p class="body-medium">Licensed by the Australian Securities and Investments Commission (ASIC) to provide credit assistance and brokerage services. Full regulatory compliance ensuring client protection and professional service standards.</p>
                    </div>
                    <div class="service-card-consistent">
                        <div class="icon-wrapper text-4xl mb-6">🏢</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Business Registration</h3>
                        <p class="body-medium mb-4"><strong class="text-primary-orange">ABN:</strong> [ABN Number]</p>
                        <p class="body-medium">Registered Australian business entity operating in full compliance with all regulatory requirements and professional standards.</p>
                    </div>
                    <div class="service-card-consistent">
                        <div class="icon-wrapper text-4xl mb-6">🌟</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Professional Memberships</h3>
                        <p class="body-medium mb-4"><strong class="text-primary-orange">FBAA Member</strong></p>
                        <p class="body-medium">Active member of the Finance Brokers Association of Australia, committed to professional development and industry best practices.</p>
                    </div>
                    <div class="service-card-consistent">
                        <div class="icon-wrapper text-4xl mb-6">🛡️</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Insurance & Protection</h3>
                        <p class="body-medium mb-4"><strong class="text-primary-orange">PI Insurance:</strong> $2M Coverage</p>
                        <p class="body-medium">Comprehensive professional indemnity insurance protecting clients and ensuring service delivery standards.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Client Success Stories -->
        <section class="section-content bg-neutral-light">
            <div class="container-default">
                <div class="text-center mb-16">
                    <h2 class="heading-secondary mb-6">What Business Builders Say About Our Partnership</h2>
                </div>
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <div class="testimonial-card">
                        <div class="text-6xl text-primary-orange mb-4">“</div>
                        <p class="testimonial-quote">
                            EVFBS understood our civil contracting business from day one. Their AI-enhanced analysis 
                            identified the perfect equipment finance structure that matched our project cycles. 
                            We’ve secured funding for three major excavators and expanded our fleet by 40%.
                        </p>
                        <div class="testimonial-author">
                            <div class="testimonial-avatar">BM</div>
                            <div>
                                <h4 class="font-semibold text-secondary-dark">Ben Morrison</h4>
                                <p class="text-gray-600 text-sm">Managing Director, Morrison Civil Contractors</p>
                                <div class="bg-primary-orange text-white px-2 py-1 rounded text-xs mt-2 inline-block">Civil Contracting</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="testimonial-card">
                        <div class="text-6xl text-primary-orange mb-4">“</div>
                        <p class="testimonial-quote">
                            The strategic approach to our working capital requirements was exactly what our 
                            electrical business needed. Professional service, transparent communication, and 
                            funding that supports our growth rather than constraining it.
                        </p>
                        <div class="testimonial-author">
                            <div class="testimonial-avatar">LT</div>
                            <div>
                                <h4 class="font-semibold text-secondary-dark">Lisa Thompson</h4>
                                <p class="text-gray-600 text-sm">Director, Thompson Industrial Electrical</p>
                                <div class="bg-primary-orange text-white px-2 py-1 rounded text-xs mt-2 inline-block">Industrial Electrical</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="testimonial-card">
                        <div class="text-6xl text-primary-orange mb-4">“</div>
                        <p class="testimonial-quote">
                            From initial consultation to funding approval, the process was streamlined and professional. 
                            Their industry knowledge of commercial plumbing helped secure optimal terms for our 
                            commercial property purchase.
                        </p>
                        <div class="testimonial-author">
                            <div class="testimonial-avatar">MH</div>
                            <div>
                                <h4 class="font-semibold text-secondary-dark">Mark Hughes</h4>
                                <p class="text-gray-600 text-sm">Owner, Hughes Commercial Plumbing</p>
                                <div class="bg-primary-orange text-white px-2 py-1 rounded text-xs mt-2 inline-block">Commercial Trades</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Why Choose EVFBS -->
        <section class="section-content">
            <div class="container-default">
                <div class="text-center mb-16">
                    <h2 class="heading-secondary mb-6">Why Australian Business Builders Choose EVFBS</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Strategic Partnership Approach</h3>
                        <p class="body-medium">We’re not just a finance broker – we’re your strategic partner committed to long-term business success and growth.</p>
                    </div>
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Commercial Trades Expertise</h3>
                        <p class="body-medium">Deep specialization in commercial trades, civil contractors, and industrial businesses with exclusion of high-risk residential building.</p>
                    </div>
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Technology-Enhanced Service</h3>
