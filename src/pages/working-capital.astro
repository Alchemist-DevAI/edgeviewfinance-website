---
// Working Capital Solutions Page - Strategic Business Finance for Commercial Growth
// Optimized for Ben the Business Builder ICP (excluding residential builders)
import Agency11Layout from '../layouts/Agency11Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const siteData = {
  title: "Working Capital Solutions | Business Finance for Growth | EVFBS Australia",
  description: "Strategic working capital solutions for commercial trades, civil contractors, and growing businesses. Cash flow management, business expansion finance, and growth capital from $50K to $2M+.",
  keywords: "working capital Australia, business finance, cash flow solutions, commercial trades finance, civil contractor loans, business growth capital, SME finance"
};
---

<Agency11Layout title={siteData.title} description={siteData.description} keywords={siteData.keywords}>
  <!-- Working Capital Service Schema -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://edgeviewfinance.com.au/working-capital",
    "name": "Working Capital Solutions",
    "alternateName": "Business Growth Finance",
    "description": "Strategic working capital and business growth finance for commercial trades, civil contractors, and expanding businesses",
    "serviceType": "Business Finance",
    "provider": {
      "@type": "FinancialService",
      "@id": "https://edgeviewfinance.com.au/#organization",
      "name": "Edgeview Finance Business Solutions",
      "areaServed": {
        "@type": "Country",
        "name": "Australia"
      }
    },
    "offers": {
      "@type": "Offer",
      "name": "Working Capital Finance",
      "description": "Flexible business finance from $50K to $2M+ for cash flow management and business growth",
      "itemOffered": {
        "@type": "Service",
        "name": "Working Capital Solutions",
        "category": "Business Finance"
      }
    },
    "audience": {
      "@type": "BusinessAudience",
      "businessType": ["Commercial Trades", "Civil Contractors", "Growing Businesses"],
      "numberOfEmployees": "5-50"
    }
  }
