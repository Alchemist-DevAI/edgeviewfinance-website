                    </div>
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 text-gray-100">
                        <span class="flex items-center">
                            <svg class="w-5 h-5 mr-2 text-green-400" fill="currentColor" viewBox="0 0 20 20">
