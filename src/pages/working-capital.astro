            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 70px;
        }
        
        .logo h1 {
            color: #2c5aa0;
            font-size: 1.5rem;
            margin-bottom: -5px;
        }
        
        .logo span {
            color: #666;
            font-size: 0.9rem;
        }
        
        .nav-menu {
            display: flex;
            list-style: none;
            gap: 2rem;
            align-items: center;
        }
        
