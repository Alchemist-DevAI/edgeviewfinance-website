---
import Agency11Layout from '../layouts/Agency11Layout.astro';

const pageTitle = 'Terms of Service | Edgeview Finance Business Solutions';
const pageDescription = 'Comprehensive terms of service for EVFBS commercial finance brokerage services. Compliant with Australian Consumer Law, ASIC Act 2001, and National Consumer Credit Protection Act 2009.';

const lastUpdated = "15 August 2025";
const reviewDate = "15 August 2026";
const effectiveDate = "15 August 2025";
---

<Agency11Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="section-hero bg-gradient-to-br from-brand-primary to-brand-primary-dark text-white">
    <div class="container-default">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="heading-primary text-white mb-6">
          Terms of Service
        </h1>
        <p class="body-large text-brand-grey-100 mb-4">
          Professional service terms governing our commercial finance brokerage relationship
        </p>
        <div class="flex flex-wrap justify-center gap-4 text-sm text-brand-grey-200">
          <span><strong>Last Updated:</strong> {lastUpdated}</span>
          <span><strong>Effective Date:</strong> {effectiveDate}</span>
          <span><strong>Next Review:</strong> {reviewDate}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Terms Content -->
  <section class="section-content">
    <div class="container-default">
      <div class="max-w-4xl mx-auto">
        
        <!-- Quick Navigation -->
        <div class="bg-brand-grey-50 rounded-xl p-6 mb-12">
          <h2 class="heading-tertiary text-brand-primary mb-4">Quick Navigation</h2>
          <div class="flex flex-wrap gap-3">
            <a href="#acceptance" class="text-brand-accent hover:text-brand-primary underline">Service Agreement</a>
            <a href="#services" class="text-brand-accent hover:text-brand-primary underline">Service Description</a>
            <a href="#obligations" class="text-brand-accent hover:text-brand-primary underline">Client Obligations</a>
            <a href="#fees" class="text-brand-accent hover:text-brand-primary underline">Fees & Payment</a>
            <a href="#intellectual" class="text-brand-accent hover:text-brand-primary underline">Intellectual Property</a>
            <a href="#liability" class="text-brand-accent hover:text-brand-primary underline">Liability & Disclaimers</a>
            <a href="#termination" class="text-brand-accent hover:text-brand-primary underline">Termination</a>
            <a href="#dispute" class="text-brand-accent hover:text-brand-primary underline">Dispute Resolution</a>
            <a href="#governing" class="text-brand-accent hover:text-brand-primary underline">Governing Law</a>
          </div>
        </div>

        <!-- Service Agreement and Acceptance -->
        <div class="mb-12" id="acceptance">
          <h2 class="heading-tertiary text-brand-primary mb-6">1. Service Agreement and Acceptance</h2>
          
          <div class="space-y-6 text-brand-grey-700">
            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">About This Agreement</h3>
              <p class="mb-4">
                These Terms of Service ("Terms", "Agreement") constitute a legally binding agreement between 
                Edgeview Finance Business Solutions Pty Ltd (ABN: [ABN Number], ACL: [ACL Number]) ("EVFBS", "we", "us", "our") 
                and you ("Client", "you", "your") for the provision of commercial finance brokerage services.
              </p>
            </div>

            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Acceptance of Terms</h3>
              <p class="mb-3">By engaging our services, you acknowledge that you have:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Read, understood, and agree to be bound by these Terms</li>
                <li>Authority to enter into this agreement on behalf of your business entity</li>
                <li>Capacity to enter into legally binding agreements under Australian law</li>
                <li>Received and understood our Credit Guide and Financial Services Guide</li>
              </ul>
            </div>

            <div class="bg-brand-accent-light rounded-lg p-6">
              <h4 class="font-semibold text-brand-grey-900 mb-3">Key Legislative Framework</h4>
              <p class="mb-3">Our services are governed by:</p>
              <ul class="list-disc list-inside space-y-2">
                <li>Australian Consumer Law (Competition and Consumer Act 2010)</li>
                <li>Australian Securities and Investments Commission Act 2001 (Cth)</li>
                <li>National Consumer Credit Protection Act 2009 (Cth)</li>
                <li>Corporations Act 2001 (Cth)</li>
                <li>Privacy Act 1988 (Cth) and Australian Privacy Principles</li>
                <li>Anti-Money Laundering and Counter-Terrorism Financing Act 2006 (Cth)</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Service Description and Scope -->
        <div class="mb-12" id="services">
          <h2 class="heading-tertiary text-brand-primary mb-6">2. Service Description and Scope</h2>
          
          <div class="space-y-6 text-brand-grey-700">
            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Commercial Finance Brokerage Services</h3>
              <p class="mb-4">We provide professional commercial finance brokerage services including:</p>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                  <h4 class="font-semibold text-brand-accent mb-3">Equipment Finance</h4>
                  <ul class="list-disc list-inside space-y-1 text-sm">
                    <li>Asset finance and equipment loans</li>
                    <li>Commercial vehicle financing</li>
                    <li>Construction equipment funding</li>
                    <li>Technology and machinery finance</li>
                    <li>Chattel mortgage structures</li>
                  </ul>
                </div>
                
                <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                  <h4 class="font-semibold text-brand-accent mb-3">Commercial Property</h4>
                  <ul class="list-disc list-inside space-y-1 text-sm">
                    <li>Business premises acquisition</li>
                    <li>Investment property loans</li>
                    <li>Development funding</li>
                    <li>Commercial refinancing</li>
                    <li>Construction finance</li>
                  </ul>
                </div>
                
                <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                  <h4 class="font-semibold text-brand-accent mb-3">Working Capital</h4>
                  <ul class="list-disc list-inside space-y-1 text-sm">
                    <li>Business overdrafts</li>
                    <li>Cash flow funding</li>
                    <li>Invoice factoring</li>
                    <li>Trade finance</li>
                    <li>Business credit cards</li>
                  </ul>
                </div>
                
                <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                  <h4 class="font-semibold text-brand-accent mb-3">Personal Lending</h4>
                  <ul class="list-disc list-inside space-y-1 text-sm">
                    <li>Home loans for business owners</li>
                    <li>Investment property finance</li>
                    <li>Equity release</li>
                    <li>SMSF lending</li>
                    <li>Personal secured loans</li>
                  </ul>
                </div>
              </div>
            </div>

            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Service Limitations</h3>
              <p class="mb-3">Our services do not include:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Legal advice (we recommend independent legal counsel)</li>
                <li>Accounting or taxation advice (consult your accountant)</li>
                <li>Investment advice or securities recommendations</li>
                <li>Insurance brokerage (though we can provide referrals)</li>
                <li>Guarantee or assurance of loan approval</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Client Obligations -->
        <div class="mb-12" id="obligations">
          <h2 class="heading-tertiary text-brand-primary mb-6">3. Client Obligations and Responsibilities</h2>
          
          <div class="space-y-6 text-brand-grey-700">
            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Information Provision</h3>
              <p class="mb-3">You agree to provide:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Complete, accurate, and current information about your financial position</li>
                <li>All necessary documents including financial statements and tax returns</li>
                <li>Prompt notification of any material changes to your circumstances</li>
                <li>Timely responses to requests for additional information</li>
              </ul>
            </div>

            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Professional Conduct</h3>
              <p class="mb-3">You agree to:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Engage with lenders and third parties professionally</li>
                <li>Attend scheduled meetings and consultations</li>
                <li>Comply with all lender requirements and conditions</li>
                <li>Maintain confidentiality of commercially sensitive information</li>
              </ul>
            </div>

            <div class="bg-brand-accent-light rounded-lg p-6">
              <h4 class="font-semibold text-brand-grey-900 mb-3">Important Notice</h4>
              <p>
                While we provide expert finance brokerage services, we strongly recommend seeking independent 
                professional advice from legal counsel and accounting professionals for contract review, 
                taxation implications, and business structure matters.
              </p>
            </div>
          </div>
        </div>

        <!-- Fees and Payment -->
        <div class="mb-12" id="fees">
          <h2 class="heading-tertiary text-brand-primary mb-6">4. Fees and Payment Terms</h2>
          
          <div class="space-y-6 text-brand-grey-700">
            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Fee Structure</h3>
              <p class="mb-4">Our professional fees are disclosed in our Fee Disclosure Statement and may include:</p>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                  <h4 class="font-semibold text-brand-accent mb-3">Lender Commission</h4>
                  <ul class="list-disc list-inside space-y-1 text-sm">
                    <li>Upfront commission (0.5% - 1.5% of loan)</li>
                    <li>Trail commission (0.1% - 0.3% per annum)</li>
                    <li>No direct cost for standard services</li>
                    <li>Rates vary by lender and product</li>
                  </ul>
                </div>
                
                <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                  <h4 class="font-semibold text-brand-accent mb-3">Professional Fees</h4>
                  <ul class="list-disc list-inside space-y-1 text-sm">
                    <li>Application preparation: $500 - $2,500</li>
                    <li>Strategic consulting: $350 per hour</li>
                    <li>Document review: $200 per hour</li>
                    <li>Expedited processing: $750</li>
                  </ul>
                </div>
              </div>
            </div>

            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Payment Terms</h3>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Commission payments received from lenders upon loan settlement</li>
                <li>Professional service fees payable within 14 days of invoice</li>
                <li>Third-party costs payable immediately upon invoice</li>
              </ul>
            </div>

            <div class="bg-brand-accent-light rounded-lg p-6">
              <h4 class="font-semibold text-brand-grey-900 mb-3">Transparent Fee Disclosure</h4>
              <p>
                We are committed to transparent fee disclosure in accordance with ASIC Regulatory Guide 273. 
                All fees, commission arrangements, and potential conflicts of interest are disclosed in our 
                Financial Services Guide and Fee Disclosure Statement.
              </p>
            </div>
          </div>
        </div>

        <!-- Intellectual Property -->
        <div class="mb-12" id="intellectual">
          <h2 class="heading-tertiary text-brand-primary mb-6">5. Intellectual Property Rights</h2>
          
          <div class="space-y-6 text-brand-grey-700">
            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Our Intellectual Property</h3>
              <p class="mb-3">All intellectual property in our services remains our exclusive property, including:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Technology platforms and proprietary software</li>
                <li>Business processes and methodologies</li>
                <li>Marketing materials and presentations</li>
                <li>Trade marks and branding</li>
                <li>Databases and client management systems</li>
              </ul>
            </div>

            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Restrictions on Use</h3>
              <p class="mb-3">You agree not to:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Copy or reverse-engineer our proprietary systems</li>
                <li>Use our intellectual property for competitive purposes</li>
                <li>Modify or create derivative works from our materials</li>
                <li>Transfer rights to third parties</li>
                <li>Use our trade marks without written permission</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Liability and Disclaimers -->
        <div class="mb-12" id="liability">
          <h2 class="heading-tertiary text-brand-primary mb-6">6. Liability and Disclaimers</h2>
          
          <div class="space-y-6 text-brand-grey-700">
            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Service Disclaimers</h3>
              <p class="mb-3">While we provide professional services to high standards, we disclaim liability for:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Loan approval outcomes or specific terms</li>
                <li>Lender credit policies and decisions</li>
                <li>Market conditions and interest rate changes</li>
                <li>Third-party service performance</li>
                <li>Economic factors affecting applications</li>
              </ul>
            </div>

            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Consumer Law Rights</h3>
              <p class="mb-3">Under Australian Consumer Law, you have rights that cannot be excluded, including:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Services provided with due care and skill</li>
                <li>Services fit for purpose and as described</li>
                <li>Remedy for failure to meet consumer guarantees</li>
                <li>Protection against misleading conduct</li>
              </ul>
            </div>

            <div class="bg-brand-accent-light rounded-lg p-6">
              <h4 class="font-semibold text-brand-grey-900 mb-3">Professional Indemnity Insurance</h4>
              <p>
                We maintain professional indemnity insurance covering professional negligence, 
                breach of duty, privacy breaches, and regulatory compliance matters.
              </p>
            </div>
          </div>
        </div>

        <!-- Termination -->
        <div class="mb-12" id="termination">
          <h2 class="heading-tertiary text-brand-primary mb-6">7. Termination</h2>
          
          <div class="space-y-6 text-brand-grey-700">
            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Termination by Client</h3>
              <p class="mb-3">You may terminate our services at any time by:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Providing written notice to our office</li>
                <li>Requesting withdrawal of pending applications</li>
                <li>Ceasing to engage our ongoing services</li>
              </ul>
            </div>

            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Termination by EVFBS</h3>
              <p class="mb-3">We may terminate services immediately if:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>You breach these Terms and fail to remedy within 7 days</li>
                <li>You provide false or misleading information</li>
                <li>Payment of fees is overdue by more than 14 days</li>
                <li>Continuing services would breach our regulatory obligations</li>
              </ul>
            </div>

            <div class="bg-brand-accent-light rounded-lg p-6">
              <h4 class="font-semibold text-brand-grey-900 mb-3">Commission Rights</h4>
              <p>
                Termination does not affect our entitlement to upfront and trail commission 
                for loans settled through our introduction, or professional service fees for completed work.
              </p>
            </div>
          </div>
        </div>

        <!-- Dispute Resolution -->
        <div class="mb-12" id="dispute">
          <h2 class="heading-tertiary text-brand-primary mb-6">8. Dispute Resolution</h2>
          
          <div class="space-y-6 text-brand-grey-700">
            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Resolution Process</h3>
              <p class="mb-4">We are committed to resolving disputes fairly through:</p>
              
              <div class="space-y-4">
                <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                  <div class="flex items-start gap-4">
                    <div class="bg-brand-accent text-white rounded-full w-8 h-8 flex items-center justify-center font-bold flex-shrink-0">1</div>
                    <div>
                      <h4 class="font-semibold text-brand-grey-900 mb-2">Internal Resolution</h4>
                      <p class="text-sm">Direct discussion with your consultant to identify and resolve concerns promptly.</p>
                    </div>
                  </div>
                </div>
                
                <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                  <div class="flex items-start gap-4">
                    <div class="bg-brand-accent text-white rounded-full w-8 h-8 flex items-center justify-center font-bold flex-shrink-0">2</div>
                    <div>
                      <h4 class="font-semibold text-brand-grey-900 mb-2">Formal Complaints</h4>
                      <p class="text-sm">Written complaint to our Complaints Officer with acknowledgment within 7 days.</p>
                    </div>
                  </div>
                </div>
                
                <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                  <div class="flex items-start gap-4">
                    <div class="bg-brand-accent text-white rounded-full w-8 h-8 flex items-center justify-center font-bold flex-shrink-0">3</div>
                    <div>
                      <h4 class="font-semibold text-brand-grey-900 mb-2">External Resolution</h4>
                      <p class="text-sm">Referral to Australian Financial Complaints Authority (AFCA) for independent resolution.</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="bg-brand-accent-light rounded-lg p-6">
              <h4 class="font-semibold text-brand-grey-900 mb-3">External Dispute Resolution</h4>
              <p class="mb-3"><strong>Australian Financial Complaints Authority (AFCA)</strong></p>
              <p class="text-sm">
                Website: www.afca.org.au<br/>
                Phone: 1800 931 678<br/>
                Email: info@afca.org.au<br/>
                Post: GPO Box 3, Melbourne VIC 3001
              </p>
            </div>
          </div>
        </div>

        <!-- Governing Law -->
        <div class="mb-12" id="governing">
          <h2 class="heading-tertiary text-brand-primary mb-6">9. Governing Law and Jurisdiction</h2>
          
          <div class="space-y-6 text-brand-grey-700">
            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Applicable Law</h3>
              <p class="mb-3">These Terms are governed by the laws of Queensland and the Commonwealth of Australia, including:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Queensland contract law and commercial legislation</li>
                <li>Commonwealth consumer protection and financial services laws</li>
                <li>Australian Consumer Law and ASIC regulations</li>
                <li>National Consumer Credit Protection Act 2009</li>
              </ul>
            </div>

            <div>
              <h3 class="font-semibold text-brand-grey-900 mb-3">Jurisdiction</h3>
              <p>
                The parties submit to the non-exclusive jurisdiction of the courts of Queensland 
                and Federal courts sitting in Queensland for any legal proceedings.
              </p>
            </div>

            <div class="bg-brand-accent-light rounded-lg p-6">
              <h4 class="font-semibold text-brand-grey-900 mb-3">Australian Consumer Law Protection</h4>
              <p>
                These Terms are subject to Australian Consumer Law, which provides protections that cannot be excluded. 
                Small businesses with fewer than 20 employees may be entitled to additional protections under the ACL.
              </p>
            </div>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="bg-gradient-to-br from-brand-accent to-brand-primary rounded-2xl p-8 text-white text-center">
          <h2 class="heading-tertiary text-white mb-4">
            Questions About Our Terms?
          </h2>
          <p class="body-medium text-brand-grey-100 mb-6">
            Our legal and compliance team is available to clarify any aspects of our service agreement
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="btn-primary bg-white text-brand-primary hover:bg-brand-grey-50">
              Contact Legal Department
            </a>
            <a href="/privacy" class="btn-secondary border-white text-white hover:bg-white hover:text-brand-primary">
              View Privacy Policy
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Agency11Layout>