            padding: 2rem;
            border-radius: 10px;
            border: 2px solid #e67e22;
        }
        
        .option h4 {
            color: #e67e22;
            margin-bottom: 1rem;
            margin-top: 0;
        }
        
        /* Regulatory Framework */
        .regulatory-framework {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }
        
        .framework-section {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }
        
        .framework-section h4 {
            color: #2c5aa0;
            margin-bottom: 1rem;
            margin-top: 0;
        }
        
        /* Contact Details */
        .contact-details {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }
        
        .contact-card {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.1);
        }
        
        .contact-card h4 {
            color: #2c5aa0;
            margin-bottom: 1rem;
            margin-top: 0;
        }
        
        .business-info {
            background: #f8f9fa;
            padding: 2rem;
            border-radius: 10px;
            margin: 2rem 0;
        }
        
        .regulatory-contacts {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }
        
        .contact-item {
            background: #e8f4f8;
            padding: 1.5rem;
            border-radius: 8px;
            border-left: 4px solid #2c5aa0;
        }
        
        .contact-item h4 {
            color: #2c5aa0;
            margin-bottom: 1rem;
            margin-top: 0;
        }
        
        /* Version Info */
        .version-info {
            background: #e8f4f8;
            padding: 1.5rem;
            border-radius: 5px;
            margin: 1rem 0;
        }
        
        .version-info p {
            margin-bottom: 0.5rem;
        }
        
        /* CTA Section */
        .cta-section {
            background: #2c5aa0;
            color: white;
            padding: 80px 20px;
            text-align: center;
        }
        
        .cta-section h2 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        
        .cta-section p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
        }
        
        .cta-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        .primary-button {
            background: #e67e22;
            color: white;
            padding: 15px 30px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s;
        }
        
        .primary-button:hover {
            background: #d35400;
            transform: translateY(-2px);
        }
        
        .secondary-button {
            background: transparent;
            color: white;
            padding: 15px 30px;
            text-decoration: none;
            border: 2px solid white;
            border-radius: 5px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s;
        }
        
        .secondary-button:hover {
            background: white;
            color: #2c5aa0;
        }
        
        .large {
            font-size: 1.2rem;
            padding: 18px 36px;
        }
        
        /* Footer */
        footer {
            background: #333;
            color: white;
            padding: 40px 20px 20px;
        }
        
        .footer-content {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }
        
        .footer-section h4 {
            color: #e67e22;
            margin-bottom: 1rem;
        }
        
        .footer-section ul {
            list-style: none;
        }
        
        .footer-section a {
            color: #ccc;
            text-decoration: none;
            transition: color 0.3s;
        }
        
        .footer-section a:hover,
        .footer-section a.active {
            color: white;
        }
        
        .footer-bottom {
            border-top: 1px solid #555;
            padding-top: 1rem;
            text-align: center;
            color: #ccc;
        }
        
        .footer-bottom a.active {
            color: #e67e22;
            font-weight: 600;
        }
        
        /* Responsive Design */
        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2rem;
            }
            
            .hero-subtitle {
                font-size: 1.1rem;
            }
            
            .hero-meta {
                flex-direction: column;
                gap: 1rem;
            }
            
            .nav-menu {
                display: none;
            }
            
            .nav-links {
                flex-direction: column;
                align-items: center;
            }
            
            .terms-section h2 {
                font-size: 2rem;
            }
            
            .service-categories,
            .fee-categories,
            .liability-sections,
            .external-options,
            .regulatory-framework,
            .contact-details {
                grid-template-columns: 1fr;
            }
            
            .step {
                flex-direction: column;
                text-align: center;
            }
            
            .cta-buttons {
                flex-direction: column;
                align-items: center;
            }
        }
        
        @media (max-width: 480px) {
            .terms-section {
                padding: 40px 10px;
            }
            
            .container {
                padding: 0 10px;
            }
            
            .category,
            .section,
            .step,
            .option,
            .contact-card,
            .framework-section {
                padding: 1.5rem;
            }
        }
    </style>
</body>
</html>