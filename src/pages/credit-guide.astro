---
import Agency11Layout from '../layouts/Agency11Layout.astro';

const pageTitle = 'Credit Guide | Edgeview Finance Business Solutions - ASIC Compliant Commercial Finance Broker';
const pageDescription = 'Comprehensive ASIC RG 206 compliant credit guide for EVFBS commercial finance brokerage services. Essential information about our credit licence, services, fees, complaints process, and your rights under the National Credit Code.';

const lastUpdated = "15 August 2025";
const reviewDate = "15 August 2026";
const creditLicenceNumber = "ACL-XXXXXX"; // Replace with actual ACL number
const abnNumber = "XX XXX XXX XXX"; // Replace with actual ABN
---

<Agency11Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="section-hero bg-gradient-to-br from-brand-primary to-brand-primary-dark text-white">
    <div class="container-default">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="heading-primary text-white mb-6">
          Credit Guide
        </h1>
        <p class="body-large text-brand-grey-100 mb-4">
          ASIC RG 206 compliant credit guide providing essential information about our commercial finance 
          brokerage services, licensing, fees, and your rights
        </p>
        <div class="flex flex-wrap justify-center gap-4 text-sm text-brand-grey-200">
          <span><strong>Last Updated:</strong> {lastUpdated}</span>
          <span><strong>Next Review:</strong> {reviewDate}</span>
          <span><strong>ASIC Compliant:</strong> RG 206</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Credit Guide Content -->
  <section class="section-content">
    <div class="container-default">
      <div class="max-w-4xl mx-auto">
        
        <!-- Important Notice -->
        <div class="bg-brand-accent-light rounded-xl p-8 mb-12">
          <h2 class="heading-tertiary text-brand-accent mb-4">Important Information</h2>
          <p class="text-brand-grey-700 mb-4">
            This Credit Guide is provided to you under section 126 of the National Consumer Credit Protection Act 2009. 
            It contains important information about our credit services, including our Australian Credit Licence details, 
            the services we provide, how we are remunerated, and your rights and obligations.
          </p>
          <p class="font-semibold text-brand-grey-900">
            Please read this document carefully before engaging our services.
          </p>
        </div>

        <!-- Quick Navigation -->
        <div class="bg-brand-grey-50 rounded-xl p-6 mb-12">
          <h2 class="heading-tertiary text-brand-primary mb-4">Quick Navigation</h2>
          <div class="flex flex-wrap gap-3">
            <a href="#licensee" class="text-brand-accent hover:text-brand-primary underline">Licensee Information</a>
            <a href="#representative" class="text-brand-accent hover:text-brand-primary underline">Credit Representative</a>
            <a href="#services" class="text-brand-accent hover:text-brand-primary underline">Services Provided</a>
            <a href="#remuneration" class="text-brand-accent hover:text-brand-primary underline">Fees & Commission</a>
            <a href="#conflicts" class="text-brand-accent hover:text-brand-primary underline">Conflicts of Interest</a>
            <a href="#complaints" class="text-brand-accent hover:text-brand-primary underline">Complaints Process</a>
            <a href="#privacy" class="text-brand-accent hover:text-brand-primary underline">Privacy Information</a>
            <a href="#contact" class="text-brand-accent hover:text-brand-primary underline">Contact Details</a>
          </div>
        </div>

        <!-- Credit Licensee Information -->
        <div class="mb-12" id="licensee">
          <h2 class="heading-tertiary text-brand-primary mb-6">Australian Credit Licensee Information</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <h3 class="font-semibold text-brand-primary mb-3">Credit Licensee</h3>
              <p class="text-sm text-brand-grey-700"><strong>Entity Name:</strong> Edgeview Finance Business Solutions Pty Ltd</p>
              <p class="text-sm text-brand-grey-700"><strong>ABN:</strong> {abnNumber}</p>
              <p class="text-sm text-brand-grey-700"><strong>ACL:</strong> {creditLicenceNumber}</p>
              <p class="text-sm text-brand-grey-700"><strong>ASIC Registration:</strong> Australian Credit Licensee</p>
            </div>
            
            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <h3 class="font-semibold text-brand-primary mb-3">Licence Authorisation</h3>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li>Providing credit assistance</li>
                <li>Suggesting credit contracts</li>
                <li>Assisting with applications</li>
                <li>Credit provider recommendations</li>
              </ul>
            </div>
            
            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <h3 class="font-semibold text-brand-primary mb-3">Registered Office</h3>
              <p class="text-sm text-brand-grey-700">
                <strong>Address:</strong><br/>
                [Business Address]<br/>
                [City, State, Postcode]<br/>
                Australia
              </p>
              <p class="text-sm text-brand-grey-700 mt-2">
                <strong>Hours:</strong> Mon-Fri, 8AM-6PM AEST
              </p>
            </div>
          </div>

          <div class="bg-brand-accent-light rounded-lg p-6">
            <h4 class="font-semibold text-brand-grey-900 mb-3">ASIC Verification</h4>
            <p class="text-brand-grey-700">
              You can verify our licence details on the ASIC Professional Registers at 
              <a href="https://connectonline.asic.gov.au" target="_blank" rel="noopener noreferrer" class="text-brand-accent underline">
              https://connectonline.asic.gov.au</a> using our ACL number {creditLicenceNumber}.
            </p>
          </div>
        </div>

        <!-- Credit Representative Information -->
        <div class="mb-12" id="representative">
          <h2 class="heading-tertiary text-brand-primary mb-6">Credit Representative Information</h2>
          
          <p class="text-brand-grey-700 mb-6">
            [Credit Representative Name] operates as an authorised credit representative of 
            Edgeview Finance Business Solutions Pty Ltd under our Australian Credit Licence.
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div class="bg-white rounded-lg p-6 border-2 border-brand-accent">
              <h4 class="font-semibold text-brand-accent mb-3">Representative Details</h4>
              <p class="text-sm text-brand-grey-700"><strong>Name:</strong> [Credit Representative Name]</p>
              <p class="text-sm text-brand-grey-700"><strong>CRN:</strong> [CRN Number]</p>
              <p class="text-sm text-brand-grey-700"><strong>Qualifications:</strong> Certificate IV in Finance and Mortgage Broking</p>
              <p class="text-sm text-brand-grey-700"><strong>Memberships:</strong> Finance Brokers Association of Australia (FBAA)</p>
            </div>
            
            <div class="bg-white rounded-lg p-6 border-2 border-brand-accent">
              <h4 class="font-semibold text-brand-accent mb-3">Authorisation Scope</h4>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li>Provide credit assistance</li>
                <li>Assist with loan applications</li>
                <li>Liaise with lenders</li>
                <li>Account management</li>
                <li>Responsible lending assessments</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Services Provided -->
        <div class="mb-12" id="services">
          <h2 class="heading-tertiary text-brand-primary mb-6">Credit Services We Provide</h2>
          
          <p class="text-brand-grey-700 mb-6">
            Under our Australian Credit Licence, we provide credit assistance services specifically 
            focused on commercial finance solutions for Australian businesses.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <h4 class="font-semibold text-brand-accent mb-3">Equipment Finance</h4>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li>Commercial vehicle finance</li>
                <li>Construction equipment</li>
                <li>Technology and IT equipment</li>
                <li>Chattel mortgages</li>
                <li>Operating and finance leases</li>
              </ul>
              <p class="text-sm font-semibold text-brand-accent mt-3">
                Loan Range: $20,000 to $2,000,000+
              </p>
            </div>

            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <h4 class="font-semibold text-brand-accent mb-3">Commercial Property Finance</h4>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li>Business premises purchase</li>
                <li>Commercial investment loans</li>
                <li>Development finance</li>
                <li>Industrial property finance</li>
                <li>Commercial mortgage solutions</li>
              </ul>
              <p class="text-sm font-semibold text-brand-accent mt-3">
                Loan Range: $100,000 to $10,000,000+
              </p>
            </div>

            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <h4 class="font-semibold text-brand-accent mb-3">Working Capital Solutions</h4>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li>Business line of credit</li>
                <li>Overdraft facilities</li>
                <li>Invoice factoring</li>
                <li>Trade finance</li>
                <li>Project-specific funding</li>
              </ul>
              <p class="text-sm font-semibold text-brand-accent mt-3">
                Facility Range: $50,000 to $5,000,000+
              </p>
            </div>

            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <h4 class="font-semibold text-brand-accent mb-3">Personal Lending</h4>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li>Self-employed home loans</li>
                <li>Investment property finance</li>
                <li>Low-doc lending</li>
                <li>Asset-based lending</li>
                <li>Private lending arrangements</li>
              </ul>
              <p class="text-sm font-semibold text-brand-accent mt-3">
                Loan Range: $100,000 to $5,000,000+
              </p>
            </div>
          </div>

          <div class="bg-brand-accent-light rounded-lg p-6">
            <h4 class="font-semibold text-brand-grey-900 mb-3">Important Note: Commercial Focus</h4>
            <p class="text-brand-grey-700">
              Our services are specifically designed for commercial finance and business lending. 
              We do not provide consumer credit assistance for personal purchases unrelated to business activities.
            </p>
          </div>
        </div>

        <!-- Remuneration and Fees -->
        <div class="mb-12" id="remuneration">
          <h2 class="heading-tertiary text-brand-primary mb-6">How We Are Remunerated</h2>
          
          <p class="text-brand-grey-700 mb-6">
            We operate on a commission-based model where we receive payments from lenders when 
            successful finance arrangements are established. This means our services are typically 
            provided at no direct cost to you.
          </p>

          <div class="space-y-6">
            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <h4 class="font-semibold text-brand-accent mb-3">Upfront Commission</h4>
              <p class="text-brand-grey-700 mb-3">
                We receive an upfront commission from the lender when your loan settles:
              </p>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li><strong>Equipment Finance:</strong> 0.5% to 2.5% of loan amount</li>
                <li><strong>Commercial Property:</strong> 0.6% to 1.2% of loan amount</li>
                <li><strong>Working Capital:</strong> 1.0% to 3.0% of facility limit</li>
                <li><strong>Personal Lending:</strong> 0.65% to 1.1% of loan amount</li>
              </ul>
              <p class="text-sm text-brand-grey-600 italic mt-3">
                Commission rates vary based on loan type, lender, loan amount, and terms.
              </p>
            </div>

            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <h4 class="font-semibold text-brand-accent mb-3">Trail Commission</h4>
              <p class="text-brand-grey-700 mb-3">
                For some loan products, we may receive ongoing trail commission:
              </p>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li><strong>Home Loans:</strong> 0.15% to 0.25% per annum</li>
                <li><strong>Commercial Facilities:</strong> 0.10% to 0.50% per annum</li>
                <li><strong>Line of Credit:</strong> 0.25% to 0.75% per annum</li>
              </ul>
            </div>

            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <h4 class="font-semibold text-brand-accent mb-3">Direct Fees (When Applicable)</h4>
              <p class="text-brand-grey-700 mb-3">
                In specific circumstances, we may charge direct fees:
              </p>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li><strong>Complex Structuring:</strong> $2,500 to $15,000</li>
                <li><strong>Due Diligence:</strong> $1,500 to $5,000</li>
                <li><strong>Documentation Review:</strong> $500 to $2,000</li>
                <li><strong>Unsuccessful Application:</strong> $500 to $2,500 (if disclosed upfront)</li>
              </ul>
              <p class="text-sm font-semibold text-brand-grey-900 mt-3">
                Any direct fees will be clearly disclosed and agreed upon in writing before we commence work.
              </p>
            </div>
          </div>

          <div class="bg-brand-accent-light rounded-lg p-6 mt-6">
            <h4 class="font-semibold text-brand-grey-900 mb-3">Transparency Commitment</h4>
            <p class="text-brand-grey-700">
              We are committed to full transparency about our remuneration. Before proceeding with 
              any application, we will provide you with specific details of commission amounts, 
              any direct fees, and how our remuneration may influence our recommendations.
            </p>
          </div>
        </div>

        <!-- Conflicts of Interest -->
        <div class="mb-12" id="conflicts">
          <h2 class="heading-tertiary text-brand-primary mb-6">Conflicts of Interest</h2>
          
          <p class="text-brand-grey-700 mb-6">
            We are committed to managing conflicts of interest to ensure our recommendations 
            are in your best interests. We have policies and procedures to identify, 
            manage, and disclose any potential conflicts.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
            <div class="bg-white rounded-lg p-6 border-l-4 border-brand-accent">
              <h4 class="font-semibold text-brand-accent mb-3">Remuneration-Based Conflicts</h4>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li>Diverse lender panel</li>
                <li>Needs-based recommendations</li>
                <li>Commission disclosure</li>
                <li>Documented rationale</li>
              </ul>
            </div>

            <div class="bg-white rounded-lg p-6 border-l-4 border-brand-accent">
              <h4 class="font-semibold text-brand-accent mb-3">Lender Relationships</h4>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li>Competitive product access</li>
                <li>Volume incentive disclosure</li>
                <li>Independent recommendations</li>
                <li>Managed through policy</li>
              </ul>
            </div>

            <div class="bg-white rounded-lg p-6 border-l-4 border-brand-accent">
              <h4 class="font-semibold text-brand-accent mb-3">Related Entity Interests</h4>
              <ul class="list-disc list-inside space-y-1 text-sm text-brand-grey-700">
                <li>No lender ownership</li>
                <li>Referral arrangements disclosed</li>
                <li>Independent advice</li>
                <li>Optional referrals only</li>
              </ul>
            </div>
          </div>

          <div class="bg-brand-accent-light rounded-lg p-6">
            <h4 class="font-semibold text-brand-grey-900 mb-3">Your Right to Know</h4>
            <p class="text-brand-grey-700">
              You have the right to ask about any potential conflicts of interest that may 
              affect our services. We encourage you to discuss any concerns about our 
              recommendations or the basis for our advice.
            </p>
          </div>
        </div>

        <!-- Complaints Process -->
        <div class="mb-12" id="complaints">
          <h2 class="heading-tertiary text-brand-primary mb-6">Complaints and Dispute Resolution</h2>
          
          <p class="text-brand-grey-700 mb-6">
            If you have a complaint about our credit services, we have an internal 
            dispute resolution process to address your concerns promptly and fairly.
          </p>

          <div class="space-y-4 mb-8">
            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <div class="flex items-start gap-4">
                <div class="bg-brand-accent text-white rounded-full w-8 h-8 flex items-center justify-center font-bold flex-shrink-0">1</div>
                <div>
                  <h4 class="font-semibold text-brand-grey-900 mb-2">Lodge Your Complaint</h4>
                  <p class="text-sm text-brand-grey-700">
                    Contact us via phone (1300 XXX XXX), email (complaints@edgeviewfinance.com.au), 
                    or in writing with details of your complaint.
                  </p>
                </div>
              </div>
            </div>
            
            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <div class="flex items-start gap-4">
                <div class="bg-brand-accent text-white rounded-full w-8 h-8 flex items-center justify-center font-bold flex-shrink-0">2</div>
                <div>
                  <h4 class="font-semibold text-brand-grey-900 mb-2">Acknowledgment</h4>
                  <p class="text-sm text-brand-grey-700">
                    We will acknowledge your complaint within 1 business day and provide a reference number for tracking.
                  </p>
                </div>
              </div>
            </div>
            
            <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
              <div class="flex items-start gap-4">
                <div class="bg-brand-accent text-white rounded-full w-8 h-8 flex items-center justify-center font-bold flex-shrink-0">3</div>
                <div>
                  <h4 class="font-semibold text-brand-grey-900 mb-2">Investigation & Resolution</h4>
                  <p class="text-sm text-brand-grey-700">
                    We investigate and provide a written response within 21-45 days with our findings and any remedial action.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white rounded-lg p-6 border-2 border-brand-primary">
              <h4 class="font-semibold text-brand-primary mb-3">Australian Financial Complaints Authority (AFCA)</h4>
              <p class="text-sm text-brand-grey-700 mb-3">
                If unresolved after 45 days, you can lodge a complaint with AFCA:
              </p>
              <p class="text-sm text-brand-grey-700">
                <strong>Website:</strong> <a href="https://www.afca.org.au" target="_blank" rel="noopener noreferrer" class="text-brand-accent underline">www.afca.org.au</a><br/>
                <strong>Phone:</strong> 1800 931 678<br/>
                <strong>Email:</strong> info@afca.org.au<br/>
                <strong>Post:</strong> GPO Box 3, Melbourne VIC 3001
              </p>
            </div>

            <div class="bg-white rounded-lg p-6 border-2 border-brand-primary">
              <h4 class="font-semibold text-brand-primary mb-3">Australian Securities and Investments Commission (ASIC)</h4>
              <p class="text-sm text-brand-grey-700 mb-3">
                ASIC regulates our credit licence:
              </p>
              <p class="text-sm text-brand-grey-700">
                <strong>Website:</strong> <a href="https://www.asic.gov.au" target="_blank" rel="noopener noreferrer" class="text-brand-accent underline">www.asic.gov.au</a><br/>
                <strong>Phone:</strong> 1300 300 630<br/>
                <strong>Online:</strong> ASIC Report Misconduct page
              </p>
            </div>
          </div>

          <div class="bg-brand-accent-light rounded-lg p-6 mt-6">
            <h4 class="font-semibold text-brand-grey-900 mb-3">No Cost Complaints Service</h4>
            <p class="text-brand-grey-700">
              Our internal complaints handling service is provided at no cost to you. 
              AFCA's service is also free. You may wish to seek independent legal 
              advice, though this is at your own cost.
            </p>
          </div>
        </div>

        <!-- Privacy Information -->
        <div class="mb-12" id="privacy">
          <h2 class="heading-tertiary text-brand-primary mb-6">Privacy and Personal Information</h2>
          
          <p class="text-brand-grey-700 mb-6">
            We collect, use, and disclose personal information (including credit information) 
            in accordance with the Privacy Act 1988 and the Credit Reporting Privacy Code 2014.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <div class="bg-white rounded-lg p-4 border-l-4 border-brand-accent">
              <h4 class="font-semibold text-brand-accent mb-2">Information Collection</h4>
              <ul class="list-disc list-inside space-y-1 text-xs text-brand-grey-700">
                <li>Identity details</li>
                <li>Financial information</li>
                <li>Credit reports</li>
                <li>Reference checks</li>
              </ul>
            </div>

            <div class="bg-white rounded-lg p-4 border-l-4 border-brand-accent">
              <h4 class="font-semibold text-brand-accent mb-2">Information Use</h4>
              <ul class="list-disc list-inside space-y-1 text-xs text-brand-grey-700">
                <li>Assess credit needs</li>
                <li>Product recommendations</li>
                <li>Submit applications</li>
                <li>Ongoing management</li>
              </ul>
            </div>

            <div class="bg-white rounded-lg p-4 border-l-4 border-brand-accent">
              <h4 class="font-semibold text-brand-accent mb-2">Information Disclosure</h4>
              <ul class="list-disc list-inside space-y-1 text-xs text-brand-grey-700">
                <li>Credit providers</li>
                <li>Credit reporting bodies</li>
                <li>Professional services</li>
                <li>Service providers</li>
              </ul>
            </div>

            <div class="bg-white rounded-lg p-4 border-l-4 border-brand-accent">
              <h4 class="font-semibold text-brand-accent mb-2">Your Privacy Rights</h4>
              <ul class="list-disc list-inside space-y-1 text-xs text-brand-grey-700">
                <li>Access information</li>
                <li>Request corrections</li>
                <li>Make complaints</li>
                <li>Opt out of marketing</li>
              </ul>
            </div>
          </div>

          <div class="bg-brand-accent-light rounded-lg p-6">
            <h4 class="font-semibold text-brand-grey-900 mb-3">Full Privacy Policy</h4>
            <p class="text-brand-grey-700">
              For complete information about how we handle your personal information, 
              please read our full <a href="/privacy" class="text-brand-accent underline">Privacy Policy</a>. 
              Contact our Privacy Officer at privacy@edgeviewfinance.com.au with any 
              privacy-related questions.
            </p>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="mb-12" id="contact">
          <h2 class="heading-tertiary text-brand-primary mb-6">Contact Information</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <div class="bg-white rounded-lg p-4 border border-brand-grey-200">
              <h3 class="font-semibold text-brand-primary mb-2">Credit Licensee</h3>
              <p class="text-xs text-brand-grey-700">
                <strong>EVFBS Pty Ltd</strong><br/>
                ACL: {creditLicenceNumber}<br/>
                ABN: {abnNumber}<br/>
                [Business Address]<br/>
                [City, State, Postcode]
              </p>
            </div>

            <div class="bg-white rounded-lg p-4 border border-brand-grey-200">
              <h3 class="font-semibold text-brand-primary mb-2">General Enquiries</h3>
              <p class="text-xs text-brand-grey-700">
                <strong>Phone:</strong> 1300 XXX XXX<br/>
                <strong>Email:</strong> enquiries@edgeviewfinance.com.au<br/>
                <strong>Hours:</strong> Mon-Fri<br/>
                8:00 AM - 6:00 PM AEST
              </p>
            </div>

            <div class="bg-white rounded-lg p-4 border border-brand-grey-200">
              <h3 class="font-semibold text-brand-primary mb-2">Complaints</h3>
              <p class="text-xs text-brand-grey-700">
                <strong>Phone:</strong> 1300 XXX XXX<br/>
                <strong>Email:</strong> complaints@edgeviewfinance.com.au<br/>
                <strong>Response:</strong><br/>
                21-45 days resolution
              </p>
            </div>

