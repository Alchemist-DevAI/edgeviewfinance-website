---
// Equipment Finance Page - Strategic Equipment Financing for Commercial Trades
// Optimized for Ben the Business Builder ICP (excluding residential builders)
import Agency11Layout from '../layouts/Agency11Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const siteData = {
  title: "Equipment Finance Australia | Commercial Trades & Civil Contractors | EVFBS",
  description: "Strategic equipment financing for commercial trades, civil contractors, and industrial businesses. Heavy machinery, vehicles, and specialised equipment finance from $20K to $500K+ with competitive rates.",
  keywords: "equipment finance Australia, commercial vehicle finance, heavy machinery loans, trade equipment financing, civil contractor equipment, industrial equipment finance"
};
---

<Agency11Layout title={siteData.title} description={siteData.description} keywords={siteData.keywords}>
  
  <!-- Equipment Finance Service Schema -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://edgeviewfinance.com.au/equipment-finance",
    "name": "Equipment Finance",
    "alternateName": "Commercial Equipment Financing",
    "description": "Strategic equipment financing for commercial trades, civil contractors, and industrial businesses with competitive rates and flexible terms",
    "serviceType": "Equipment Financing",
    "provider": {
      "@type": "FinancialService",
      "@id": "https://edgeviewfinance.com.au/#organization",
      "name": "Edgeview Finance Business Solutions",
      "areaServed": {
        "@type": "Country",
        "name": "Australia"
      }
    },
    "offers": {
      "@type": "Offer",
      "name": "Equipment Finance Solutions",
      "description": "Flexible equipment financing from $20K to $500K+ for commercial trades and civil contractors",
      "itemOffered": {
        "@type": "Service",
        "name": "Equipment Finance",
        "category": "Commercial Finance"
      }
    },
    "audience": {
      "@type": "BusinessAudience",
      "businessType": ["Commercial Trades", "Civil Contractors", "Industrial Businesses"],
      "numberOfEmployees": "10-25"
    }
  }
  </script>

  <Header />

    <main>
        <!-- Hero Section -->
        <section class="section-hero hero-section">
            <div class="container-default">
                <div class="text-center">
                    <div class="breadcrumb text-white/80 mb-4">
                        <a href="/" class="text-white hover:text-white">Home</a> > <a href="/services" class="text-white hover:text-white">Services</a> > Equipment Finance
                    </div>
                    <h1 class="heading-primary text-white mb-6">Strategic Equipment Finance for Commercial Trades & Civil Contractors</h1>
                    <p class="hero-subtitle text-xl lg:text-2xl font-light mb-8 text-gray-100 max-w-4xl mx-auto">
                        Professional equipment financing solutions from $20K to $500K+ for heavy machinery, commercial vehicles, and specialised trade equipment. Competitive rates with flexible terms designed for established commercial businesses.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center button-gap mb-8">
                        <a href="/get-quote?service=equipment-finance" class="btn-primary btn-large">Get Equipment Finance Quote</a>
                        <a href="/calculator" class="btn-secondary btn-large text-white border-white hover:bg-white hover:text-secondary-dark">Calculate Repayments</a>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center flex-wrap text-gray-100">
                        <span class="flex items-center gap-2">✓ 24-48 Hour Approvals</span>
                        <span class="flex items-center gap-2">✓ Competitive Commercial Rates</span>
                        <span class="flex items-center gap-2">✓ $500M+ Equipment Financed</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Equipment Types Section -->
        <section class="section-content bg-neutral-light">
            <div class="container-default">
                <h2 class="heading-secondary text-center mb-16">Equipment We Finance for Commercial Trades</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="service-card-consistent">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Heavy Machinery & Construction</h3>
                        <ul class="space-y-2">
                            <li class="body-medium text-gray-700">Excavators, Diggers & Earthmoving Equipment</li>
                            <li class="body-medium text-gray-700">Cranes & Lifting Equipment</li>
                            <li class="body-medium text-gray-700">Concrete Pumps & Mixers</li>
                            <li class="body-medium text-gray-700">Bulldozers & Graders</li>
                            <li class="body-medium text-gray-700">Compactors & Road Construction</li>
                        </ul>
                    </div>
                    
                    <div class="service-card-consistent">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Commercial Vehicles & Fleet</h3>
                        <ul class="space-y-2">
                            <li class="body-medium text-gray-700">Commercial Utes & Work Vehicles</li>
                            <li class="body-medium text-gray-700">Truck & Heavy Vehicle Fleet</li>
                            <li class="body-medium text-gray-700">Specialised Service Vehicles</li>
                            <li class="body-medium text-gray-700">Trailers & Transport Equipment</li>
                            <li class="body-medium text-gray-700">Van Conversions & Fit-Outs</li>
                        </ul>
                    </div>
                    
                    <div class="service-card-consistent">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Trade & Industrial Equipment</h3>
                        <ul class="space-y-2">
                            <li class="body-medium text-gray-700">Welding & Fabrication Machinery</li>
                            <li class="body-medium text-gray-700">HVAC Installation Equipment</li>
                            <li class="body-medium text-gray-700">Electrical Testing & Safety Equipment</li>
                            <li class="body-medium text-gray-700">Workshop Tools & Machinery</li>
                            <li class="body-medium text-gray-700">Material Handling Equipment</li>
                        </ul>
                    </div>
                    
                    <div class="service-card-consistent">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Specialised Contractor Equipment</h3>
                        <ul class="space-y-2">
                            <li class="body-medium text-gray-700">Mining & Resources Equipment</li>
                            <li class="body-medium text-gray-700">Agricultural & Farming Machinery</li>
                            <li class="body-medium text-gray-700">Telecommunications Equipment</li>
                            <li class="body-medium text-gray-700">Medical & Healthcare Equipment</li>
                            <li class="body-medium text-gray-700">Technology & IT Infrastructure</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Process Section -->
        <section class="section-content">
            <div class="container-default">
                <h2 class="heading-secondary text-center mb-16">Professional Equipment Finance Process</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">1</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Equipment Assessment</h3>
                        <p class="body-medium">We evaluate your equipment needs, business capacity, and optimal financing structure aligned with your cash flow requirements.</p>
                    </div>
                    
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">2</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Strategic Structuring</h3>
                        <p class="body-medium">Our team structures the finance solution to maximize tax benefits and minimise business disruption during equipment acquisition.</p>
                    </div>
                    
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">3</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Lender Comparison</h3>
                        <p class="body-medium">We negotiate with multiple commercial lenders to secure competitive rates and terms specific to your industry and equipment type.</p>
                    </div>
                    
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">4</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Fast Settlement</h3>
                        <p class="body-medium">Professional management of documentation and settlement processes ensures you can deploy your equipment quickly and efficiently.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Benefits Section -->
        <section class="section-content bg-neutral-light">
            <div class="container-default">
                <h2 class="heading-secondary text-center mb-16">Why Commercial Trades Choose EVFBS Equipment Finance</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Industry Expertise</h3>
                        <p class="body-medium">Deep understanding of commercial trades, civil contracting, and industrial business requirements. We know your equipment and industry challenges.</p>
                    </div>
                    
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Flexible Terms</h3>
                        <p class="body-medium">Loan terms from 12-60 months with seasonal payment options and balloon payments available to match your business cash flow patterns.</p>
                    </div>
                    
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Competitive Rates</h3>
                        <p class="body-medium">Access to commercial finance rates typically 2-4% lower than consumer finance, with equipment security reducing your overall cost of capital.</p>
                    </div>
                    
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Tax Optimisation</h3>
                        <p class="body-medium">Strategic structuring to maximize depreciation benefits, and other tax advantages available to commercial businesses.</p>
                    </div>
                    
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Cash Flow Protection</h3>
                        <p class="body-medium">Preserve working capital for operations while acquiring essential equipment. Structured to maintain healthy cash flow during growth phases.</p>
                    </div>
                    
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Fast Approvals</h3>
                        <p class="body-medium">24-48 hour approval processes for established commercial businesses, enabling you to secure equipment quickly for time-sensitive projects.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Finance Options -->
        <section class="section-content">
            <div class="container-default">
                <h2 class="heading-secondary text-center mb-16">Equipment Finance Solutions Available</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <div class="service-card-consistent border-l-4 border-primary-orange">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Equipment Loan</h3>
                        <p class="body-medium mb-6">Traditional ownership model with equipment as security</p>
                        <ul class="space-y-2">
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">Loan amounts: $20K - $500K+</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">Terms: 12-60 months</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">Immediate ownership</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">Full depreciation benefits</span>
                            </li>
                        </ul>
                    </div>
                    
                    <div class="service-card-consistent border-l-4 border-secondary-dark">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Equipment Lease</h3>
                        <p class="body-medium mb-6">Operational lease with end-of-term options</p>
                        <ul class="space-y-2">
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">Lower monthly payments</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">100% tax deductible</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">Upgrade options available</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">Maintenance packages</span>
                            </li>
                        </ul>
                    </div>
                    
                    <div class="service-card-consistent border-l-4 border-primary-orange">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Hire Purchase</h3>
                        <p class="body-medium mb-6">Ownership transfer at completion</p>
                        <ul class="space-y-2">
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">Fixed monthly payments</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">Balloon payment options</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">GST and tax benefits</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="body-medium text-gray-700">Equipment ownership</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Call to Action -->
        <section class="section-cta hero-section">
            <div class="container-default">
                <div class="text-center">
                    <h2 class="heading-secondary text-white mb-6">Ready to Finance Your Next Equipment Purchase?</h2>
                    <p class="text-xl lg:text-2xl text-gray-100 mb-8 max-w-4xl mx-auto">Join hundreds of commercial trades and civil contractors who've secured strategic equipment finance through our professional service.</p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center button-gap mb-8">
                        <a href="/get-quote?service=equipment-finance" class="btn-primary btn-large">Get Equipment Finance Quote</a>
                        <a href="/contact" class="btn-secondary btn-large text-white border-white hover:bg-white hover:text-secondary-dark">Speak with Equipment Finance Specialist</a>
                    </div>
                    <div class="text-gray-100">
                        <p>Quick consultation available: <strong>1300 XXX XXX</strong> | Monday-Friday 8AM-6PM AEST</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Agency11Layout>