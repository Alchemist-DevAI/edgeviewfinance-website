        }
        
        .challenge-problem {
            background: #ffebee;
            border-left: 4px solid #e74c3c;
        }
        
        .challenge-solution {
            background: #e8f5e8;
            border-left: 4px solid #27ae60;
        }
        
        .challenge-problem h3 {
            color: #c62828;
            margin-bottom: 1rem;
        }
        
        .challenge-solution h3 {
            color: #2e7d32;
