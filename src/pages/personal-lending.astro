                <div class="hero-cta">
                    <a href="/get-quote?service=personal-lending" class="primary-button">Get Personal Loan Quote</a>
                    <a href="/loan-calculator" class="secondary-button">Loan Calculator</a>
                </div>
                <div class="trust-indicators">
                    <span>✓ Self-Employed Specialists</span>
                    <span>✓ Investment Property Experts</span>
                    <span>✓ Competitive Rates</span>
                </div>
            </div>
        </section>

        <!-- Lending Solutions Section -->
        <section class="lending-solutions">
            <div class="container">
                <h2>Personal Lending Solutions for Business Owners</h2>
                <div class="solutions-grid">
                    <div class="solution-card">
                        <div class="solution-icon">🏠</div>
                        <h3>Owner-Occupied Home Loans</h3>
                        <p>Competitive home loans designed for business owners and self-employed professionals</p>
                        <ul>
                            <li>First home buyer solutions</li>
                            <li>Upgrading to larger family homes</li>
                            <li>Refinancing existing home loans</li>
                            <li>Construction and land packages</li>
                            <li>Self-employed income verification</li>
                        </ul>
                        <div class="rate-info">
                            <strong>From 5.89% p.a.*</strong>
                        </div>
                    </div>
                    
                    <div class="solution-card">
                        <div class="solution-icon">🏘️</div>
                        <h3>Investment Property Finance</h3>
                        <p>Strategic investment property loans to build long-term wealth and passive income</p>
                        <ul>
                            <li>Residential investment properties</li>
                            <li>Multi-property portfolio finance</li>
                            <li>Rentvesting strategies</li>
                            <li>Positive and negative gearing</li>
                            <li>Cross-collateral arrangements</li>
                        </ul>
                        <div class="rate-info">
                            <strong>From 6.19% p.a.*</strong>
                        </div>
                    </div>
                    
                    <div class="solution-card">
                        <div class="solution-icon">🏗️</div>
                        <h3>Construction & Development</h3>
                        <p>Specialised finance for building your dream home or small-scale development projects</p>
                        <ul>
                            <li>House and land packages</li>
                            <li>Custom home construction</li>
                            <li>Renovation and extension projects</li>
                            <li>Knock-down rebuild finance</li>
                            <li>Progressive payment management</li>
                        </ul>
                        <div class="rate-info">
                            <strong>From 6.49% p.a.*</strong>
                        </div>
                    </div>
                    
                    <div class="solution-card">
                        <div class="solution-icon">🔄</div>
                        <h3>Refinancing & Restructuring</h3>
                        <p>Optimise existing loans and unlock equity for investment or business opportunities</p>
                        <ul>
                            <li>Rate and term improvements</li>
                            <li>Cash-out refinancing</li>
                            <li>Debt consolidation</li>
                            <li>Portfolio restructuring</li>
                            <li>Equity release strategies</li>
                        </ul>
                        <div class="rate-info">
                            <strong>Potential savings up to $50K+ annually</strong>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Self-Employed Challenges Section -->
        <section class="challenges-section">
            <div class="container">
                <h2>Overcoming Self-Employed Lending Challenges</h2>
                <div class="challenges-content">
                    <div class="challenge-problem">
                        <h3>Common Challenges Business Owners Face:</h3>
                        <ul class="challenge-list">
                            <li>❌ Variable income streams and seasonal fluctuations</li>
                            <li>❌ Complex tax returns with deductions reducing taxable income</li>
                            <li>❌ Limited PAYG employment history</li>
                            <li>❌ Business income not recognized by traditional lenders</li>
                            <li>❌ Longer processing times and documentation requirements</li>
                            <li>❌ Higher interest rates due to perceived risk</li>
                        </ul>
                    </div>
                    
                    <div class="challenge-solution">
                        <h3>Our Specialised Solutions:</h3>
                        <ul class="solution-list">
                            <li>✅ Alternative income verification methods</li>
                            <li>✅ BAS statements and business banking analysis</li>
                            <li>✅ Asset-based lending options</li>
                            <li>✅ Relationship with self-employed specialist lenders</li>
                            <li>✅ Streamlined documentation processes</li>
                            <li>✅ Competitive rates for business owners</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Documentation Solutions Section -->
        <section class="documentation-section">
            <div class="container">
                <h2>Flexible Documentation Options</h2>
                <div class="doc-options">
                    <div class="doc-option">
                        <h3>Full Documentation</h3>
                        <p><strong>Best Rates & Terms</strong></p>
                        <ul>
                            <li>2 years of tax returns</li>
                            <li>Financial statements (if company)</li>
                            <li>BAS statements</li>
                            <li>Bank statements (6-12 months)</li>
                            <li>Accountant verification letter</li>
                        </ul>
                        <div class="doc-benefit">Lowest rates - from 5.89% p.a.*</div>
                    </div>
                    
                    <div class="doc-option">
                        <h3>Alternative Documentation</h3>
                        <p><strong>Streamlined Process</strong></p>
                        <ul>
                            <li>12 months bank statements</li>
                            <li>BAS statements or business activity</li>
                            <li>ABN registration details</li>
                            <li>Accountant letter</li>
                            <li>Asset verification</li>
                        </ul>
                        <div class="doc-benefit">Competitive rates - from 6.29% p.a.*</div>
                    </div>
                    
                    <div class="doc-option">
                        <h3>Low Documentation</h3>
                        <p><strong>Simplified Verification</strong></p>
                        <ul>
                            <li>Income declaration</li>
                            <li>Business registration proof</li>
                            <li>Asset and liability statement</li>
                            <li>Minimal bank statements</li>
                            <li>Property as primary security</li>
                        </ul>
                        <div class="doc-benefit">Fast approval - from 6.89% p.a.*</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Investment Strategy Section -->
        <section class="strategy-section">
            <div class="container">
                <h2>Investment Property Strategies for Business Owners</h2>
                <div class="strategy-grid">
                    <div class="strategy">
                        <h3>Negative Gearing Strategy</h3>
                        <p>Use rental losses to reduce taxable income while building long-term capital growth.</p>
                        <div class="strategy-example">
                            <strong>Example:</strong> $800K property, 80% LVR, $500/week rent
                            <br><em>Annual tax benefit: $8,000 - $15,000</em>
                        </div>
                    </div>
                    
                    <div class="strategy">
                        <h3>Positive Cash Flow</h3>
                        <p>Generate immediate rental income to supplement business cash flow and lifestyle.</p>
                        <div class="strategy-example">
                            <strong>Example:</strong> $450K regional property, 80% LVR, $420/week rent
                            <br><em>Annual cash flow: $2,000 - $6,000 positive</em>
                        </div>
                    </div>
                    
                    <div class="strategy">
                        <h3>Portfolio Building</h3>
                        <p>Use equity from existing properties to acquire additional investment properties.</p>
                        <div class="strategy-example">
                            <strong>Example:</strong> Use $200K equity from home to purchase 2 properties
                            <br><em>Total portfolio value: $1.5M+ with diversified income</em>
                        </div>
                    </div>
                    
                    <div class="strategy">
                        <h3>SMSF Property Investment</h3>
                        <p>Purchase investment properties within your Self-Managed Super Fund for tax advantages.</p>
                        <div class="strategy-example">
                            <strong>Example:</strong> $600K property in SMSF with limited recourse loan
                            <br><em>Tax rate: 15% in accumulation, 0% in pension phase</em>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Process Section -->
        <section class="process-section">
            <div class="container">
                <h2>Our Personal Lending Process</h2>
                <div class="process-steps">
                    <div class="step">
                        <div class="step-number">1</div>
                        <h3>Personal Consultation</h3>
                        <p>Comprehensive discussion of your personal property goals, business situation, and financial capacity to determine optimal lending strategy.</p>
                    </div>
                    
                    <div class="step">
                        <div class="step-number">2</div>
                        <h3>Pre-Approval Strategy</h3>
                        <p>Secure pre-approval with appropriate lending capacity, giving you confidence to negotiate and purchase with competitive terms.</p>
                    </div>
                    
                    <div class="step">
                        <div class="step-number">3</div>
                        <h3>Property & Documentation</h3>
                        <p>Professional guidance through property selection, valuation process, and streamlined documentation management.</p>
                    </div>
                    
                    <div class="step">
                        <div class="step-number">4</div>
                        <h3>Settlement & Ongoing</h3>
                        <p>Seamless settlement process and ongoing relationship management for refinancing and portfolio growth opportunities.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Benefits Section -->
        <section class="benefits-section">
            <div class="container">
                <h2>Why Business Owners Choose EVFBS for Personal Lending</h2>
                <div class="benefits-grid">
                    <div class="benefit">
                        <h3>Self-Employed Expertise</h3>
                        <p>Deep understanding of business owner challenges and specialised lender relationships that cater specifically to self-employed income verification.</p>
                    </div>
                    
                    <div class="benefit">
                        <h3>Holistic Financial Strategy</h3>
                        <p>Integration of personal and business finance strategies to optimize tax benefits, cash flow, and long-term wealth creation goals.</p>
                    </div>
                    
                    <div class="benefit">
                        <h3>Competitive Rates Access</h3>
                        <p>Access to wholesale lending rates and specialised self-employed products not available directly to consumers through major banks.</p>
                    </div>
                    
                    <div class="benefit">
                        <h3>Investment Strategy Guidance</h3>
                        <p>Professional investment property advice including location analysis, rental yield assessment, and portfolio structuring for optimal returns.</p>
                    </div>
                    
                    <div class="benefit">
                        <h3>Ongoing Relationship</h3>
                        <p>Continuous support for refinancing opportunities, portfolio expansion, and changing personal circumstances throughout your property journey.</p>
                    </div>
                    
                    <div class="benefit">
                        <h3>Comprehensive Solutions</h3>
                        <p>One-stop solution covering home loans, investment property, construction finance, and business lending requirements.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Lender Panel Section -->
        <section class="lender-panel">
            <div class="container">
                <h2>Extensive Lender Panel for Best Outcomes</h2>
                <div class="panel-categories">
                    <div class="panel-category">
                        <h3>Major Banks</h3>
                        <p>Competitive rates for strong applicants with traditional income verification</p>
                    </div>
                    
                    <div class="panel-category">
                        <h3>Self-Employed Specialists</h3>
                        <p>Lenders who understand and cater specifically to business owner income structures</p>
                    </div>
                    
                    <div class="panel-category">
                        <h3>Non-Bank Lenders</h3>
                        <p>Alternative lenders offering flexible terms and faster approval processes</p>
                    </div>
                    
                    <div class="panel-category">
                        <h3>Investment Specialists</h3>
                        <p>Lenders focused on investment property finance with competitive investor rates</p>
                    </div>
                </div>
                <p class="panel-note">Our extensive panel ensures we find the right lender match for your specific situation and goals.</p>
            </div>
        </section>

        <!-- Call to Action -->
        <section class="cta-section">
            <div class="container">
                <h2>Ready to Secure Your Personal Property Goals?</h2>
                <p>Join successful business owners who've achieved their property dreams through our specialised self-employed lending solutions and expert guidance.</p>
                <div class="cta-buttons">
                    <a href="/get-quote?service=personal-lending" class="primary-button large">Get Personal Loan Quote</a>
                    <a href="/contact" class="secondary-button large">Speak with Lending Specialist</a>
                </div>
                <div class="contact-info">
                    <p>Personal consultation available: <strong>1300 XXX XXX</strong> | Monday-Friday 8AM-6PM AEST</p>
                </div>
                <div class="disclaimer">
                    <p><small>*Rates quoted are indicative and subject to individual assessment. Fees and charges apply. Credit criteria apply.</small></p>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h4>Personal Lending</h4>
                    <ul>
                        <li><a href="/home-loans">Home Loans</a></li>
