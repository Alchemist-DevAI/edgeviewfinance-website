---
// Personal Lending Page - Personal Home & Investment Property Finance
// Supporting business owners' personal property goals
export const prerender = true;

const siteData = {
  title: "Personal Home & Investment Property Finance | EVFBS Australia",
  description: "Personal home loans and investment property finance for business owners, trades, and contractors. Competitive rates with self-employed income solutions from $200K to $5M+.",
  keywords: "personal home loans Australia, investment property finance, self-employed home loans, business owner mortgages, contractor home loans, SMSF property loans"
};
---

<html lang="en-AU">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteData.description} />
    <meta name="keywords" content={siteData.keywords} />
    
    <!-- Personal Lending Service Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "@id": "https://edgeviewfinance.com.au/personal-lending",
      "name": "Personal Home & Investment Lending",
      "alternateName": "Personal Property Finance",
      "description": "Personal home loans and investment property finance for business owners, trades, and contractors with specialised self-employed solutions",
      "serviceType": "Personal Lending",
      "provider": {
        "@type": "FinancialService",
        "@id": "https://edgeviewfinance.com.au/#organization",
        "name": "Edgeview Finance Business Solutions",
        "areaServed": {
          "@type": "Country",
          "name": "Australia"
        }
      },
      "offers": {
        "@type": "Offer",
        "name": "Personal Lending Solutions",
        "description": "Competitive personal home loans and investment property finance from $200K to $5M+ for business owners",
        "itemOffered": {
          "@type": "Service",
          "name": "Personal Lending",
          "category": "Personal Finance"
        }
      },
      "audience": {
        "@type": "BusinessAudience",
        "businessType": ["Business Owners", "Self-Employed", "Contractors"]
      }
    }
    </script>
    
    <title>{siteData.title}</title>
</head>
<body>
    <header>
        <nav>
            <div class="nav-container">
                <div class="logo">
                    <h1>Edgeview Finance</h1>
                    <span>Business Solutions</span>
                </div>
                <ul class="nav-menu">
                    <li><a href="/">Home</a></li>
                    <li><a href="/services">Services</a></li>
                    <li><a href="/commercial-property">Commercial Property</a></li>
                    <li><a href="/personal-lending" class="active">Personal Lending</a></li>
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact" class="cta-button">Expert Consultation</a></li>
                </ul>
            </div>
        </nav>
