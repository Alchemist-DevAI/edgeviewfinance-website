---
import Agency11Layout from '../layouts/Agency11Layout.astro';

const pageTitle = 'Personal Home & Investment Property Finance | EVFBS Australia';
const pageDescription = 'Personal home loans and investment property finance for business owners, trades, and contractors. Competitive rates with self-employed income solutions from $200K to $5M+.';
    
const lendingSolutions = [
  {
    icon: "🏠",
    title: "Owner-Occupied Home Loans",
    description: "Competitive home loans designed for business owners and self-employed professionals",
    features: [
      "First home buyer solutions",
      "Upgrading to larger family homes",
      "Refinancing existing home loans",
      "Construction and land packages",
      "Self-employed income verification"
    ],
    rate: "From 5.89% p.a.*"
  },
  {
    icon: "🏘️",
    title: "Investment Property Finance",
    description: "Strategic investment property loans to build long-term wealth and passive income",
    features: [
      "Residential investment properties",
      "Multi-property portfolio finance",
      "Rentvesting strategies",
      "Positive and negative gearing",
      "Cross-collateral arrangements"
    ],
    rate: "From 6.19% p.a.*"
  },
  {
    icon: "🏗️",
    title: "Construction & Development",
    description: "Specialised finance for building your dream home or small-scale development projects",
    features: [
      "House and land packages",
      "Custom home construction",
      "Renovation and extension projects",
      "Knock-down rebuild finance",
      "Progressive payment management"
    ],
    rate: "From 6.49% p.a.*"
  },
  {
    icon: "🔄",
    title: "Refinancing & Restructuring",
    description: "Optimise existing loans and unlock equity for investment or business opportunities",
    features: [
      "Rate and term improvements",
      "Cash-out refinancing",
      "Debt consolidation",
      "Portfolio restructuring",
      "Equity release strategies"
    ],
    rate: "Potential savings up to $50K+ annually"
  }
];

const documentationOptions = [
  {
    type: "Full Documentation",
    subtitle: "Best Rates & Terms",
    requirements: [
      "2 years of tax returns",
      "Financial statements (if company)",
      "BAS statements",
      "Bank statements (6-12 months)",
      "Accountant verification letter"
    ],
    benefit: "Lowest rates - from 5.89% p.a.*"
  },
  {
    type: "Alternative Documentation",
    subtitle: "Streamlined Process",
    requirements: [
      "12 months bank statements",
      "BAS statements or business activity",
      "ABN registration details",
      "Accountant letter",
      "Asset verification"
    ],
    benefit: "Competitive rates - from 6.29% p.a.*"
  },
  {
    type: "Low Documentation",
    subtitle: "Simplified Verification",
    requirements: [
      "Income declaration",
      "Business registration proof",
      "Asset and liability statement",
      "Minimal bank statements",
      "Property as primary security"
    ],
    benefit: "Fast approval - from 6.89% p.a.*"
  }
];

const investmentStrategies = [
  {
    title: "Negative Gearing Strategy",
    description: "Use rental losses to reduce taxable income while building long-term capital growth.",
    example: "$800K property, 80% LVR, $500/week rent",
    benefit: "Annual tax benefit: $8,000 - $15,000"
  },
  {
    title: "Positive Cash Flow",
    description: "Generate immediate rental income to supplement business cash flow and lifestyle.",
    example: "$450K regional property, 80% LVR, $420/week rent",
    benefit: "Annual cash flow: $2,000 - $6,000 positive"
  },
  {
    title: "Portfolio Building",
    description: "Use equity from existing properties to acquire additional investment properties.",
    example: "Use $200K equity from home to purchase 2 properties",
    benefit: "Total portfolio value: $1.5M+ with diversified income"
  },
  {
    title: "SMSF Property Investment",
    description: "Purchase investment properties within your Self-Managed Super Fund for tax advantages.",
    example: "$600K property in SMSF with limited recourse loan",
    benefit: "Tax rate: 15% in accumulation, 0% in pension phase"
  }
];
---

<Agency11Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="section-hero bg-gradient-to-br from-brand-primary to-brand-primary-dark text-white">
    <div class="container-default">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="heading-primary text-white mb-6">
          Personal Home & Investment Property Finance
        </h1>
        <p class="body-large text-brand-grey-100 mb-8">
          Specialised personal lending solutions from $200K to $5M+ for business owners, trades, and contractors. 
          Self-employed income solutions with competitive rates and expert guidance.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
          <a href="/get-quote?service=personal-lending" class="btn-primary btn-large">
            Get Personal Loan Quote
          </a>
          <a href="/calculator" class="btn-secondary btn-large border-white text-white hover:bg-white hover:text-brand-primary">
            Loan Calculator
          </a>
        </div>
        <div class="flex flex-wrap justify-center gap-6 text-sm text-brand-grey-200">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Self-Employed Specialists
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Investment Property Experts
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Competitive Rates
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Lending Solutions Section -->
  <section class="section-content bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-12">
        <h2 class="heading-secondary text-brand-primary mb-4">
          Personal Lending Solutions for Business Owners
        </h2>
        <p class="body-large text-brand-grey-700 max-w-3xl mx-auto">
          Comprehensive finance options tailored to your personal property goals
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {lendingSolutions.map((solution) => (
          <div class="bg-white rounded-xl p-8 shadow-soft hover:shadow-medium transition-all duration-300">
            <div class="text-4xl mb-4">{solution.icon}</div>
            <h3 class="heading-tertiary text-brand-primary mb-3">{solution.title}</h3>
            <p class="text-brand-grey-700 mb-4">{solution.description}</p>
            <ul class="space-y-2 mb-6">
              {solution.features.map((feature) => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-brand-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-brand-grey-700">{feature}</span>
                </li>
              ))}
            </ul>
            <div class="bg-brand-accent-light text-brand-accent font-semibold px-4 py-3 rounded-lg text-center">
              {solution.rate}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Self-Employed Challenges Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-12">
        <h2 class="heading-secondary text-brand-primary mb-4">
          Overcoming Self-Employed Lending Challenges
        </h2>
        <p class="body-large text-brand-grey-700 max-w-3xl mx-auto">
          Expert solutions for the unique challenges business owners face
        </p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-red-50 rounded-xl p-8 border-l-4 border-red-500">
          <h3 class="heading-tertiary text-red-700 mb-6">Common Challenges Business Owners Face:</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-red-500 text-xl mt-0.5">❌</span>
              <span class="text-brand-grey-700">Variable income streams and seasonal fluctuations</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-500 text-xl mt-0.5">❌</span>
              <span class="text-brand-grey-700">Complex tax returns with deductions reducing taxable income</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-500 text-xl mt-0.5">❌</span>
              <span class="text-brand-grey-700">Limited PAYG employment history</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-500 text-xl mt-0.5">❌</span>
              <span class="text-brand-grey-700">Business income not recognized by traditional lenders</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-500 text-xl mt-0.5">❌</span>
              <span class="text-brand-grey-700">Longer processing times and documentation requirements</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-500 text-xl mt-0.5">❌</span>
              <span class="text-brand-grey-700">Higher interest rates due to perceived risk</span>
            </li>
          </ul>
        </div>
        
        <div class="bg-green-50 rounded-xl p-8 border-l-4 border-green-500">
          <h3 class="heading-tertiary text-green-700 mb-6">Our Specialised Solutions:</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-green-500 text-xl mt-0.5">✅</span>
              <span class="text-brand-grey-700">Alternative income verification methods</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 text-xl mt-0.5">✅</span>
              <span class="text-brand-grey-700">BAS statements and business banking analysis</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 text-xl mt-0.5">✅</span>
              <span class="text-brand-grey-700">Asset-based lending options</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 text-xl mt-0.5">✅</span>
              <span class="text-brand-grey-700">Relationship with self-employed specialist lenders</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 text-xl mt-0.5">✅</span>
              <span class="text-brand-grey-700">Streamlined documentation processes</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 text-xl mt-0.5">✅</span>
              <span class="text-brand-grey-700">Competitive rates for business owners</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Documentation Solutions Section -->
  <section class="section-content bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-12">
        <h2 class="heading-secondary text-brand-primary mb-4">
          Flexible Documentation Options
        </h2>
        <p class="body-large text-brand-grey-700 max-w-3xl mx-auto">
          Multiple pathways to approval based on your documentation availability
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {documentationOptions.map((option) => (
          <div class="bg-white rounded-xl p-6 shadow-soft hover:shadow-medium transition-all duration-300">
            <h3 class="heading-tertiary text-brand-primary mb-2">{option.type}</h3>
            <p class="text-brand-accent font-semibold mb-4">{option.subtitle}</p>
            <ul class="space-y-2 mb-6">
              {option.requirements.map((req) => (
                <li class="text-brand-grey-700 text-sm pl-4 relative before:content-['•'] before:absolute before:left-0 before:text-brand-primary">
                  {req}
                </li>
              ))}
            </ul>
            <div class="bg-brand-accent-light text-brand-accent font-semibold px-4 py-3 rounded-lg text-center text-sm">
              {option.benefit}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Investment Strategy Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-12">
        <h2 class="heading-secondary text-brand-primary mb-4">
          Investment Property Strategies for Business Owners
        </h2>
        <p class="body-large text-brand-grey-700 max-w-3xl mx-auto">
          Proven strategies to build wealth through strategic property investment
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {investmentStrategies.map((strategy) => (
          <div class="bg-white rounded-xl p-6 shadow-soft hover:shadow-medium transition-all duration-300 border-t-4 border-brand-accent">
            <h3 class="heading-tertiary text-brand-primary mb-3">{strategy.title}</h3>
            <p class="text-brand-grey-700 mb-4">{strategy.description}</p>
            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
              <p class="text-sm text-brand-grey-800 mb-2">
                <strong>Example:</strong> {strategy.example}
              </p>
              <p class="text-sm text-brand-accent font-semibold">
                {strategy.benefit}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="section-content bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-12">
        <h2 class="heading-secondary text-brand-primary mb-4">
          Our Personal Lending Process
        </h2>
        <p class="body-large text-brand-grey-700 max-w-3xl mx-auto">
          A streamlined approach to securing your personal property finance
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-brand-accent text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
            1
          </div>
          <h3 class="heading-tertiary text-brand-primary mb-3">Personal Consultation</h3>
          <p class="text-brand-grey-700">
            Comprehensive discussion of your personal property goals, business situation, and financial capacity to determine optimal lending strategy.
          </p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-brand-accent text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
            2
          </div>
          <h3 class="heading-tertiary text-brand-primary mb-3">Pre-Approval Strategy</h3>
          <p class="text-brand-grey-700">
            Secure pre-approval with appropriate lending capacity, giving you confidence to negotiate and purchase with competitive terms.
          </p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-brand-accent text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
            3
          </div>
          <h3 class="heading-tertiary text-brand-primary mb-3">Property & Documentation</h3>
          <p class="text-brand-grey-700">
            Professional guidance through property selection, valuation process, and streamlined documentation management.
          </p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-brand-accent text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
            4
          </div>
          <h3 class="heading-tertiary text-brand-primary mb-3">Settlement & Ongoing</h3>
          <p class="text-brand-grey-700">
            Seamless settlement process and ongoing relationship management for refinancing and portfolio growth opportunities.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="text-center mb-12">
        <h2 class="heading-secondary text-brand-primary mb-4">
          Why Business Owners Choose EVFBS for Personal Lending
        </h2>
        <p class="body-large text-brand-grey-700 max-w-3xl mx-auto">
          Expertise and advantages that make the difference for self-employed professionals
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-soft hover:shadow-medium transition-all duration-300">
          <h3 class="heading-tertiary text-brand-accent mb-3">Self-Employed Expertise</h3>
          <p class="text-brand-grey-700">
            Deep understanding of business owner challenges and specialised lender relationships that cater specifically to self-employed income verification.
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 shadow-soft hover:shadow-medium transition-all duration-300">
          <h3 class="heading-tertiary text-brand-accent mb-3">Holistic Financial Strategy</h3>
          <p class="text-brand-grey-700">
            Integration of personal and business finance strategies to optimize tax benefits, cash flow, and long-term wealth creation goals.
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 shadow-soft hover:shadow-medium transition-all duration-300">
          <h3 class="heading-tertiary text-brand-accent mb-3">Competitive Rates Access</h3>
          <p class="text-brand-grey-700">
            Access to wholesale lending rates and specialised self-employed products not available directly to consumers through major banks.
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 shadow-soft hover:shadow-medium transition-all duration-300">
          <h3 class="heading-tertiary text-brand-accent mb-3">Investment Strategy Guidance</h3>
          <p class="text-brand-grey-700">
            Professional investment property advice including location analysis, rental yield assessment, and portfolio structuring for optimal returns.
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 shadow-soft hover:shadow-medium transition-all duration-300">
          <h3 class="heading-tertiary text-brand-accent mb-3">Ongoing Relationship</h3>
          <p class="text-brand-grey-700">
            Continuous support for refinancing opportunities, portfolio expansion, and changing personal circumstances throughout your property journey.
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 shadow-soft hover:shadow-medium transition-all duration-300">
          <h3 class="heading-tertiary text-brand-accent mb-3">Comprehensive Solutions</h3>
          <p class="text-brand-grey-700">
            One-stop solution covering home loans, investment property, construction finance, and business lending requirements.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Lender Panel Section -->
  <section class="section-content bg-brand-grey-50">
    <div class="container-default">
      <div class="text-center mb-12">
        <h2 class="heading-secondary text-brand-primary mb-4">
          Extensive Lender Panel for Best Outcomes
        </h2>
        <p class="body-large text-brand-grey-700 max-w-3xl mx-auto">
          Access to 40+ lenders ensures we find the perfect match for your unique situation
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-xl p-6 text-center shadow-soft">
          <h3 class="heading-tertiary text-brand-primary mb-3">Major Banks</h3>
          <p class="text-brand-grey-700">
            Competitive rates for strong applicants with traditional income verification
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 text-center shadow-soft">
          <h3 class="heading-tertiary text-brand-primary mb-3">Self-Employed Specialists</h3>
          <p class="text-brand-grey-700">
            Lenders who understand and cater specifically to business owner income structures
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 text-center shadow-soft">
          <h3 class="heading-tertiary text-brand-primary mb-3">Non-Bank Lenders</h3>
          <p class="text-brand-grey-700">
            Alternative lenders offering flexible terms and faster approval processes
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 text-center shadow-soft">
          <h3 class="heading-tertiary text-brand-primary mb-3">Investment Specialists</h3>
          <p class="text-brand-grey-700">
            Lenders focused on investment property finance with competitive investor rates
          </p>
        </div>
      </div>
      
      <p class="text-center text-brand-grey-700 italic">
        Our extensive panel ensures we find the right lender match for your specific situation and goals.
      </p>
    </div>
  </section>

  <!-- Call to Action Section -->
  <section class="bg-gradient-to-br from-brand-accent to-brand-primary">
    <div class="container-default py-16">
      <div class="text-center text-white">
        <h2 class="heading-secondary text-white mb-4">
          Ready to Secure Your Personal Property Goals?
        </h2>
        <p class="body-large text-brand-grey-100 mb-8 max-w-3xl mx-auto">
          Join successful business owners who've achieved their property dreams through our specialised 
          self-employed lending solutions and expert guidance.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
          <a href="/get-quote?service=personal-lending" class="btn-primary btn-large bg-white text-brand-primary hover:bg-brand-grey-50">
            Get Personal Loan Quote
          </a>
          <a href="/contact" class="btn-secondary btn-large border-white text-white hover:bg-white hover:text-brand-primary">
            Speak with Lending Specialist
          </a>
        </div>
        <p class="text-brand-grey-100">
          Personal consultation available: <strong class="text-white">1300 XXX XXX</strong> | Monday-Friday 8AM-6PM AEST
        </p>
        <p class="text-sm text-brand-grey-200 mt-4">
          *Rates quoted are indicative and subject to individual assessment. Fees and charges apply. Credit criteria apply.
        </p>
      </div>
    </div>
  </section>

</Agency11Layout>