        }
        
        .doc-option h3 {
            color: #34495e;
            margin-bottom: 0.5rem;
        }
        
        .doc-option p {
            color: #e67e22;
            font-weight: bold;
            margin-bottom: 1rem;
        }
        
        .doc-option ul {
            list-style: none;
            margin-bottom: 1rem;
        }
        
        .doc-option li {
            padding: 0.3rem 0;
            padding-left: 1rem;
            position: relative;
        }
        
        .doc-option li:before {
            content: "•";
            color: #34495e;
            font-weight: bold;
            position: absolute;
            left: 0;
        }
        
        .doc-benefit {
            background: #e8f5e8;
            color: #27ae60;
            padding: 0.8rem;
            border-radius: 5px;
            font-weight: bold;
            text-align: center;
        }
        
        /* Strategy Section */
        .strategy-section {
            padding: 80px 20px;
        }
        
        .strategy-section h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 3rem;
            color: #34495e;
        }
        
        .strategy-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }
        
        .strategy {
            background: #f8f9fa;
            padding: 2rem;
            border-radius: 10px;
            border-top: 4px solid #34495e;
        }
        
        .strategy h3 {
            color: #34495e;
            margin-bottom: 1rem;
        }
        
        .strategy-example {
            background: #fff3cd;
            padding: 1rem;
            border-radius: 5px;
            margin-top: 1rem;
            font-size: 0.9rem;
        }
        
        /* Process Section */
        .process-section {
            padding: 80px 20px;
            background: #f8f9fa;
        }
        
        .process-section h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 3rem;
            color: #34495e;
        }
        
        .process-steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }
        
        .step {
            text-align: center;
            padding: 2rem;
        }
        
        .step-number {
            background: #e67e22;
            color: white;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: bold;
            margin: 0 auto 1rem;
        }
        
        .step h3 {
            color: #34495e;
            margin-bottom: 1rem;
        }
        
        /* Benefits Section */
        .benefits-section {
            padding: 80px 20px;
        }
        
        .benefits-section h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 3rem;
            color: #34495e;
        }
        
        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }
        
        .benefit {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .benefit h3 {
            color: #e67e22;
            margin-bottom: 1rem;
        }
        
        /* Lender Panel */
        .lender-panel {
            padding: 80px 20px;
            background: #f8f9fa;
        }
        
        .lender-panel h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 3rem;
            color: #34495e;
        }
        
        .panel-categories {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }
        
        .panel-category {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .panel-category h3 {
            color: #34495e;
            margin-bottom: 1rem;
        }
        
        .panel-note {
            text-align: center;
            font-style: italic;
            color: #666;
            font-size: 1.1rem;
        }
        
        /* CTA Section */
        .cta-section {
            background: #34495e;
            color: white;
            padding: 80px 20px;
            text-align: center;
        }
        
        .cta-section h2 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        
        .cta-section p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
        }
        
        .cta-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 2rem;
        }
        
        .large {
            font-size: 1.2rem;
            padding: 18px 36px;
        }
        
        .contact-info {
            font-size: 1.1rem;
            opacity: 0.9;
            margin-bottom: 2rem;
        }
        
        .disclaimer {
            opacity: 0.8;
            font-size: 0.9rem;
        }
        
        /* Footer */
        footer {
            background: #333;
            color: white;
            padding: 40px 20px 20px;
        }
        
        .footer-content {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }
        
        .footer-section h4 {
            color: #e67e22;
            margin-bottom: 1rem;
        }
        
        .footer-section ul {
            list-style: none;
        }
        
        .footer-section a {
            color: #ccc;
            text-decoration: none;
            transition: color 0.3s;
        }
        
        .footer-section a:hover {
            color: white;
        }
        
        .footer-bottom {
            border-top: 1px solid #555;
            padding-top: 1rem;
            text-align: center;
            color: #ccc;
        }
        
        /* Responsive Design */
        @media (max-width: 768px) {
            .service-hero h1 {
                font-size: 2rem;
            }
            
            .hero-subtitle {
                font-size: 1.1rem;
            }
            
            .nav-menu {
                display: none;
            }
            
            .challenges-content {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            
            .solutions-grid,
            .doc-options,
            .strategy-grid,
            .process-steps,
            .benefits-grid,
            .panel-categories {
                grid-template-columns: 1fr;
            }
            
            .trust-indicators {
                flex-direction: column;
                gap: 1rem;
            }
            
            .cta-buttons {
                flex-direction: column;
                align-items: center;
            }
        }
    </style>
