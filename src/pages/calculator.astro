---
// Loan Calculator Page - Professional Financial Calculations for Australian Commercial Finance
// Multiple calculator types with GST considerations and educational content
import Agency11Layout from '../layouts/Agency11Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const siteData = {
  title: "Loan Calculator | Australian Commercial Finance Calculator | EVFBS",
  description: "Professional loan calculator suite for Australian commercial finance. Calculate equipment finance, commercial property, working capital, invoice financing, and compare options. GST considerations included. Instant results with professional assessment.",
  keywords: "loan calculator Australia, commercial finance calculator, equipment finance calculator, business loan calculator, repayment calculator, commercial property finance calculator, invoice financing calculator, finance comparison calculator"
};
---

<Agency11Layout title={siteData.title} description={siteData.description} keywords={siteData.keywords}>
  <!-- Calculator Tool Schema -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "@id": "https://edgeviewfinance.com.au/calculator",
    "name": "Commercial Finance Calculator",
    "description": "Professional loan calculator for Australian commercial finance including equipment finance, commercial property, and working capital solutions",
    "url": "https://edgeviewfinance.com.au/calculator",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web Browser",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "AUD"
    },
    "provider": {
      "@type": "FinancialService",
      "@id": "https://edgeviewfinance.com.au/#organization",
      "name": "Edgeview Finance Business Solutions"
    },
    "featureList": [
      "Equipment Finance Calculator",
      "Commercial Property Calculator", 
      "Working Capital Calculator",
      "Invoice Financing Calculator",
      "Finance Comparison Calculator",
      "GST Inclusive Calculations",
      "Australian Tax Considerations"
    ]
  }
  </script>
  
  <!-- Open Graph for Social Sharing -->
  <meta property="og:title" content={siteData.title} slot="head" />
  <meta property="og:description" content={siteData.description} slot="head" />
  <meta property="og:type" content="website" slot="head" />
  <meta property="og:url" content="https://edgeviewfinance.com.au/calculator" slot="head" />
  <meta property="og:locale" content="en_AU" slot="head" />

  <Header />

    <main>
        <!-- Hero Section -->
        <section class="section-hero hero-section">
            <div class="container-default">
                <div class="text-center">
                    <h1 class="heading-primary text-white mb-6">Professional Loan Calculator</h1>
                    <p class="hero-subtitle text-xl lg:text-2xl font-light mb-8 text-gray-100 max-w-4xl mx-auto">
                        Calculate your commercial finance repayments with our professional calculator suite. Get instant estimates for equipment finance, commercial property, and working capital solutions with Australian tax considerations.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center flex-wrap text-gray-100 mb-8">
                        <span class="flex items-center gap-2">✓ Australian Financial Calculations</span>
                        <span class="flex items-center gap-2">✓ GST Inclusive Options</span>
                        <span class="flex items-center gap-2">✓ Professional Assessment Available</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Calculator Interface -->
        <section class="section-content bg-neutral-light">
            <div class="container-default">
                <div class="service-card-consistent">
                    <!-- Calculator Type Selection -->
                    <div class="flex flex-wrap border-b-2 border-neutral-light mb-8 gap-0">
                        <button class="tab-button flex-1 bg-none border-none card-padding-sm text-base font-semibold text-gray-600 cursor-pointer border-b-3 border-transparent transition-all duration-300 hover:bg-gray-50 active" data-calculator="equipment">Equipment Finance</button>
                        <button class="tab-button flex-1 bg-none border-none card-padding-sm text-base font-semibold text-gray-600 cursor-pointer border-b-3 border-transparent transition-all duration-300 hover:bg-gray-50" data-calculator="property">Commercial Property</button>
                        <button class="tab-button flex-1 bg-none border-none card-padding-sm text-base font-semibold text-gray-600 cursor-pointer border-b-3 border-transparent transition-all duration-300 hover:bg-gray-50" data-calculator="working-capital">Working Capital</button>
                        <button class="tab-button flex-1 bg-none border-none card-padding-sm text-base font-semibold text-gray-600 cursor-pointer border-b-3 border-transparent transition-all duration-300 hover:bg-gray-50" data-calculator="invoice">Invoice Financing</button>
                        <button class="tab-button flex-1 bg-none border-none card-padding-sm text-base font-semibold text-gray-600 cursor-pointer border-b-3 border-transparent transition-all duration-300 hover:bg-gray-50" data-calculator="comparison">Compare Options</button>
                    </div>

                    <!-- Equipment Finance Calculator -->
                    <div id="equipment-calculator" class="calculator-form active">
                        <h2 class="heading-tertiary text-secondary-dark mb-4">Equipment Finance Calculator</h2>
                        <p class="body-medium text-gray-700 mb-8">Calculate repayments for commercial equipment, vehicles, and machinery financing.</p>
                        
                        <form class="calc-form mb-8">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                                <div class="flex flex-col">
                                    <label for="eq-amount" class="form-label">Equipment Value (AUD)</label>
                                    <input type="number" id="eq-amount" min="10000" max="5000000" step="1000" value="100000" required class="form-input">
                                    <small class="text-xs text-gray-500 mt-1">Minimum $10,000 - Maximum $5,000,000</small>
                                </div>
                                <div class="flex flex-col">
                                    <label for="eq-gst" class="form-label">Include GST?</label>
                                    <select id="eq-gst" class="form-input">
                                        <option value="true">Yes - GST Inclusive</option>
                                        <option value="false">No - GST Exclusive</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                                <div class="flex flex-col">
                                    <label for="eq-term" class="form-label">Loan Term</label>
                                    <select id="eq-term" class="form-input">
                                        <option value="12">1 Year</option>
                                        <option value="24">2 Years</option>
                                        <option value="36" selected>3 Years</option>
                                        <option value="48">4 Years</option>
                                        <option value="60">5 Years</option>
                                        <option value="84">7 Years</option>
                                    </select>
                                </div>
                                <div class="flex flex-col">
                                    <label for="eq-rate" class="form-label">Estimated Interest Rate (%)</label>
                                    <input type="number" id="eq-rate" min="3" max="25" step="0.1" value="8.5" required class="form-input">
                                    <small class="text-xs text-gray-500 mt-1">Indicative rate - actual rates vary by application</small>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                                <div class="flex flex-col">
                                    <label for="eq-deposit" class="form-label">Deposit Amount (AUD)</label>
                                    <input type="number" id="eq-deposit" min="0" step="1000" value="20000" class="form-input">
                                    <small class="text-xs text-gray-500 mt-1">Optional - reduces loan amount</small>
                                </div>
                                <div class="flex flex-col">
                                    <label for="eq-balloon" class="form-label">Balloon Payment (%)</label>
                                    <select id="eq-balloon" class="form-input">
                                        <option value="0" selected>No Balloon Payment</option>
                                        <option value="10">10% Balloon</option>
                                        <option value="20">20% Balloon</option>
                                        <option value="30">30% Balloon</option>
                                    </select>
                                </div>
                            </div>

                            <button type="button" class="btn-primary btn-large w-full" onclick="calculateEquipment()">Calculate Repayments</button>
                        </form>
                    </div>

                    <!-- Commercial Property Calculator -->
                    <div id="property-calculator" class="calculator-form">
                        <h2>Commercial Property Calculator</h2>
                        <p class="calculator-description">Calculate repayments for commercial property purchase or investment financing.</p>
                        
                        <form class="calc-form">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col">
                                    <label for="prop-value" class="form-label">Property Value (AUD)</label>
                                    <input type="number" id="prop-value" min="100000" max="20000000" step="10000" value="800000" required class="form-input">
                                    <small class="text-gray-600 text-sm mt-1">Minimum $100,000 - Maximum $20,000,000</small>
                                </div>
                                <div class="flex flex-col">
                                    <label for="prop-lvr" class="form-label">Loan to Value Ratio (%)</label>
                                    <select id="prop-lvr" class="form-input">
                                        <option value="60">60% LVR</option>
                                        <option value="70" selected>70% LVR</option>
                                        <option value="80">80% LVR</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col">
                                    <label for="prop-term" class="form-label">Loan Term</label>
                                    <select id="prop-term" class="form-input">
                                        <option value="120">10 Years</option>
                                        <option value="180">15 Years</option>
                                        <option value="240" selected>20 Years</option>
                                        <option value="300">25 Years</option>
                                        <option value="360">30 Years</option>
                                    </select>
                                </div>
                                <div class="flex flex-col">
                                    <label for="prop-rate" class="form-label">Interest Rate (%)</label>
                                    <input type="number" id="prop-rate" min="3" max="15" step="0.1" value="7.2" required class="form-input">
                                    <small class="text-gray-600 text-sm mt-1">Commercial property rates typically 6-10%</small>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col">
                                    <label for="prop-type" class="form-label">Property Type</label>
                                    <select id="prop-type" class="form-input">
                                        <option value="owner-occupied" selected>Owner Occupied</option>
                                        <option value="investment">Investment Property</option>
                                    </select>
                                </div>
                                <div class="flex flex-col">
                                    <label for="prop-io" class="form-label">Interest Only Period</label>
                                    <select id="prop-io" class="form-input">
                                        <option value="0" selected>Principal & Interest</option>
                                        <option value="12">1 Year Interest Only</option>
                                        <option value="24">2 Years Interest Only</option>
                                        <option value="60">5 Years Interest Only</option>
                                    </select>
                                </div>
                            </div>

                            <button type="button" class="btn-primary btn-large w-full" onclick="calculateProperty()">Calculate Repayments</button>
                        </form>
                    </div>

                    <!-- Working Capital Calculator -->
                    <div id="working-capital-calculator" class="calculator-form hidden">
                        <h2 class="heading-tertiary text-secondary-dark mb-4">Working Capital Calculator</h2>
                        <p class="body-medium text-gray-600 mb-6">Calculate repayments for business line of credit and working capital facilities.</p>
                        
                        <form class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col">
                                    <label for="wc-amount" class="form-label">Credit Facility Amount (AUD)</label>
                                    <input type="number" id="wc-amount" min="25000" max="2000000" step="5000" value="150000" required class="form-input">
                                    <small class="text-gray-600 text-sm mt-1">Minimum $25,000 - Maximum $2,000,000</small>
                                </div>
                                <div class="flex flex-col">
                                    <label for="wc-utilisation" class="form-label">Expected Utilisation (%)</label>
                                    <select id="wc-utilisation" class="form-input">
                                        <option value="50">50% Average Use</option>
                                        <option value="70" selected>70% Average Use</option>
                                        <option value="85">85% Average Use</option>
                                        <option value="100">100% Fully Drawn</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col">
                                    <label for="wc-rate" class="form-label">Interest Rate (%)</label>
                                    <input type="number" id="wc-rate" min="6" max="25" step="0.1" value="12.5" required class="form-input">
                                    <small class="text-gray-600 text-sm mt-1">Working capital rates typically 10-18%</small>
                                </div>
                                <div class="flex flex-col">
                                    <label for="wc-fees" class="form-label">Monthly Line Fee (%)</label>
                                    <input type="number" id="wc-fees" min="0" max="5" step="0.05" value="0.3" class="form-input">
                                    <small class="text-gray-600 text-sm mt-1">Monthly fee on total facility limit</small>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col">
                                    <label for="wc-type" class="form-label">Facility Type</label>
                                    <select id="wc-type" class="form-input">
                                        <option value="line-of-credit" selected>Line of Credit</option>
                                        <option value="overdraft">Bank Overdraft</option>
                                        <option value="invoice-finance">Invoice Finance</option>
                                    </select>
                                </div>
                                <div class="flex flex-col">
                                    <label for="wc-security" class="form-label">Security Required</label>
                                    <select id="wc-security" class="form-input">
                                        <option value="business-assets" selected>Business Assets</option>
                                        <option value="property">Property Security</option>
                                        <option value="personal-guarantee">Personal Guarantee</option>
                                    </select>
                                </div>
                            </div>

                            <button type="button" class="btn-primary btn-large w-full" onclick="calculateWorkingCapital()">Calculate Costs</button>
                        </form>
                    </div>

                    <!-- Invoice Financing Calculator -->
                    <div id="invoice-calculator" class="calculator-form hidden">
                        <h2 class="heading-tertiary text-secondary-dark mb-4">Invoice Financing Calculator</h2>
                        <p class="body-medium text-gray-600 mb-6">Calculate costs for invoice factoring and debtor financing to improve cash flow.</p>
                        
                        <form class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col">
                                    <label for="inv-value" class="form-label">Monthly Invoice Value (AUD)</label>
                                    <input type="number" id="inv-value" min="50000" max="5000000" step="5000" value="200000" required class="form-input">
                                    <small class="text-gray-600 text-sm mt-1">Minimum $50,000 - Maximum $5,000,000</small>
                                </div>
                                <div class="flex flex-col">
                                    <label for="inv-advance" class="form-label">Advance Rate (%)</label>
                                    <select id="inv-advance" class="form-input">
                                        <option value="70">70% Advance</option>
                                        <option value="80" selected>80% Advance</option>
                                        <option value="85">85% Advance</option>
                                        <option value="90">90% Advance</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col">
                                    <label for="inv-factor" class="form-label">Factor Rate (%)</label>
                                    <input type="number" id="inv-factor" min="1" max="8" step="0.1" value="2.5" required class="form-input">
                                    <small class="text-gray-600 text-sm mt-1">Monthly factor rate typically 1.5-4%</small>
                                </div>
                                <div class="flex flex-col">
                                    <label for="inv-terms" class="form-label">Average Debtor Days</label>
                                    <select id="inv-terms" class="form-input">
                                        <option value="30" selected>30 Days</option>
                                        <option value="45">45 Days</option>
                                        <option value="60">60 Days</option>
                                        <option value="90">90 Days</option>
                                    </select>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col">
                                    <label for="inv-service" class="form-label">Service Fee (%)</label>
                                    <input type="number" id="inv-service" min="0" max="2" step="0.1" value="0.5" class="form-input">
                                    <small class="text-gray-600 text-sm mt-1">Monthly service fee on turnover</small>
                                </div>
                                <div class="flex flex-col">
                                    <label for="inv-type" class="form-label">Financing Type</label>
                                    <select id="inv-type" class="form-input">
                                        <option value="factoring" selected>Invoice Factoring</option>
                                        <option value="discounting">Invoice Discounting</option>
                                        <option value="trade-finance">Trade Finance</option>
                                    </select>
                                </div>
                            </div>

                            <button type="button" class="btn-primary btn-large w-full" onclick="calculateInvoiceFinancing()">Calculate Financing Costs</button>
                        </form>
                    </div>

                    <!-- Comparison Calculator -->
                    <div id="comparison-calculator" class="calculator-form hidden">
                        <h2 class="heading-tertiary text-secondary-dark mb-4">Finance Option Comparison</h2>
                        <p class="body-medium text-gray-600 mb-6">Compare different finance options side by side to find the best solution for your business.</p>
                        
                        <div class="service-card-consistent mb-8">
                            <h3 class="heading-tertiary text-secondary-dark mb-6 border-b-2 border-primary-orange pb-3">Finance Requirement</h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col">
                                    <label for="comp-amount" class="form-label">Finance Amount (AUD)</label>
                                    <input type="number" id="comp-amount" min="50000" max="5000000" step="10000" value="300000" required class="form-input">
                                </div>
                                <div class="flex flex-col">
                                    <label for="comp-purpose" class="form-label">Finance Purpose</label>
                                    <select id="comp-purpose" class="form-input">
                                        <option value="equipment">Equipment Purchase</option>
                                        <option value="property">Commercial Property</option>
                                        <option value="working-capital" selected>Working Capital</option>
                                        <option value="mixed">Mixed Purpose</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                            <div class="service-card-consistent">
                                <h4 class="heading-quaternary text-secondary-dark mb-4">Option 1: Traditional Bank Loan</h4>
                                <div class="space-y-4">
                                    <div class="flex flex-col">
                                        <label for="comp1-rate" class="form-label">Interest Rate (%)</label>
                                        <input type="number" id="comp1-rate" min="3" max="20" step="0.1" value="7.5" class="form-input">
                                    </div>
                                    <div class="flex flex-col">
                                        <label for="comp1-term" class="form-label">Loan Term (Months)</label>
                                        <select id="comp1-term" class="form-input">
                                            <option value="36">3 Years</option>
                                            <option value="48">4 Years</option>
                                            <option value="60" selected>5 Years</option>
                                            <option value="84">7 Years</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="service-card-consistent">
                                <h4 class="heading-quaternary text-secondary-dark mb-4">Option 2: Alternative Lender</h4>
                                <div class="space-y-4">
                                    <div class="flex flex-col">
                                        <label for="comp2-rate" class="form-label">Interest Rate (%)</label>
                                        <input type="number" id="comp2-rate" min="3" max="25" step="0.1" value="12.5" class="form-input">
                                    </div>
                                    <div class="flex flex-col">
                                        <label for="comp2-term" class="form-label">Loan Term (Months)</label>
                                        <select id="comp2-term" class="form-input">
                                            <option value="24">2 Years</option>
                                            <option value="36" selected>3 Years</option>
                                            <option value="48">4 Years</option>
                                            <option value="60">5 Years</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="service-card-consistent">
                                <h4 class="heading-quaternary text-secondary-dark mb-4">Option 3: Equipment Finance</h4>
                                <div class="space-y-4">
                                    <div class="flex flex-col">
                                        <label for="comp3-rate" class="form-label">Interest Rate (%)</label>
                                        <input type="number" id="comp3-rate" min="3" max="20" step="0.1" value="9.8" class="form-input">
                                    </div>
                                    <div class="flex flex-col">
                                        <label for="comp3-term" class="form-label">Loan Term (Months)</label>
                                        <select id="comp3-term" class="form-input">
                                            <option value="36">3 Years</option>
                                            <option value="48" selected>4 Years</option>
                                            <option value="60">5 Years</option>
                                            <option value="84">7 Years</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <button type="button" class="btn-primary btn-large w-full" onclick="calculateComparison()">Compare Finance Options</button>

                        <!-- Comparison Results -->
                        <div id="comparison-results" class="comparison-results" style="display: none;">
                            <h3>Finance Option Comparison</h3>
                            <div class="comparison-table">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Finance Option</th>
                                            <th>Monthly Payment</th>
                                            <th>Total Interest</th>
                                            <th>Total Cost</th>
                                            <th>Savings vs Option 1</th>
                                        </tr>
                                    </thead>
                                    <tbody id="comparison-table-body">
                                        <!-- Results populated by JavaScript -->
                                    </tbody>
                                </table>
                            </div>
                            <div class="comparison-chart">
                                <canvas id="comparisonChart" width="400" height="200"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Results Display -->
                    <div id="results" class="service-card-consistent" style="display: none;">
                        <h3 class="heading-tertiary text-secondary-dark mb-6">Calculation Results</h3>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                            <div class="bg-neutral-light card-padding-sm rounded-lg text-center">
                                <span class="form-label block mb-2">Monthly Repayment</span>
                                <span class="text-2xl font-bold text-primary-orange" id="monthly-payment">$0</span>
                            </div>
                            <div class="bg-neutral-light card-padding-sm rounded-lg text-center">
                                <span class="form-label block mb-2">Total Interest</span>
                                <span class="text-2xl font-bold text-secondary-dark" id="total-interest">$0</span>
                            </div>
                            <div class="bg-neutral-light card-padding-sm rounded-lg text-center">
                                <span class="form-label block mb-2">Total Cost</span>
                                <span class="text-2xl font-bold text-secondary-dark" id="total-cost">$0</span>
                            </div>
                            <div class="md:col-span-3 bg-yellow-50 border border-yellow-200 rounded-lg card-padding-sm" id="additional-costs" style="display: none;">
                                <span class="form-label block mb-2">Additional Information</span>
                                <div class="body-medium text-gray-700" id="additional-info"></div>
                            </div>
                        </div>
                        
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="/contact?calculator-results=true" class="btn-primary btn-large">Get Professional Assessment</a>
                            <button type="button" class="btn-secondary btn-large" onclick="printResults()">Print Results</button>
                        </div>
                    </div>
                </div>

                <!-- Educational Content -->
                <div class="service-card-consistent mt-12">
                    <div class="text-center mb-8">
                        <h3 class="heading-secondary text-secondary-dark mb-6">Understanding Your Calculations</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                            <div class="feature-card">
                                <h4 class="heading-tertiary text-secondary-dark mb-4">Interest Rate Factors</h4>
                                <p class="body-medium mb-4">Commercial finance rates vary based on loan type, security, business strength, and market conditions. The rates shown are indicative only.</p>
                                <ul class="space-y-2">
                                    <li class="flex items-start"><span class="text-primary-orange font-bold mr-2">•</span><span class="body-medium">Equipment finance: 6-15% typically</span></li>
                                    <li class="flex items-start"><span class="text-primary-orange font-bold mr-2">•</span><span class="body-medium">Commercial property: 6-10% typically</span></li>
                                    <li class="flex items-start"><span class="text-primary-orange font-bold mr-2">•</span><span class="body-medium">Working capital: 10-18% typically</span></li>
                                </ul>
                            </div>
                            
                            <div class="feature-card">
                                <h4 class="heading-tertiary text-secondary-dark mb-4">GST Considerations</h4>
