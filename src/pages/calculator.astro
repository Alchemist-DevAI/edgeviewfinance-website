    <!-- Calculator JavaScript -->
    <script>
        // Calculator functionality
        function switchCalculator(type) {
            // Hide all calculators
            document.querySelectorAll('.calculator-form').forEach(calc => {
                calc.classList.remove('active');
            });
            
            // Hide results
            document.getElementById('results').style.display = 'none';
            
            // Show selected calculator
            document.getElementById(type + '-calculator').classList.add('active');
            
            // Update tab buttons
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });
            document.querySelector(`[data-calculator="${type}"]`).classList.add('active');
        }

        // Tab button event listeners
        document.querySelectorAll('.tab-button').forEach(button => {
            button.addEventListener('click', () => {
                const calculator = button.getAttribute('data-calculator');
                switchCalculator(calculator);
            });
        });

        // Equipment Finance Calculator
        function calculateEquipment() {
            const amount = parseFloat(document.getElementById('eq-amount').value);
            const includeGST = document.getElementById('eq-gst').value === 'true';
            const term = parseInt(document.getElementById('eq-term').value);
            const rate = parseFloat(document.getElementById('eq-rate').value) / 100 / 12;
            const deposit = parseFloat(document.getElementById('eq-deposit').value) || 0;
            const balloonPercent = parseFloat(document.getElementById('eq-balloon').value);
            
            if (!amount || amount < 10000) {
                alert('Please enter a valid equipment value of at least $10,000');
                return;
            }
            
            let loanAmount = amount - deposit;
            const balloonAmount = loanAmount * (balloonPercent / 100);
            const financeAmount = loanAmount - balloonAmount;
            
            // Calculate monthly payment for principal amount
            let monthlyPayment;
            if (rate === 0) {
                monthlyPayment = financeAmount / term;
            } else {
                monthlyPayment = financeAmount * (rate * Math.pow(1 + rate, term)) / (Math.pow(1 + rate, term) - 1);
            }
            
            const totalPaid = (monthlyPayment * term) + balloonAmount;
            const totalInterest = totalPaid - loanAmount;
            
            displayResults(monthlyPayment, totalInterest, totalPaid, {
                balloonPayment: balloonAmount,
                gstInfo: includeGST ? 'GST inclusive calculation' : 'GST exclusive - consider GST credits if applicable',
                loanAmount: loanAmount
            });
        }

        // Commercial Property Calculator
        function calculateProperty() {
            const propertyValue = parseFloat(document.getElementById('prop-value').value);
            const lvrPercent = parseFloat(document.getElementById('prop-lvr').value);
            const term = parseInt(document.getElementById('prop-term').value);
            const rate = parseFloat(document.getElementById('prop-rate').value) / 100 / 12;
            const interestOnlyMonths = parseInt(document.getElementById('prop-io').value);
            
            if (!propertyValue || propertyValue < 100000) {
                alert('Please enter a valid property value of at least $100,000');
                return;
            }
            
            const loanAmount = propertyValue * (lvrPercent / 100);
            const deposit = propertyValue - loanAmount;
            
            let monthlyPayment, totalInterest;
            
            if (interestOnlyMonths > 0) {
                // Interest only period
                const interestOnlyPayment = loanAmount * rate;
                const remainingTerm = term - interestOnlyMonths;
                
                // Principal and interest payment after IO period
                let piPayment;
                if (rate === 0) {
                    piPayment = loanAmount / remainingTerm;
                } else {
                    piPayment = loanAmount * (rate * Math.pow(1 + rate, remainingTerm)) / (Math.pow(1 + rate, remainingTerm) - 1);
                }
                
                const totalIOInterest = interestOnlyPayment * interestOnlyMonths;
                const totalPIPayments = piPayment * remainingTerm;
                const totalPaid = totalIOInterest + totalPIPayments;
                totalInterest = totalPaid - loanAmount;
                
                // Show blended average payment for simplicity
                monthlyPayment = totalPaid / term;
                
            } else {
                // Standard principal and interest
                if (rate === 0) {
                    monthlyPayment = loanAmount / term;
                } else {
                    monthlyPayment = loanAmount * (rate * Math.pow(1 + rate, term)) / (Math.pow(1 + rate, term) - 1);
                }
                
                const totalPaid = monthlyPayment * term;
                totalInterest = totalPaid - loanAmount;
            }
            
            displayResults(monthlyPayment, totalInterest, monthlyPayment * term, {
                deposit: deposit,
                loanAmount: loanAmount,
                lvr: lvrPercent + '%'
            });
        }

        // Working Capital Calculator
        function calculateWorkingCapital() {
            const facilityAmount = parseFloat(document.getElementById('wc-amount').value);
            const utilisation = parseFloat(document.getElementById('wc-utilisation').value) / 100;
            const rate = parseFloat(document.getElementById('wc-rate').value) / 100 / 12;
            const monthlyFeePercent = parseFloat(document.getElementById('wc-fees').value) / 100;
            
            if (!facilityAmount || facilityAmount < 25000) {
                alert('Please enter a valid facility amount of at least $25,000');
                return;
            }
            
            const averageDrawdown = facilityAmount * utilisation;
            const monthlyInterest = averageDrawdown * rate;
            const monthlyLineFee = facilityAmount * monthlyFeePercent;
            const totalMonthlyCost = monthlyInterest + monthlyLineFee;
            
            // Annual costs
            const annualInterest = monthlyInterest * 12;
            const annualFees = monthlyLineFee * 12;
            const totalAnnualCost = totalMonthlyCost * 12;
            
            displayResults(totalMonthlyCost, annualInterest, totalAnnualCost, {
                facilityAmount: facilityAmount,
                averageDrawdown: averageDrawdown,
                monthlyFees: monthlyLineFee
            });
        }

        // Invoice Financing Calculator
        function calculateInvoiceFinancing() {
            const monthlyInvoiceValue = parseFloat(document.getElementById('inv-value').value);
            const advanceRate = parseFloat(document.getElementById('inv-advance').value) / 100;
            const factorRate = parseFloat(document.getElementById('inv-factor').value) / 100;
            const debtorDays = parseInt(document.getElementById('inv-terms').value);
            const serviceFee = parseFloat(document.getElementById('inv-service').value) / 100;
            
            if (!monthlyInvoiceValue || monthlyInvoiceValue < 50000) {
                alert('Please enter a valid monthly invoice value of at least $50,000');
                return;
            }
            
            // Calculate financing costs
            const advanceAmount = monthlyInvoiceValue * advanceRate;
            const factorFee = monthlyInvoiceValue * factorRate;
            const serviceCharge = monthlyInvoiceValue * serviceFee;
            const totalMonthlyCost = factorFee + serviceCharge;
            
            // Annual costs
            const annualInvoices = monthlyInvoiceValue * 12;
            const annualAdvances = advanceAmount * 12;
            const annualTotalCost = totalMonthlyCost * 12;
            
            // Effective interest rate calculation
            const daysInMonth = 30;
            const annualFactorRate = factorRate * (365 / debtorDays);
            
            displayResults(totalMonthlyCost, annualTotalCost - annualAdvances, annualTotalCost, {
                monthlyAdvance: advanceAmount,
                effectiveRate: (annualFactorRate * 100).toFixed(2) + '% p.a.',
                annualTurnover: annualInvoices,
                costAsPercentage: ((totalMonthlyCost / monthlyInvoiceValue) * 100).toFixed(2) + '% of turnover'
            });
        }

        // Comparison Calculator
        function calculateComparison() {
            const amount = parseFloat(document.getElementById('comp-amount').value);
            
            if (!amount || amount < 50000) {
                alert('Please enter a valid finance amount of at least $50,000');
                return;
            }
            
            const options = [
                {
                    name: 'Traditional Bank Loan',
                    rate: parseFloat(document.getElementById('comp1-rate').value) / 100 / 12,
                    term: parseInt(document.getElementById('comp1-term').value)
                },
                {
                    name: 'Alternative Lender',
                    rate: parseFloat(document.getElementById('comp2-rate').value) / 100 / 12,
                    term: parseInt(document.getElementById('comp2-term').value)
                },
                {
                    name: 'Equipment Finance',
                    rate: parseFloat(document.getElementById('comp3-rate').value) / 100 / 12,
                    term: parseInt(document.getElementById('comp3-term').value)
                }
            ];
            
            const results = options.map(option => {
                let monthlyPayment;
                if (option.rate === 0) {
                    monthlyPayment = amount / option.term;
                } else {
                    monthlyPayment = amount * (option.rate * Math.pow(1 + option.rate, option.term)) / (Math.pow(1 + option.rate, option.term) - 1);
                }
                
                const totalPaid = monthlyPayment * option.term;
                const totalInterest = totalPaid - amount;
                
                return {
                    name: option.name,
                    monthlyPayment: monthlyPayment,
                    totalInterest: totalInterest,
                    totalCost: totalPaid
                };
            });
            
            // Find the best option (lowest total cost)
            const bestOption = results.reduce((best, current) => 
                current.totalCost < best.totalCost ? current : best
            );
            
            displayComparisonResults(results, bestOption);
        }

        // Display Comparison Results
        function displayComparisonResults(results, bestOption) {
            const tableBody = document.getElementById('comparison-table-body');
            tableBody.innerHTML = '';
            
            const baselineCost = results[0].totalCost;
            
            results.forEach((result, index) => {
                const row = document.createElement('tr');
                const savings = baselineCost - result.totalCost;
                const isBest = result.name === bestOption.name;
                
                if (isBest) {
                    row.classList.add('best-option');
                }
                
                row.innerHTML = `
                    <td>${result.name}${isBest ? ' ⭐ Best Option' : ''}</td>
                    <td>${formatCurrency(result.monthlyPayment)}</td>
                    <td>${formatCurrency(result.totalInterest)}</td>
                    <td>${formatCurrency(result.totalCost)}</td>
                    <td class="${savings >= 0 ? 'savings-positive' : 'savings-negative'}">
                        ${index === 0 ? 'Baseline' : formatCurrency(savings)}
                    </td>
                `;
                
                tableBody.appendChild(row);
            });
            
            // Show results and scroll to them
            document.getElementById('comparison-results').style.display = 'block';
            document.getElementById('comparison-results').scrollIntoView({ behavior: 'smooth' });
            
            // Create simple comparison chart
            createComparisonChart(results);
        }

        // Create Comparison Chart
        function createComparisonChart(results) {
            const canvas = document.getElementById('comparisonChart');
            const ctx = canvas.getContext('2d');
            
            // Clear canvas
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Chart dimensions
            const chartWidth = canvas.width - 100;
            const chartHeight = canvas.height - 60;
            const barWidth = chartWidth / (results.length * 2);
            const maxValue = Math.max(...results.map(r => r.totalCost));
            
            // Draw bars
            results.forEach((result, index) => {
                const x = 50 + (index * barWidth * 2);
                const barHeight = (result.totalCost / maxValue) * chartHeight;
                const y = canvas.height - 30 - barHeight;
                
                // Bar color
                ctx.fillStyle = result.totalCost === Math.min(...results.map(r => r.totalCost)) ? '#27ae60' : '#3498db';
                ctx.fillRect(x, y, barWidth, barHeight);
                
                // Value on top of bar
                ctx.fillStyle = '#333';
                ctx.font = '12px Arial';
                ctx.textAlign = 'center';
                ctx.fillText(formatCurrency(result.totalCost), x + barWidth/2, y - 5);
                
                // Label below bar
                ctx.save();
                ctx.translate(x + barWidth/2, canvas.height - 10);
                ctx.rotate(-Math.PI/6);
                ctx.textAlign = 'right';
                ctx.fillText(result.name, 0, 0);
                ctx.restore();
            });
            
            // Chart title
            ctx.fillStyle = '#333';
            ctx.font = 'bold 14px Arial';
            ctx.textAlign = 'center';
            ctx.fillText('Total Cost Comparison', canvas.width/2, 20);
        }

        // Display Results Function
        function displayResults(monthlyPayment, totalInterest, totalCost, additionalInfo = {}) {
            document.getElementById('monthly-payment').textContent = formatCurrency(monthlyPayment);
            document.getElementById('total-interest').textContent = formatCurrency(totalInterest);
            document.getElementById('total-cost').textContent = formatCurrency(totalCost);
            
            // Show additional information if provided
            if (Object.keys(additionalInfo).length > 0) {
                let infoHTML = '';
                Object.entries(additionalInfo).forEach(([key, value]) => {
                    const label = key.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase());
                    if (typeof value === 'number') {
                        infoHTML += `<p><strong>${label}:</strong> ${formatCurrency(value)}</p>`;
                    } else {
                        infoHTML += `<p><strong>${label}:</strong> ${value}</p>`;
                    }
                });
                
                document.getElementById('additional-info').innerHTML = infoHTML;
                document.getElementById('additional-costs').style.display = 'block';
            } else {
                document.getElementById('additional-costs').style.display = 'none';
            }
            
            document.getElementById('results').style.display = 'block';
            document.getElementById('results').scrollIntoView({ behavior: 'smooth' });
        }

        // Format currency helper
        function formatCurrency(amount) {
            return new Intl.NumberFormat('en-AU', {
                style: 'currency',
                currency: 'AUD',
                minimumFractionDigits: 0,
                maximumFractionDigits: 0
            }).format(amount);
        }

        // Print results function
        function printResults() {
            window.print();
        }

        // Form validation and input formatting
        document.addEventListener('DOMContentLoaded', function() {
            // Add input formatting for currency fields
            const currencyInputs = document.querySelectorAll('input[type="number"]');
            currencyInputs.forEach(input => {
                if (input.id.includes('amount') || input.id.includes('value') || input.id.includes('deposit')) {
                    input.addEventListener('blur', function() {
                        if (this.value && !isNaN(this.value)) {
                            // Format display without changing the actual value
                            const value = parseFloat(this.value);
                            this.title = formatCurrency(value);
                        }
                    });
                }
            });
        });

        // Error handling for calculations
        function validateInputs(calculatorType) {
            const inputs = document.querySelectorAll(`#${calculatorType}-calculator input[required]`);
            for (let input of inputs) {
                if (!input.value || isNaN(input.value)) {
                    input.focus();
                    alert(`Please enter a valid ${input.previousElementSibling.textContent}`);
                    return false;
                }
            }
            return true;
        }
    </script>
