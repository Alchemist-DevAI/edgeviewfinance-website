---
// Invoice Financing Page - AI-Driven Cash Flow Acceleration
// Optimized for Ben the Business Builder ICP (excluding residential builders)
import Agency11Layout from '../layouts/Agency11Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const siteData = {
  title: "Invoice Financing Australia | Accelerate Cash Flow | EVFBS",
  description: "AI-driven invoice financing for commercial trades and civil contractors. Unlock 80-100% of invoice value upfront with smart cash flow optimisation. Fast approvals and competitive rates.",
  keywords: "invoice financing Australia, accounts receivable financing, factoring, cash flow acceleration, commercial invoice finance, trade invoice funding"
};
---

<Agency11Layout title={siteData.title} description={siteData.description} keywords={siteData.keywords}>
  <!-- Invoice Financing Service Schema -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://edgeviewfinance.com.au/invoice-financing",
    "name": "Invoice Financing",
    "alternateName": "Accounts Receivable Financing",
    "description": "Invoice financing solutions for commercial trades and civil contractors to accelerate cash flow and unlock working capital",
    "serviceType": "Invoice Financing",
    "provider": {
      "@type": "FinancialService",
      "@id": "https://edgeviewfinance.com.au/#organization",
      "name": "Edgeview Finance Business Solutions",
      "areaServed": {
        "@type": "Country",
        "name": "Australia"
      }
    },
    "offers": {
      "@type": "Offer",
      "name": "Invoice Financing Solutions",
      "description": "Flexible invoice financing with 80-100% advance rates and AI-driven cash flow optimisation",
      "itemOffered": {
        "@type": "Service",
        "name": "Invoice Financing",
        "category": "Commercial Finance"
      }
    },
    "audience": {
      "@type": "BusinessAudience",
      "businessType": ["Commercial Trades", "Civil Contractors", "B2B Service Businesses"],
      "numberOfEmployees": "5-50"
    }
  }
  </script>

