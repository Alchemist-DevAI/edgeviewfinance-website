            color: white;
            padding: 60px 20px 80px;
            text-align: center;
        }
        
        .breadcrumb {
            font-size: 0.9rem;
            margin-bottom: 1rem;
            opacity: 0.8;
        }
        
        .breadcrumb a {
            color: white;
