            color: #2c5aa0;
        }
        
        .cta-button {
            background: #e67e22 !important;
            color: white !important;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background 0.3s;
        }
        
        .cta-button:hover {
            background: #d35400 !important;
        }
        
