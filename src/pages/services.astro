---
// EVFBS Services Overview - Australian Commercial Finance Services
// Optimized for "Ben the Business Builder" ICP
import Agency11Layout from '../layouts/Agency11Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const siteData = {
  title: "Commercial Finance Services Australia | Equipment Finance & Business Loans",
  description: "Comprehensive commercial finance services for Australian trades and service businesses. Equipment finance, commercial property, working capital, invoice financing, and personal lending with expert partnership.",
  keywords: "commercial finance services Australia, equipment finance, business loans, trade finance, working capital, commercial property finance, invoice financing"
};
---

<Agency11Layout title={siteData.title} description={siteData.description} keywords={siteData.keywords}>
  <!-- Services Schema -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "@id": "https://edgeviewfinance.com.au/services#organization",
    "name": "Edgeview Finance Business Solutions Services",
    "description": "Comprehensive commercial finance services for Australian trades and service businesses",
    "url": "https://edgeviewfinance.com.au/services",
    "serviceType": "Commercial Finance Brokerage",
    "areaServed": {
      "@type": "Country",
      "name": "Australia"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Commercial Finance Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Equipment Finance",
            "description": "Strategic equipment finance for commercial trades, civil contractors, and industrial businesses"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Commercial Property Finance",
            "description": "Professional property finance for business premises and commercial investment"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Working Capital Solutions",
            "description": "Strategic working capital and cash flow management for commercial trades"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Invoice Financing",
            "description": "Unlock cash from unpaid invoices for established commercial trade businesses"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Personal Home Lending",
            "description": "Professional home lending leveraging commercial business success"
          }
        }
      ]
    }
  }
  </script>
  
  <!-- Open Graph for Social Sharing -->
  <meta property="og:title" content={siteData.title} slot="head" />
  <meta property="og:description" content={siteData.description} slot="head" />
  <meta property="og:type" content="website" slot="head" />
  <meta property="og:url" content="https://edgeviewfinance.com.au/services" slot="head" />
  <meta property="og:locale" content="en_AU" slot="head" />

  <Header />
  <main>
        <!-- Hero Section -->
        <section class="hero-section">
            <div class="section-hero">
                <div class="container-default">
                    <div class="text-center">
                        <h1 class="heading-primary text-white mb-8">
                            Comprehensive Commercial Finance Services for Australian Business Growth
                        </h1>
                        <p class="body-large text-gray-100 mb-10 max-w-4xl mx-auto">
                        Strategic finance solutions designed for commercial trades, civil contractors, and industrial businesses. 
                        Professional assessment, expert guidance, and partnership approach for sustainable growth.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center button-gap">
                        <a href="/get-quote" class="btn-primary btn-large">Get Professional Assessment</a>
                        <a href="/calculator" class="btn-secondary btn-large text-white border-white hover:bg-white hover:text-secondary-dark">Calculate Repayments</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Services Overview -->
        <section class="section-content bg-neutral-light">
            <div class="container-default">
                <div class="text-center mb-16">
                    <h2 class="heading-secondary mb-6">Strategic Finance Solutions for Professional Business Growth</h2>
                    <p class="body-large max-w-4xl mx-auto">
                        Edgeview Finance Business Solutions specializes in commercial finance for Australian trades and service businesses. 
                        Our comprehensive range of services is designed to support every stage of your business journey, from equipment acquisition to expansion financing.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <!-- Featured Service Cards -->
                    <div class="service-card-consistent lg:col-span-1 border-2 border-primary-orange">
                        <div class="icon-wrapper text-4xl mb-6">🏗️</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Equipment Finance</h3>
                        <p class="body-medium mb-6">Strategic equipment financing for commercial trades, civil contractors, and industrial businesses. Competitive rates from $20K to $500K+ with flexible terms.</p>
                        <ul class="space-y-2 mb-6">
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Heavy machinery & construction equipment</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Commercial vehicles & fleet expansion</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Industrial tools & workshop equipment</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Specialised trade machinery & technology</span>
                            </li>
                        </ul>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span class="bg-primary-orange text-white px-3 py-1 rounded-full text-sm font-semibold">$20K - $500K+</span>
                            <span class="bg-primary-orange text-white px-3 py-1 rounded-full text-sm font-semibold">1-7 years</span>
                        </div>
                        <a href="/equipment-finance" class="text-primary-orange hover:text-primary-orange-dark font-semibold transition-colors duration-200">
                            Explore Equipment Finance →
                        </a>
                    </div>
                    
                    <div class="service-card-consistent lg:col-span-1 border-2 border-primary-orange">
                        <div class="icon-wrapper text-4xl mb-6">🏢</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Commercial Property Finance</h3>
                        <p class="body-medium mb-6">Professional property finance for business premises acquisition or investment opportunities with strategic structuring.</p>
                        <ul class="space-y-2 mb-6">
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Business premises purchase</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Commercial property investment</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Property development funding</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Refinancing existing properties</span>
                            </li>
                        </ul>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span class="bg-primary-orange text-white px-3 py-1 rounded-full text-sm font-semibold">$100K - $5M+</span>
                            <span class="bg-primary-orange text-white px-3 py-1 rounded-full text-sm font-semibold">5-30 years</span>
                        </div>
                        <a href="/commercial-property" class="text-primary-orange hover:text-primary-orange-dark font-semibold transition-colors duration-200">
                            Explore Property Finance →
                        </a>
                    </div>
                    
                    <div class="service-card-consistent lg:col-span-1 border-2 border-primary-orange">
                        <div class="icon-wrapper text-4xl mb-6">💰</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Working Capital Solutions</h3>
                        <p class="body-medium mb-6">Strategic working capital and cash flow management for commercial trades and civil contractors. Support business operations and growth initiatives.</p>
                        <ul class="space-y-2 mb-6">
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Cash flow bridging for payment delays</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Invoice factoring & discounting</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Business line of credit facilities</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Seasonal funding for peak demand</span>
                            </li>
                        </ul>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span class="bg-primary-orange text-white px-3 py-1 rounded-full text-sm font-semibold">$50K - $1M+</span>
                            <span class="bg-primary-orange text-white px-3 py-1 rounded-full text-sm font-semibold">Flexible terms</span>
                        </div>
                        <a href="/working-capital" class="text-primary-orange hover:text-primary-orange-dark font-semibold transition-colors duration-200">
                            Explore Working Capital →
                        </a>
                    </div>
                    
                    <!-- Additional Service Cards -->
                    <div class="service-card-consistent lg:col-span-1">
                        <div class="icon-wrapper text-4xl mb-6">📄</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Invoice Financing</h3>
                        <p class="body-medium mb-6">Unlock cash tied up in unpaid invoices to smooth cash flow and fund ongoing commercial work. Ideal for established trade businesses.</p>
                        <ul class="space-y-2 mb-6">
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">80-100% invoice value upfront</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Selective invoice finance options</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Commercial client payment acceleration</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">AI-driven cash flow optimization</span>
                            </li>
                        </ul>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span class="bg-primary-orange text-white px-3 py-1 rounded-full text-sm font-semibold">$25K - $500K+</span>
                            <span class="bg-primary-orange text-white px-3 py-1 rounded-full text-sm font-semibold">30-90 days</span>
                        </div>
                        <a href="/invoice-financing" class="text-primary-orange hover:text-primary-orange-dark font-semibold transition-colors duration-200">
                            Explore Invoice Finance →
                        </a>
                    </div>
                    
                    <div class="service-card-consistent lg:col-span-1">
                        <div class="icon-wrapper text-4xl mb-6">🏠</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Personal Home Lending</h3>
                        <p class="body-medium mb-6">Professional home lending services for business owners, leveraging commercial success for competitive personal finance terms.</p>
                        <ul class="space-y-2 mb-6">
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Owner-occupier home loans</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Investment property finance</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Self-employed lending solutions</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary-orange font-bold mr-2">✓</span>
                                <span class="text-gray-700">Equity release for business growth</span>
                            </li>
                        </ul>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span class="bg-primary-orange text-white px-3 py-1 rounded-full text-sm font-semibold">$200K - $2M+</span>
                            <span class="bg-primary-orange text-white px-3 py-1 rounded-full text-sm font-semibold">15-30 years</span>
                        </div>
                        <a href="/personal-lending" class="text-primary-orange hover:text-primary-orange-dark font-semibold transition-colors duration-200">
                            Explore Personal Lending →
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Service Process -->
        <section class="section-content">
            <div class="container-default">
                <div class="text-center mb-16">
                    <h2 class="heading-secondary mb-6">Our Professional Assessment Process</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">1</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Initial Consultation</h3>
                        <p class="body-medium">Comprehensive discussion of your business goals, financial requirements, and growth objectives. Understanding your "Ben the Business Builder" journey.</p>
                    </div>
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">2</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Financial Assessment</h3>
                        <p class="body-medium">Professional analysis of your business financials, borrowing capacity, and optimal finance structure using AI-enhanced analytics.</p>
                    </div>
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">3</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Strategic Structuring</h3>
                        <p class="body-medium">Design finance solutions aligned with your business cycle, cash flow patterns, and growth timeline for optimal outcomes.</p>
                    </div>
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">4</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Lender Matching</h3>
                        <p class="body-medium">Access our network of specialist commercial lenders to secure competitive terms and conditions for your specific industry.</p>
                    </div>
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">5</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Application Management</h3>
                        <p class="body-medium">Professional presentation and management of your application through to settlement, ensuring smooth process and optimal outcomes.</p>
                    </div>
                    <div class="process-step text-center card-padding-lg">
                        <div class="process-number mb-6">6</div>
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Ongoing Partnership</h3>
                        <p class="body-medium">Continued support for future growth requirements, refinancing opportunities, and strategic finance optimization.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Industry Specialization -->
        <section class="section-content bg-neutral-light">
            <div class="container-default">
                <div class="text-center mb-16">
                    <h2 class="heading-secondary mb-6">Industries We Serve</h2>
                    <p class="body-large max-w-4xl mx-auto">
                        Specializing in commercial trades, civil contractors, and industrial businesses across Australia. 
                        We understand the unique challenges and opportunities in these sectors.
                    </p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Commercial Trades</h3>
                        <p class="body-medium">Electricians, plumbers, HVAC, commercial cleaning, security services, and specialized trade contractors.</p>
                    </div>
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Civil Contractors</h3>
                        <p class="body-medium">Earthmoving, excavation, road construction, drainage, utilities, and infrastructure contractors.</p>
                    </div>
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Transport & Logistics</h3>
                        <p class="body-medium">Freight operators, courier services, warehousing, distribution, and logistics management.</p>
                    </div>
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Manufacturing</h3>
                        <p class="body-medium">Light manufacturing, fabrication, processing, packaging, and industrial production.</p>
                    </div>
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Construction Services</h3>
                        <p class="body-medium">Commercial construction, fit-outs, project management, and construction support services.</p>
                    </div>
                    <div class="feature-card">
                        <h3 class="heading-tertiary text-secondary-dark mb-4">Industrial Services</h3>
                        <p class="body-medium">Maintenance, repairs, technical services, and specialized industrial support operations.</p>
                    </div>
                </div>
                
                <div class="bg-yellow-50 border border-yellow-200 rounded-xl card-padding-lg text-center">
                    <p class="body-medium text-gray-700">
                        <strong class="text-secondary-dark">Note:</strong> We focus on sustainable commercial sectors and exclude residential building to concentrate on businesses with stable cash flows and growth potential.
                    </p>
                </div>
            </div>
        </section>

        <!-- Call to Action -->
        <section class="section-cta hero-section">
            <div class="container-default">
                <div class="text-center">
                    <h2 class="heading-secondary text-white mb-6">Ready to Partner for Strategic Business Growth?</h2>
                    <p class="text-xl lg:text-2xl text-gray-100 mb-8 max-w-4xl mx-auto">
                        Join hundreds of Australian business builders who've secured strategic finance solutions through our professional partnership approach.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center button-gap">
                        <a href="/get-quote" class="btn-primary btn-large">Request Professional Assessment</a>
                        <a href="/contact" class="btn-secondary btn-large text-white border-white hover:bg-white hover:text-secondary-dark">Speak with a Finance Specialist</a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Agency11Layout>