---
import Agency11Layout from '../layouts/Agency11Layout.astro';

const pageTitle = 'Privacy Policy | Edgeview Finance Business Solutions';
const pageDescription = 'Comprehensive privacy policy for EVFBS commercial finance brokerage services. Compliant with Australian Privacy Principles (APPs), Privacy Act 1988, and Credit Reporting Code.';

const lastUpdated = "15 August 2025";
const reviewDate = "15 August 2026";
---

<Agency11Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="section-hero bg-gradient-to-br from-brand-primary to-brand-primary-dark text-white">
    <div class="container-default">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="heading-primary text-white mb-6">
          Privacy Policy
        </h1>
        <p class="body-large text-brand-grey-100 mb-4">
          Your privacy and data security are our priority
        </p>
        <p class="text-sm text-brand-grey-200">
          Last Updated: {lastUpdated} | Next Review: {reviewDate}
        </p>
      </div>
    </div>
  </section>

  <!-- Privacy Policy Content -->
  <section class="section-content">
    <div class="container-default">
      <div class="max-w-4xl mx-auto">
        
        <!-- Introduction -->
        <div class="prose prose-lg max-w-none mb-12">
          <div class="bg-brand-grey-50 rounded-xl p-6 mb-8">
            <p class="text-brand-grey-700 leading-relaxed">
              Edgeview Finance Business Solutions Pty Ltd (EVFBS) is committed to protecting your privacy and ensuring the security of your personal information. This Privacy Policy explains how we collect, use, disclose, and protect your information in accordance with the Privacy Act 1988 (Cth) and the Australian Privacy Principles (APPs).
            </p>
          </div>

          <!-- Collection of Information -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-4">1. Information We Collect</h2>
            <div class="space-y-4 text-brand-grey-700">
              <p>We collect information necessary to provide our commercial finance brokerage services, including:</p>
              
              <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                <h3 class="font-semibold text-brand-grey-900 mb-3">Personal Information</h3>
                <ul class="list-disc list-inside space-y-2">
                  <li>Full name, date of birth, and contact details</li>
                  <li>Driver's licence and identification documents</li>
                  <li>Employment and income information</li>
                  <li>Financial statements and tax returns</li>
                  <li>Credit history and credit reports</li>
                </ul>
              </div>
              
              <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                <h3 class="font-semibold text-brand-grey-900 mb-3">Business Information</h3>
                <ul class="list-disc list-inside space-y-2">
                  <li>ABN, ACN, and business registration details</li>
                  <li>Business financial statements and cash flow data</li>
                  <li>Business plans and forecasts</li>
                  <li>Asset and liability information</li>
                  <li>Industry and operational details</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- How We Collect Information -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-4">2. How We Collect Information</h2>
            <div class="space-y-4 text-brand-grey-700">
              <p>We collect information through:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Application forms and enquiry submissions</li>
                <li>Phone calls, emails, and meetings</li>
                <li>Our website forms and calculator tools</li>
                <li>Credit reporting bodies and financial institutions</li>
                <li>Accountants, lawyers, and other professional advisers</li>
                <li>Public registers and databases</li>
              </ul>
            </div>
          </div>

          <!-- Use of Information -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-4">3. How We Use Your Information</h2>
            <div class="space-y-4 text-brand-grey-700">
              <p>We use your information to:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Assess your finance requirements and eligibility</li>
                <li>Source and negotiate appropriate finance solutions</li>
                <li>Submit applications to lenders and finance providers</li>
                <li>Provide ongoing support and service</li>
                <li>Comply with legal and regulatory requirements</li>
                <li>Improve our services and client experience</li>
                <li>Send relevant finance updates and opportunities (with consent)</li>
              </ul>
            </div>
          </div>

          <!-- Disclosure of Information -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-4">4. Disclosure of Information</h2>
            <div class="space-y-4 text-brand-grey-700">
              <p>We may disclose your information to:</p>
              
              <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                <ul class="list-disc list-inside space-y-2">
                  <li><strong>Finance providers:</strong> Banks, lenders, and equipment financiers</li>
                  <li><strong>Credit reporting bodies:</strong> For credit assessments</li>
                  <li><strong>Professional services:</strong> Accountants, lawyers, valuers</li>
                  <li><strong>Insurance providers:</strong> For required insurance products</li>
                  <li><strong>Government agencies:</strong> As required by law</li>
                  <li><strong>Service providers:</strong> IT, document management, compliance services</li>
                </ul>
              </div>
              
              <p class="mt-4">
                <strong>Note:</strong> We will never sell, rent, or trade your personal information to third parties for marketing purposes.
              </p>
            </div>
          </div>

          <!-- Credit Reporting -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-4">5. Credit Reporting</h2>
            <div class="space-y-4 text-brand-grey-700">
              <p>In providing our services, we may:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Obtain credit reports from credit reporting bodies</li>
                <li>Disclose credit information to lenders</li>
                <li>Use credit eligibility information for assessment</li>
              </ul>
              
              <div class="bg-brand-accent-light rounded-lg p-6 mt-4">
                <p class="text-sm">
                  <strong>Credit Reporting Bodies we use:</strong><br/>
                  • Equifax Australia: www.equifax.com.au<br/>
                  • Experian Australia: www.experian.com.au<br/>
                  • illion Australia: www.illion.com.au
                </p>
              </div>
            </div>
          </div>

          <!-- Data Security -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-4">6. Data Security</h2>
            <div class="space-y-4 text-brand-grey-700">
              <p>We protect your information through:</p>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-white rounded-lg p-4 border border-brand-grey-200">
                  <h3 class="font-semibold text-brand-grey-900 mb-2">Physical Security</h3>
                  <ul class="list-disc list-inside text-sm space-y-1">
                    <li>Locked filing systems</li>
                    <li>Restricted office access</li>
                    <li>Secure document disposal</li>
                  </ul>
                </div>
                
                <div class="bg-white rounded-lg p-4 border border-brand-grey-200">
                  <h3 class="font-semibold text-brand-grey-900 mb-2">Digital Security</h3>
                  <ul class="list-disc list-inside text-sm space-y-1">
                    <li>Encrypted data storage</li>
                    <li>Secure cloud systems</li>
                    <li>Regular security updates</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Your Rights -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-4">7. Your Rights</h2>
            <div class="space-y-4 text-brand-grey-700">
              <p>Under the Privacy Act 1988, you have the right to:</p>
              
              <div class="bg-white rounded-lg p-6 border border-brand-grey-200">
                <ul class="list-disc list-inside space-y-2">
                  <li><strong>Access:</strong> Request access to your personal information</li>
                  <li><strong>Correction:</strong> Request correction of inaccurate information</li>
                  <li><strong>Complaint:</strong> Lodge a complaint about privacy breaches</li>
                  <li><strong>Anonymity:</strong> Deal with us anonymously where lawful and practicable</li>
                  <li><strong>Opt-out:</strong> Opt-out of marketing communications</li>
                  <li><strong>Erasure:</strong> Request deletion of information (subject to legal requirements)</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Cookies and Website -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-4">8. Website and Cookies</h2>
            <div class="space-y-4 text-brand-grey-700">
              <p>Our website uses cookies to:</p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Improve website functionality and user experience</li>
                <li>Analyze website traffic and usage patterns</li>
                <li>Remember your preferences and settings</li>
                <li>Provide relevant content and services</li>
              </ul>
              <p class="mt-4">
                You can manage cookie preferences through your browser settings. Disabling cookies may affect website functionality.
              </p>
            </div>
          </div>

          <!-- Complaints Process -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-4">9. Complaints and Contact</h2>
            <div class="space-y-4 text-brand-grey-700">
              <p>If you have concerns about privacy or wish to make a complaint:</p>
              
              <div class="bg-brand-grey-50 rounded-lg p-6">
                <h3 class="font-semibold text-brand-grey-900 mb-3">Step 1: Contact Us</h3>
                <p class="mb-2">Privacy Officer<br/>
                Edgeview Finance Business Solutions<br/>
                Email: privacy@edgeviewfinance.com.au<br/>
                Phone: 1300 733 856</p>
                
                <h3 class="font-semibold text-brand-grey-900 mb-3 mt-6">Step 2: External Complaint</h3>
                <p>If unresolved, you may contact:<br/>
                <strong>Office of the Australian Information Commissioner (OAIC)</strong><br/>
                Phone: 1300 363 992<br/>
                Website: www.oaic.gov.au</p>
              </div>
            </div>
          </div>

          <!-- Updates to Policy -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-4">10. Policy Updates</h2>
            <div class="space-y-4 text-brand-grey-700">
              <p>
                We may update this Privacy Policy to reflect changes in law, technology, or our business practices. 
                Updates will be posted on our website with the revision date. We encourage you to review this policy periodically.
              </p>
            </div>
          </div>

        </div>

        <!-- Agreement Section -->
        <div class="bg-gradient-to-br from-brand-accent to-brand-primary rounded-2xl p-8 text-white text-center">
          <h2 class="heading-tertiary text-white mb-4">
            Questions About Privacy?
          </h2>
          <p class="body-medium text-brand-grey-100 mb-6">
            Our team is here to help with any privacy concerns or questions
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="btn-primary bg-white text-brand-primary hover:bg-brand-grey-50">
              Contact Privacy Officer
            </a>
            <a href="/credit-guide" class="btn-secondary border-white text-white hover:bg-white hover:text-brand-primary">
              View Credit Guide
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Agency11Layout>