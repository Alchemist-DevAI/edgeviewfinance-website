        <!-- About This Policy -->
        <section class="policy-section" id="about">
            <div class="container">
                <h2>About This Privacy Policy</h2>
                <div class="content">
                    <p>
                        Edgeview Finance Business Solutions Pty Ltd (ABN: [ABN Number], ACL: [ACL Number]) ("EVFBS", "we", "us", or "our") 
                        is committed to protecting the privacy of your personal information in accordance with Australian privacy laws.
                    </p>
                    <p>
                        This Privacy Policy explains how we collect, use, disclose, and manage personal information (including credit information) 
                        when providing commercial finance brokerage services to Australian businesses. It applies to all personal information we collect 
                        about individuals, including business owners, directors, guarantors, and authorised representatives.
                    </p>
                    <div class="highlight-box">
                        <h4>Key Legislative Framework</h4>
                        <ul>
                            <li>Privacy Act 1988 (Cth) and Australian Privacy Principles (APPs)</li>
                            <li>Credit Reporting Privacy Code 2014</li>
                            <li>National Consumer Credit Protection Act 2009 (Cth)</li>
                            <li>Corporations Act 2001 (Cth)</li>
                            <li>Australian Securities and Investments Commission Act 2001 (Cth)</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Information Collection -->
        <section class="policy-section" id="collection">
            <div class="container">
                <h2>Information We Collect</h2>
                <div class="content">
                    <h3>Personal Information</h3>
                    <p>We collect personal information necessary to provide commercial finance brokerage services, including:</p>
                    
                    <div class="info-categories">
                        <div class="category">
                            <h4>Identity Information</h4>
                            <ul>
                                <li>Full name, date of birth, and residential address</li>
                                <li>Driver's licence number and passport details</li>
                                <li>Business registration details (ABN, ACN, trading names)</li>
                                <li>Director and shareholder information</li>
                                <li>Authorised representative details</li>
                            </ul>
                        </div>
                        
                        <div class="category">
                            <h4>Contact Information</h4>
                            <ul>
                                <li>Phone numbers (mobile, business, home)</li>
                                <li>Email addresses (personal and business)</li>
                                <li>Postal and business addresses</li>
                                <li>Preferred communication methods</li>
                            </ul>
                        </div>
                        
                        <div class="category">
                            <h4>Financial Information</h4>
                            <ul>
                                <li>Income details (salary, business income, rental income)</li>
                                <li>Employment history and business details</li>
                                <li>Assets and liabilities information</li>
                                <li>Bank account details and financial statements</li>
                                <li>Existing loan and credit commitments</li>
                                <li>Insurance details and valuations</li>
                            </ul>
                        </div>
                        
                        <div class="category">
                            <h4>Business Information</h4>
                            <ul>
                                <li>Business structure and operations</li>
                                <li>Industry sector and business model</li>
                                <li>Trade history and client base</li>
                                <li>Equipment and asset requirements</li>
                                <li>Cash flow patterns and projections</li>
                                <li>Professional references and trade contacts</li>
                            </ul>
                        </div>
                    </div>

                    <h3>Credit Information</h3>
                    <p>
                        Under the Credit Reporting Privacy Code 2014, we may collect credit information including:
                    </p>
                    <ul>
                        <li>Credit reports from credit reporting bodies (Equifax, Experian, illion)</li>
                        <li>Credit history and repayment behaviour information</li>
                        <li>Default listings and court judgments</li>
                        <li>Credit enquiry history from other credit providers</li>
                        <li>Bankruptcy and personal insolvency information</li>
                        <li>Commercial credit information for business entities</li>
                    </ul>

                    <h3>Collection Methods</h3>
                    <p>We collect information through:</p>
                    <ul>
                        <li>Direct collection via application forms, consultations, and communications</li>
                        <li>Credit reporting bodies and credit reference agencies</li>
                        <li>Lenders, brokers, and financial service providers</li>
                        <li>Government agencies and regulatory bodies (ASIC, ATO)</li>
                        <li>Publicly available sources and business registers</li>
                        <li>Third-party service providers and verification services</li>
                        <li>Website interactions, cookies, and analytics tools</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Information Use -->
        <section class="policy-section" id="use">
            <div class="container">
                <h2>How We Use Your Information</h2>
                <div class="content">
                    <h3>Primary Purposes</h3>
                    <p>We use your personal information to:</p>
                    <ul>
                        <li>Assess your commercial finance applications and borrowing capacity</li>
                        <li>Provide strategic finance advice and recommendations</li>
                        <li>Submit applications to appropriate lenders and credit providers</li>
                        <li>Negotiate terms and conditions on your behalf</li>
                        <li>Manage ongoing client relationships and service delivery</li>
                        <li>Comply with legal and regulatory obligations (ASIC, AML/CTF)</li>
                    </ul>

                    <h3>Secondary Purposes</h3>
                    <p>With your consent or where permitted by law, we may also use information for:</p>
                    <ul>
                        <li>Marketing relevant financial products and services</li>
                        <li>Improving our services through analysis and feedback</li>
                        <li>Training staff and developing business processes</li>
                        <li>Research and development of new finance solutions</li>
                        <li>Quality assurance and dispute resolution</li>
                    </ul>

                    <div class="highlight-box">
                        <h4>AI-Enhanced Analysis</h4>
                        <p>
                            We use artificial intelligence and machine learning tools to analyse financial data for optimal finance structuring 
                            and risk assessment. This analysis helps provide strategic recommendations and improve service delivery. 
                            All AI processing maintains strict data security and privacy protections.
                        </p>
                    </div>

                    <h3>Direct Marketing</h3>
                    <p>
                        We may contact you with information about products and services that may interest your business. You can:
                    </p>
                    <ul>
                        <li>Opt out at any time by contacting our Privacy Officer</li>
                        <li>Use unsubscribe links in electronic communications</li>
                        <li>Update your communication preferences</li>
                        <li>Request specific types of communications only</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Information Disclosure -->
        <section class="policy-section" id="disclosure">
            <div class="container">
                <h2>Information Disclosure and Sharing</h2>
                <div class="content">
                    <h3>When We Disclose Information</h3>
                    <p>We may disclose your personal information to:</p>

                    <div class="disclosure-categories">
                        <div class="category">
                            <h4>Lenders and Credit Providers</h4>
                            <ul>
                                <li>Banks, non-bank lenders, and financial institutions</li>
                                <li>Equipment finance companies and asset funders</li>
                                <li>Commercial property lenders and developers</li>
                                <li>Alternative funding providers and private lenders</li>
                            </ul>
                        </div>

                        <div class="category">
                            <h4>Professional Service Providers</h4>
                            <ul>
                                <li>Lawyers, accountants, and financial advisers</li>
                                <li>Valuers, surveyors, and technical assessors</li>
                                <li>Insurance brokers and risk assessors</li>
                                <li>Business consultants and industry specialists</li>
                            </ul>
                        </div>

                        <div class="category">
                            <h4>Credit and Verification Services</h4>
                            <ul>
                                <li>Credit reporting bodies (Equifax, Experian, illion)</li>
                                <li>Identity verification services</li>
                                <li>Document verification and fraud prevention services</li>
                                <li>Credit reference agencies and data providers</li>
                            </ul>
                        </div>

                        <div class="category">
                            <h4>Regulatory and Government Bodies</h4>
                            <ul>
                                <li>Australian Securities and Investments Commission (ASIC)</li>
                                <li>Australian Transaction Reports and Analysis Centre (AUSTRAC)</li>
                                <li>Australian Taxation Office (ATO)</li>
                                <li>Courts and tribunals (when legally required)</li>
                            </ul>
                        </div>
                    </div>

                    <h3>Overseas Disclosure</h3>
                    <p>
                        We may disclose personal information to overseas recipients in the following circumstances:
                    </p>
                    <ul>
                        <li>Cloud storage providers (primarily US-based with Australian data sovereignty)</li>
                        <li>Software service providers for CRM and application processing</li>
                        <li>International lenders for cross-border transactions</li>
                        <li>Technology providers for AI analytics and processing</li>
                    </ul>
                    <p>
                        Before any overseas disclosure, we ensure appropriate privacy protections are in place through contractual arrangements 
                        and verification of adequate privacy laws or binding corporate rules.
                    </p>

                    <h3>Your Consent</h3>
                    <p>
                        By engaging our services, you consent to disclosure of your information to the parties listed above for the purposes 
                        of providing commercial finance brokerage services. You may withdraw consent at any time, though this may limit our 
                        ability to provide services.
                    </p>
                </div>
            </div>
        </section>

        <!-- Credit Information -->
        <section class="policy-section" id="credit">
            <div class="container">
                <h2>Credit Information Handling</h2>
                <div class="content">
                    <h3>Credit Reporting</h3>
                    <p>
                        As a licensed credit provider under the National Consumer Credit Protection Act 2009, we handle credit information 
                        in accordance with the Credit Reporting Privacy Code 2014 and Part IIIA of the Privacy Act 1988.
                    </p>

                    <h3>Credit Information We Collect</h3>
                    <ul>
                        <li>Credit reports from authorised credit reporting bodies</li>
                        <li>Credit-related personal information from applications</li>
                        <li>Repayment history information from credit providers</li>
                        <li>Credit eligibility information for assessment purposes</li>
                        <li>Default and judgment information from public records</li>
                    </ul>

                    <h3>How We Use Credit Information</h3>
                    <p>Credit information is used solely for:</p>
                    <ul>
                        <li>Assessing creditworthiness and borrowing capacity</li>
                        <li>Verifying identity and preventing fraud</li>
                        <li>Meeting responsible lending obligations</li>
                        <li>Complying with regulatory requirements</li>
                        <li>Managing credit-related risks</li>
                    </ul>

                    <h3>Credit Information Disclosure</h3>
                    <p>We may disclose credit information to:</p>
                    <ul>
                        <li>Credit providers assessing your application</li>
                        <li>Credit reporting bodies (where permitted)</li>
                        <li>Other credit providers (with consent or legal authority)</li>
                        <li>Guarantors and co-borrowers (where relevant)</li>
                        <li>Professional service providers supporting the application</li>
                        <li>Regulatory bodies (when legally required)</li>
                    </ul>

                    <div class="highlight-box">
                        <h4>Important Credit Information Rights</h4>
                        <ul>
                            <li>You have the right to access your credit information</li>
                            <li>You can request correction of inaccurate credit information</li>
                            <li>You may complain about credit information handling</li>
                            <li>You can request not to receive direct marketing based on credit eligibility</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Storage and Security -->
        <section class="policy-section" id="storage">
            <div class="container">
                <h2>Data Storage, Security, and Retention</h2>
                <div class="content">
                    <h3>Data Security Measures</h3>
                    <p>We implement comprehensive security measures to protect your personal information:</p>
                    
                    <div class="security-measures">
                        <div class="measure">
                            <h4>Technical Safeguards</h4>
                            <ul>
                                <li>End-to-end encryption for data transmission</li>
                                <li>Secure cloud storage with Australian data sovereignty</li>
                                <li>Multi-factor authentication for system access</li>
                                <li>Regular security audits and penetration testing</li>
                                <li>Automated backup and disaster recovery systems</li>
                            </ul>
                        </div>
                        
                        <div class="measure">
                            <h4>Physical Security</h4>
                            <ul>
                                <li>Secure office premises with access controls</li>
                                <li>Locked filing cabinets for paper documents</li>
                                <li>Secure disposal of sensitive documents</li>
                                <li>Restricted access to server and storage areas</li>
                            </ul>
                        </div>
                        
                        <div class="measure">
                            <h4>Administrative Controls</h4>
                            <ul>
                                <li>Staff privacy training and confidentiality agreements</li>
                                <li>Role-based access controls and regular review</li>
                                <li>Incident response and breach notification procedures</li>
                                <li>Regular policy review and updates</li>
                            </ul>
                        </div>
                    </div>

                    <h3>Data Retention</h3>
                    <p>We retain personal information for the following periods:</p>
                    <ul>
                        <li><strong>Active Client Records:</strong> Duration of the relationship plus 5 years</li>
                        <li><strong>Loan Applications:</strong> 7 years from application date (regulatory requirement)</li>
                        <li><strong>Credit Information:</strong> As required by Credit Reporting Privacy Code</li>
                        <li><strong>Financial Records:</strong> 7 years (taxation and corporations law requirements)</li>
                        <li><strong>Marketing Information:</strong> Until consent is withdrawn or 3 years of inactivity</li>
                        <li><strong>Complaint Records:</strong> 7 years from resolution</li>
                    </ul>

                    <h3>Data Destruction</h3>
                    <p>
                        When personal information is no longer required, we securely destroy or de-identify it using appropriate methods 
                        including secure deletion of electronic files and destruction of physical documents.
                    </p>

                    <h3>Data Breach Response</h3>
                    <p>
                        In the event of a data breach that is likely to result in serious harm, we will:
                    </p>
                    <ul>
                        <li>Notify affected individuals as soon as practicable</li>
                        <li>Report to the Office of the Australian Information Commissioner (OAIC)</li>
                        <li>Take immediate steps to contain and assess the breach</li>
                        <li>Implement remedial actions to prevent future breaches</li>
                        <li>Provide regular updates on the investigation and resolution</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Your Rights -->
        <section class="policy-section" id="rights">
            <div class="container">
                <h2>Your Privacy Rights</h2>
                <div class="content">
                    <h3>Access Rights (APP 12)</h3>
                    <p>You have the right to:</p>
                    <ul>
                        <li>Request access to your personal information we hold</li>
                        <li>Receive a copy of your personal information in a usable format</li>
                        <li>Understand how your information is being used and disclosed</li>
                        <li>Access your credit information subject to credit reporting requirements</li>
                    </ul>
                    <p>
                        We will respond to access requests within 30 days. Some information may not be accessible due to legal privileges, 
                        commercial sensitivity, or third-party privacy rights.
                    </p>

                    <h3>Correction Rights (APP 13)</h3>
                    <p>You can request correction of personal information that is:</p>
                    <ul>
                        <li>Inaccurate, out-of-date, incomplete, or misleading</li>
                        <li>Inconsistent with information held by other organisations</li>
                        <li>No longer relevant for the purposes for which it was collected</li>
                    </ul>
                    <p>
                        We will correct information within a reasonable timeframe and notify relevant third parties where appropriate.
                    </p>

                    <h3>Opt-Out Rights</h3>
                    <p>You may:</p>
                    <ul>
                        <li>Opt out of direct marketing communications</li>
                        <li>Request not to receive pre-approved credit offers</li>
                        <li>Withdraw consent for specific uses of your information</li>
                        <li>Request deletion of information where legally permissible</li>
                    </ul>

                    <h3>How to Exercise Your Rights</h3>
                    <p>To exercise your privacy rights:</p>
                    <ol>
                        <li>Contact our Privacy Officer using the details below</li>
                        <li>Provide sufficient information to verify your identity</li>
                        <li>Specify clearly what you are requesting</li>
                        <li>Allow reasonable time for processing (usually 30 days)</li>
                    </ol>

                    <div class="highlight-box">
                        <h4>Important Note on Regulatory Requirements</h4>
                        <p>
                            Some information must be retained for regulatory compliance (AML/CTF, taxation, corporations law). 
                            In these cases, we may not be able to delete or modify information but can restrict its use to compliance purposes only.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Complaints Process -->
        <section class="policy-section" id="complaints">
            <div class="container">
                <h2>Privacy Complaints Process</h2>
                <div class="content">
                    <h3>Making a Complaint</h3>
                    <p>
                        If you believe we have breached your privacy or handled your personal information inappropriately, 
                        you can lodge a complaint with us directly.
                    </p>

                    <h3>Complaint Process</h3>
                    <div class="process-steps">
                        <div class="step">
                            <div class="step-number">1</div>
                            <div class="step-content">
                                <h4>Submit Your Complaint</h4>
                                <p>Contact our Privacy Officer in writing with details of your concern, including:</p>
                                <ul>
                                    <li>Your contact information</li>
                                    <li>Description of the privacy concern</li>
                                    <li>When the incident occurred</li>
                                    <li>What outcome you are seeking</li>
                                </ul>
                            </div>
                        </div>
                        
                        <div class="step">
                            <div class="step-number">2</div>
                            <div class="step-content">
                                <h4>Acknowledgment</h4>
                                <p>We will acknowledge your complaint within 7 days and provide:</p>
                                <ul>
                                    <li>Confirmation of receipt</li>
                                    <li>Reference number for tracking</li>
                                    <li>Expected timeframe for resolution</li>
                                </ul>
                            </div>
                        </div>
                        
                        <div class="step">
                            <div class="step-number">3</div>
                            <div class="step-content">
                                <h4>Investigation</h4>
                                <p>We will investigate your complaint by:</p>
                                <ul>
                                    <li>Reviewing relevant records and policies</li>
                                    <li>Consulting with relevant staff members</li>
                                    <li>Seeking additional information if required</li>
                                    <li>Determining appropriate remedial action</li>
                                </ul>
                            </div>
                        </div>
                        
                        <div class="step">
                            <div class="step-number">4</div>
                            <div class="step-content">
                                <h4>Resolution</h4>
                                <p>We will provide a written response within 30 days including:</p>
                                <ul>
                                    <li>Outcome of the investigation</li>
                                    <li>Actions taken to address the complaint</li>
                                    <li>Changes made to prevent future issues</li>
                                    <li>Your right to escalate if unsatisfied</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <h3>External Complaint Options</h3>
                    <p>If you are not satisfied with our response, you may lodge a complaint with:</p>
                    
                    <div class="external-options">
                        <div class="option">
                            <h4>Office of the Australian Information Commissioner (OAIC)</h4>
                            <p><strong>Website:</strong> www.oaic.gov.au</p>
                            <p><strong>Phone:</strong> 1300 363 992</p>
                            <p><strong>Email:</strong> enquiries@oaic.gov.au</p>
                            <p>For privacy-related complaints under the Privacy Act 1988</p>
                        </div>
                        
                        <div class="option">
                            <h4>Australian Financial Complaints Authority (AFCA)</h4>
                            <p><strong>Website:</strong> www.afca.org.au</p>
                            <p><strong>Phone:</strong> 1800 931 678</p>
                            <p><strong>Email:</strong> info@afca.org.au</p>
                            <p>For credit-related privacy complaints and financial service disputes</p>
                        </div>
                        
                        <div class="option">
                            <h4>Australian Securities and Investments Commission (ASIC)</h4>
                            <p><strong>Website:</strong> www.asic.gov.au</p>
                            <p><strong>Phone:</strong> 1300 300 630</p>
                            <p>For complaints about our licensing and regulatory compliance</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Updates and Changes -->
        <section class="policy-section" id="updates">
            <div class="container">
                <h2>Policy Updates and Changes</h2>
                <div class="content">
                    <h3>Policy Review</h3>
                    <p>
                        We review this Privacy Policy annually or when there are significant changes to our practices, 
                        the law, or our business operations. The next scheduled review is {reviewDate}.
                    </p>

                    <h3>Notification of Changes</h3>
                    <p>We will notify you of material changes by:</p>
                    <ul>
                        <li>Publishing the updated policy on our website</li>
                        <li>Sending direct notifications to active clients</li>
                        <li>Highlighting changes in our next communication</li>
                        <li>Providing reasonable notice before changes take effect</li>
                    </ul>

                    <h3>Version Control</h3>
