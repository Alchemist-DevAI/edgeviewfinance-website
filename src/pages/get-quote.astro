    <script>
        // Progressive disclosure for finance type specific fields
        function toggleFinanceFields() {
            const financeType = document.getElementById('finance-type').value;
            const equipmentDetails = document.getElementById('equipment-details');
            const propertyDetails = document.getElementById('property-details');
            
            // Hide all conditional sections first
            equipmentDetails.style.display = 'none';
            propertyDetails.style.display = 'none';
            
            // Show relevant section based on selection
            if (financeType === 'equipment') {
                equipmentDetails.style.display = 'block';
            } else if (financeType === 'property') {
                propertyDetails.style.display = 'block';
            }
        }
        
        // Form validation and submission
        document.getElementById('quoteForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            // Basic client-side validation
            const requiredFields = this.querySelectorAll('[required]');
            let allValid = true;
            
            requiredFields.forEach(field => {
                if (!field.value.trim()) {
                    allValid = false;
                    field.style.borderColor = '#e74c3c';
                } else {
                    field.style.borderColor = '#27ae60';
                }
            });
            
            if (allValid) {
                // Show loading state
                const submitButton = this.querySelector('button[type="submit"]');
                submitButton.textContent = 'Submitting Request...';
                submitButton.disabled = true;
                
                // Here you would normally submit to your backend
                // For now, we'll simulate a successful submission
                setTimeout(() => {
                    alert('Thank you for your quote request! A licensed finance professional will contact you within 24 hours.');
                    submitButton.textContent = 'Request Professional Quote';
                    submitButton.disabled = false;
                }, 2000);
            } else {
                alert('Please complete all required fields before submitting your quote request.');
            }
        });
        
        // Enhanced form interactions
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-format ABN field
            const abnField = document.getElementById('abn');
            if (abnField) {
                abnField.addEventListener('input', function(e) {
                    let value = e.target.value.replace(/\D/g, '');
                    if (value.length > 0) {
                        value = value.replace(/(\d{2})(\d{3})(\d{3})(\d{3})/, '$1 $2 $3 $4');
                    }
                    e.target.value = value;
                });
            }
            
            // Phone number formatting
            const phoneField = document.getElementById('phone');
            if (phoneField) {
                phoneField.addEventListener('input', function(e) {
                    let value = e.target.value.replace(/\D/g, '');
                    if (value.length > 0) {
                        if (value.startsWith('04')) {
                            value = value.replace(/(\d{4})(\d{3})(\d{3})/, '$1 $2 $3');
                        } else if (value.length >= 8) {
                            value = value.replace(/(\d{2})(\d{4})(\d{4})/, '$1 $2 $3');
                        }
                    }
                    e.target.value = value;
                });
            }
            
            // Progressive enhancement for form sections
            const formSections = document.querySelectorAll('.form-section');
            formSections.forEach((section, index) => {
                section.style.animationDelay = (index * 0.1) + 's';
                section.classList.add('fade-in');
            });
        });
    </script>
