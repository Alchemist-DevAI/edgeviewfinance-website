---
import Agency11Layout from '../layouts/Agency11Layout.astro';

const pageTitle = 'Get Quote | Commercial Finance Assessment | EVFBS Australia';
const pageDescription = 'Request a professional commercial finance quote from licensed Australian brokers. Comprehensive assessment for equipment finance, commercial property, working capital, and business loans tailored for Australian commercial trades.';

const financeTypes = [
  'Equipment Finance',
  'Commercial Property',
  'Working Capital',
  'Invoice Financing',
  'Business Acquisition',
  'Asset Refinance'
];

const loanAmounts = [
  'Under $50,000',
  '$50,000 - $100,000',
  '$100,000 - $250,000',
  '$250,000 - $500,000',
  '$500,000 - $1M',
  '$1M - $2M',
  'Over $2M'
];

const industries = [
  'Construction & Trades',
  'Civil Contracting',
  'Transport & Logistics',
  'Manufacturing',
  'Healthcare & Medical',
  'Professional Services',
  'Retail & Hospitality',
  'Agriculture',
  'Mining & Resources',
  'Technology',
  'Other'
];
---

<Agency11Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="section-hero bg-gradient-to-br from-brand-primary to-brand-primary-dark text-white">
    <div class="container-default">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="heading-primary text-white mb-6">
          Get Your Finance Quote
        </h1>
        <p class="body-large text-brand-grey-100 mb-8">
          Professional assessment and tailored solutions in 24 hours
        </p>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>No obligation</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>40+ Lenders</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Expert advice</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote Form Section -->
  <section class="section-content">
    <div class="container-default">
      <div class="max-w-3xl mx-auto">
        <form id="quote-form" class="bg-white rounded-2xl shadow-xl p-8 lg:p-12">
          
          <!-- Finance Details Section -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-6">Finance Details</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="finance-type" class="form-label">Finance Type *</label>
                <select id="finance-type" name="finance_type" class="form-input" required>
                  <option value="">Select finance type</option>
                  {financeTypes.map((type) => (
                    <option value={type.toLowerCase().replace(/\s+/g, '-')}>{type}</option>
                  ))}
                </select>
              </div>
              
              <div>
                <label for="loan-amount" class="form-label">Loan Amount Required *</label>
                <select id="loan-amount" name="loan_amount" class="form-input" required>
                  <option value="">Select amount range</option>
                  {loanAmounts.map((amount) => (
                    <option value={amount}>{amount}</option>
                  ))}
                </select>
              </div>
              
              <div>
                <label for="urgency" class="form-label">When do you need funding? *</label>
                <select id="urgency" name="urgency" class="form-input" required>
                  <option value="">Select timeframe</option>
                  <option value="asap">ASAP</option>
                  <option value="1-week">Within 1 week</option>
                  <option value="2-weeks">Within 2 weeks</option>
                  <option value="1-month">Within 1 month</option>
                  <option value="2-months">Within 2 months</option>
                  <option value="planning">Just planning</option>
                </select>
              </div>
              
              <div>
                <label for="asset-details" class="form-label">Asset/Purpose Details</label>
                <input 
                  type="text" 
                  id="asset-details" 
                  name="asset_details"
                  class="form-input"
                  placeholder="e.g., Excavator, warehouse, working capital"
                />
              </div>
            </div>
          </div>

          <!-- Business Information Section -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-6">Business Information</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="business-name" class="form-label">Business Name *</label>
                <input 
                  type="text" 
                  id="business-name" 
                  name="business_name"
                  class="form-input"
                  required
                />
              </div>
              
              <div>
                <label for="abn" class="form-label">ABN</label>
                <input 
                  type="text" 
                  id="abn" 
                  name="abn"
                  class="form-input"
                  placeholder="XX XXX XXX XXX"
                />
              </div>
              
              <div>
                <label for="industry" class="form-label">Industry *</label>
                <select id="industry" name="industry" class="form-input" required>
                  <option value="">Select industry</option>
                  {industries.map((industry) => (
                    <option value={industry.toLowerCase().replace(/\s+/g, '-')}>{industry}</option>
                  ))}
                </select>
              </div>
              
              <div>
                <label for="years-trading" class="form-label">Years Trading *</label>
                <select id="years-trading" name="years_trading" class="form-input" required>
                  <option value="">Select years</option>
                  <option value="startup">Start-up (less than 1 year)</option>
                  <option value="1-2">1-2 years</option>
                  <option value="2-5">2-5 years</option>
                  <option value="5-10">5-10 years</option>
                  <option value="10+">10+ years</option>
                </select>
              </div>
              
              <div>
                <label for="annual-revenue" class="form-label">Annual Revenue</label>
                <select id="annual-revenue" name="annual_revenue" class="form-input">
                  <option value="">Select revenue range</option>
                  <option value="under-500k">Under $500K</option>
                  <option value="500k-1m">$500K - $1M</option>
                  <option value="1m-2m">$1M - $2M</option>
                  <option value="2m-5m">$2M - $5M</option>
                  <option value="5m-10m">$5M - $10M</option>
                  <option value="over-10m">Over $10M</option>
                </select>
              </div>
              
              <div>
                <label for="business-structure" class="form-label">Business Structure</label>
                <select id="business-structure" name="business_structure" class="form-input">
                  <option value="">Select structure</option>
                  <option value="sole-trader">Sole Trader</option>
                  <option value="partnership">Partnership</option>
                  <option value="company">Company</option>
                  <option value="trust">Trust</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Contact Information Section -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-6">Contact Information</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="first-name" class="form-label">First Name *</label>
                <input 
                  type="text" 
                  id="first-name" 
                  name="first_name"
                  class="form-input"
                  required
                />
              </div>
              
              <div>
                <label for="last-name" class="form-label">Last Name *</label>
                <input 
                  type="text" 
                  id="last-name" 
                  name="last_name"
                  class="form-input"
                  required
                />
              </div>
              
              <div>
                <label for="email" class="form-label">Email *</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email"
                  class="form-input"
                  required
                />
              </div>
              
              <div>
                <label for="phone" class="form-label">Phone *</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone"
                  class="form-input"
                  placeholder="04XX XXX XXX"
                  required
                />
              </div>
              
              <div>
                <label for="state" class="form-label">State *</label>
                <select id="state" name="state" class="form-input" required>
                  <option value="">Select state</option>
                  <option value="nsw">New South Wales</option>
                  <option value="vic">Victoria</option>
                  <option value="qld">Queensland</option>
                  <option value="wa">Western Australia</option>
                  <option value="sa">South Australia</option>
                  <option value="tas">Tasmania</option>
                  <option value="act">ACT</option>
                  <option value="nt">Northern Territory</option>
                </select>
              </div>
              
              <div>
                <label for="postcode" class="form-label">Postcode</label>
                <input 
                  type="text" 
                  id="postcode" 
                  name="postcode"
                  class="form-input"
                  maxlength="4"
                />
              </div>
            </div>
          </div>

          <!-- Additional Information -->
          <div class="mb-10">
            <h2 class="heading-tertiary text-brand-primary mb-6">Additional Information</h2>
            
            <div class="space-y-6">
              <div>
                <label for="message" class="form-label">Tell us more about your requirements</label>
                <textarea 
                  id="message" 
                  name="message"
                  rows="4"
                  class="form-input"
                  placeholder="Please provide any additional details about your finance needs, specific equipment, or questions you have..."
                ></textarea>
              </div>
              
              <div class="flex items-start gap-3">
                <input 
                  type="checkbox" 
                  id="consent" 
                  name="consent"
                  class="mt-1"
                  required
                />
                <label for="consent" class="text-sm text-brand-grey-700">
                  I consent to Edgeview Finance contacting me about my finance enquiry and understand that my information will be handled in accordance with the <a href="/privacy" class="text-brand-accent underline">Privacy Policy</a>. *
                </label>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <button type="submit" class="btn-primary btn-large">
              Get My Quote
            </button>
            <a href="/calculator" class="btn-secondary btn-large">
              Try Calculator First
            </a>
          </div>
        </form>

        <!-- Trust Indicators -->
        <div class="mt-12 text-center">
          <div class="flex flex-wrap justify-center gap-8 items-center">
            <div class="flex items-center gap-2">
              <svg class="w-6 h-6 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-brand-grey-700">Secure & Confidential</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-6 h-6 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
              </svg>
              <span class="text-brand-grey-700">Expert Support</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-6 h-6 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
              </svg>
              <span class="text-brand-grey-700">24 Hour Response</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.getElementById('quote-form')?.addEventListener('submit', function(e) {
      e.preventDefault();
      // Form submission logic would go here
      alert('Thank you for your enquiry! We will contact you within 24 hours.');
    });
  </script>
</Agency11Layout>