---
// EVFBS Get Quote Page - Professional Commercial Finance Quote Request
// Optimized for "Ben the Business Builder" ICP with comprehensive assessment form
export const prerender = true;

const siteData = {
  title: "Get Quote | Commercial Finance Assessment | EVFBS Australia",
  description: "Request a professional commercial finance quote from licensed Australian brokers. Comprehensive assessment for equipment finance, commercial property, working capital, and business loans tailored for Australian commercial trades.",
  keywords: "commercial finance quote Australia, equipment finance quote, business loan assessment, trade finance quote, working capital quote, commercial property finance assessment"
};
---

<html lang="en-AU">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteData.description} />
    <meta name="keywords" content={siteData.keywords} />
    
    <!-- Quote Request Page Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "@id": "https://edgeviewfinance.com.au/get-quote#webpage",
      "name": "Commercial Finance Quote Request",
      "description": "Professional commercial finance quote request and assessment form",
      "url": "https://edgeviewfinance.com.au/get-quote",
      "mainEntity": {
        "@type": "Service",
        "@id": "https://edgeviewfinance.com.au/#quote-service",
        "name": "Commercial Finance Quote Service",
        "description": "Comprehensive commercial finance assessment and quote generation for Australian commercial trades and service businesses",
        "provider": {
          "@type": "FinancialService",
          "@id": "https://edgeviewfinance.com.au/#organization",
          "name": "Edgeview Finance Business Solutions",
          "alternateName": "EVFBS",
          "description": "Licensed Australian finance broker specializing in commercial finance for trades and service businesses",
          "url": "https://edgeviewfinance.com.au",
          "serviceType": "Commercial Finance Brokerage",
          "areaServed": {
            "@type": "Country",
            "name": "Australia"
          },
          "hasCredential": {
            "@type": "EducationalOccupationalCredential",
            "credentialCategory": "Australian Credit Licence",
            "recognizedBy": {
              "@type": "Organization",
              "name": "Australian Securities and Investments Commission",
              "alternateName": "ASIC"
            }
          }
        },
        "serviceType": "Quote Generation Service",
        "areaServed": {
          "@type": "Country",
          "name": "Australia"
        },
        "audience": {
          "@type": "BusinessAudience",
          "audienceType": "Commercial Trades and Service Businesses"
        }
      },
      "potentialAction": {
        "@type": "ConsumeAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://edgeviewfinance.com.au/get-quote",
          "inLanguage": "en-AU",
          "actionPlatform": [
            "http://schema.org/DesktopWebPlatform",
            "http://schema.org/MobileWebPlatform"
          ]
        },
        "expectsAcceptanceOf": {
          "@type": "Offer",
          "description": "Professional commercial finance assessment and quote generation"
        }
      }
    }
    </script>
    
    <!-- Open Graph for Social Sharing -->
    <meta property="og:title" content={siteData.title} />
    <meta property="og:description" content={siteData.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://edgeviewfinance.com.au/get-quote" />
    <meta property="og:locale" content="en_AU" />
    
    <title>{siteData.title}</title>
</head>
<body>
    <header>
        <nav>
            <div class="nav-container">
                <div class="logo">
                    <h1>Edgeview Finance</h1>
                    <span>Business Solutions</span>
                </div>
                <ul class="nav-menu">
                    <li><a href="/">Home</a></li>
                    <li><a href="/services">Services</a></li>
                    <li><a href="/equipment-finance">Equipment Finance</a></li>
                    <li><a href="/working-capital">Working Capital</a></li>
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact" class="cta-button">Expert Consultation</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main>
        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <h1>Get Your Professional Commercial Finance Quote</h1>
                <p class="hero-subtitle">
                    Secure strategic finance solutions tailored for your commercial business. Complete our comprehensive assessment 
                    for personalised quotes on equipment finance, commercial property, working capital, and business growth solutions.
                </p>
                <div class="trust-indicators">
                    <span>✓ Licensed Australian Finance Broker</span>
                    <span>✓ ASIC Compliant Service</span>
                    <span>✓ Confidential Assessment Process</span>
                </div>
            </div>
        </section>

        <!-- Process Overview -->
        <section class="process-overview">
            <div class="container">
                <h2>Professional Assessment Process</h2>
                <div class="process-grid">
                    <div class="process-step">
                        <div class="step-number">1</div>
                        <h3>Complete Assessment</h3>
                        <p>Provide your business and finance requirements through our comprehensive assessment form.</p>
                    </div>
                    <div class="process-step">
                        <div class="step-number">2</div>
                        <h3>Professional Analysis</h3>
                        <p>Licensed finance brokers analyse your requirements and assess optimal finance solutions.</p>
                    </div>
                    <div class="process-step">
                        <div class="step-number">3</div>
                        <h3>Strategic Recommendations</h3>
                        <p>Receive personalised quotes with strategic guidance and transparent terms within 24 hours.</p>
                    </div>
                    <div class="process-step">
                        <div class="step-number">4</div>
                        <h3>Partnership Support</h3>
                        <p>Ongoing professional support through application, approval, and settlement processes.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Quote Request Form -->
        <section class="quote-form">
            <div class="container">
                <div class="form-header">
                    <h2>Commercial Finance Quote Request Form</h2>
                    <p>Complete this comprehensive assessment to receive personalised commercial finance quotes. All information is treated confidentially and assessed by licensed Australian finance professionals.</p>
                </div>
                
                <form class="assessment-form" action="/submit-quote-request" method="POST" id="quoteForm">
                    <!-- Business Details Section -->
                    <div class="form-section">
                        <h3>Business Details</h3>
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="business-name">Business Name *</label>
                                <input type="text" id="business-name" name="businessName" required>
                            </div>
                            <div class="form-group">
                                <label for="abn">Australian Business Number (ABN)</label>
                                <input type="text" id="abn" name="abn" placeholder="XX XXX XXX XXX" pattern="[0-9\s]*">
                            </div>
                            <div class="form-group">
                                <label for="industry">Industry Type *</label>
                                <select id="industry" name="industry" required>
                                    <option value="">Select your industry</option>
                                    <option value="commercial-trades">Commercial Trades (Electrical, Plumbing, HVAC)</option>
                                    <option value="civil-contractors">Civil Contractors (Earthmoving, Infrastructure)</option>
                                    <option value="transport-logistics">Transport & Logistics</option>
                                    <option value="manufacturing">Manufacturing & Fabrication</option>
                                    <option value="construction-services">Construction Services</option>
                                    <option value="industrial-services">Industrial Services</option>
                                    <option value="mining-support">Mining Support Services</option>
                                    <option value="agricultural-services">Agricultural Services</option>
                                    <option value="other-commercial">Other Commercial Service</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="years-operation">Years in Operation *</label>
                                <select id="years-operation" name="yearsOperation" required>
                                    <option value="">Select years</option>
                                    <option value="startup">Startup (Less than 1 year)</option>
                                    <option value="1-2">1-2 years</option>
                                    <option value="3-5">3-5 years</option>
                                    <option value="5-10">5-10 years</option>
                                    <option value="10-20">10-20 years</option>
                                    <option value="20+">20+ years</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="business-structure">Business Structure *</label>
                                <select id="business-structure" name="businessStructure" required>
                                    <option value="">Select structure</option>
                                    <option value="sole-trader">Sole Trader</option>
                                    <option value="partnership">Partnership</option>
                                    <option value="company">Company (Pty Ltd)</option>
                                    <option value="trust">Trust</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="employees">Number of Employees</label>
                                <select id="employees" name="employees">
                                    <option value="">Select employee count</option>
                                    <option value="1">1 (Just me)</option>
                                    <option value="2-5">2-5 employees</option>
                                    <option value="6-10">6-10 employees</option>
                                    <option value="11-20">11-20 employees</option>
                                    <option value="21-50">21-50 employees</option>
                                    <option value="50+">50+ employees</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Contact Information Section -->
                    <div class="form-section">
                        <h3>Contact Information</h3>
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="contact-name">Your Name *</label>
                                <input type="text" id="contact-name" name="contactName" required>
                            </div>
                            <div class="form-group">
                                <label for="position">Position/Role *</label>
                                <input type="text" id="position" name="position" placeholder="e.g., Owner, Director, Financial Manager" required>
                            </div>
                            <div class="form-group">
                                <label for="phone">Phone Number *</label>
                                <input type="tel" id="phone" name="phone" placeholder="04XX XXX XXX" required>
                            </div>
                            <div class="form-group">
                                <label for="email">Email Address *</label>
                                <input type="email" id="email" name="email" required>
                            </div>
                            <div class="form-group">
                                <label for="state">State/Territory *</label>
                                <select id="state" name="state" required>
                                    <option value="">Select state</option>
                                    <option value="NSW">New South Wales</option>
                                    <option value="VIC">Victoria</option>
                                    <option value="QLD">Queensland</option>
                                    <option value="WA">Western Australia</option>
                                    <option value="SA">South Australia</option>
                                    <option value="TAS">Tasmania</option>
                                    <option value="NT">Northern Territory</option>
                                    <option value="ACT">Australian Capital Territory</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="suburb">Suburb/City *</label>
                                <input type="text" id="suburb" name="suburb" required>
                            </div>
                        </div>
                    </div>

                    <!-- Finance Type Selection -->
                    <div class="form-section">
                        <h3>Finance Requirements</h3>
                        <div class="finance-type-selection">
                            <label for="finance-type">Finance Type Required *</label>
                            <select id="finance-type" name="financeType" required onchange="toggleFinanceFields()">
                                <option value="">Select finance type</option>
                                <option value="equipment">Equipment Finance</option>
                                <option value="property">Commercial Property Finance</option>
                                <option value="working-capital">Working Capital Solutions</option>
                                <option value="invoice">Invoice Financing</option>
                                <option value="personal">Personal Home Lending</option>
                                <option value="multiple">Multiple Finance Solutions</option>
                                <option value="unsure">Unsure - Need Guidance</option>
                            </select>
                        </div>
                        
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="loan-amount">Loan Amount Required *</label>
                                <select id="loan-amount" name="loanAmount" required>
                                    <option value="">Select amount range</option>
                                    <option value="20k-50k">$20,000 - $50,000</option>
                                    <option value="50k-100k">$50,000 - $100,000</option>
                                    <option value="100k-250k">$100,000 - $250,000</option>
                                    <option value="250k-500k">$250,000 - $500,000</option>
                                    <option value="500k-1m">$500,000 - $1,000,000</option>
                                    <option value="1m-2m">$1,000,000 - $2,000,000</option>
                                    <option value="2m+">$2,000,000+</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="loan-term">Preferred Loan Term</label>
                                <select id="loan-term" name="loanTerm">
                                    <option value="">Select term preference</option>
                                    <option value="1-2-years">1-2 years</option>
                                    <option value="3-5-years">3-5 years</option>
                                    <option value="5-7-years">5-7 years</option>
                                    <option value="7-10-years">7-10 years</option>
                                    <option value="10-15-years">10-15 years</option>
                                    <option value="15-25-years">15-25 years</option>
                                    <option value="25-30-years">25-30 years</option>
                                    <option value="flexible">Flexible - Advise optimal term</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="timeframe">Required Timeframe *</label>
                                <select id="timeframe" name="timeframe" required>
                                    <option value="">Select timeframe</option>
                                    <option value="immediate">Immediate (Within 2 weeks)</option>
                                    <option value="1-month">Within 1 month</option>
                                    <option value="1-3-months">1-3 months</option>
                                    <option value="3-6-months">3-6 months</option>
                                    <option value="planning">Strategic planning phase</option>
                                </select>
                            </div>
                            <div class="form-group full-width">
                                <label for="purpose">Purpose of Finance *</label>
                                <textarea id="purpose" name="purpose" rows="3" placeholder="Describe what the finance will be used for (e.g., purchase excavator for business expansion, acquire commercial premises, improve cash flow for large contracts)" required></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Equipment/Property Details (Conditional) -->
                    <div class="form-section conditional-section" id="equipment-details" style="display: none;">
                        <h3>Equipment Details</h3>
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="equipment-type">Equipment Type</label>
                                <select id="equipment-type" name="equipmentType">
                                    <option value="">Select equipment type</option>
                                    <option value="excavators">Excavators & Earthmoving</option>
                                    <option value="trucks">Trucks & Commercial Vehicles</option>
                                    <option value="cranes">Cranes & Lifting Equipment</option>
                                    <option value="manufacturing">Manufacturing Equipment</option>
                                    <option value="construction">Construction Tools & Machinery</option>
                                    <option value="agricultural">Agricultural Equipment</option>
                                    <option value="mining">Mining Equipment</option>
                                    <option value="technology">Technology & IT Equipment</option>
                                    <option value="other">Other Equipment</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="equipment-condition">Equipment Condition</label>
                                <select id="equipment-condition" name="equipmentCondition">
                                    <option value="">Select condition</option>
                                    <option value="new">New Equipment</option>
                                    <option value="used">Used Equipment</option>
                                    <option value="refurbished">Refurbished Equipment</option>
                                    <option value="mixed">Mix of New and Used</option>
                                </select>
                            </div>
                            <div class="form-group full-width">
                                <label for="equipment-description">Equipment Description</label>
                                <textarea id="equipment-description" name="equipmentDescription" rows="2" placeholder="Please describe the specific equipment you plan to finance (make, model, year if known)"></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="form-section conditional-section" id="property-details" style="display: none;">
                        <h3>Commercial Property Details</h3>
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="property-type">Property Type</label>
                                <select id="property-type" name="propertyType">
                                    <option value="">Select property type</option>
                                    <option value="warehouse">Warehouse/Industrial</option>
                                    <option value="office">Office Building</option>
                                    <option value="retail">Retail/Shopfront</option>
                                    <option value="workshop">Workshop/Factory</option>
                                    <option value="mixed-use">Mixed Use Property</option>
                                    <option value="development">Development Site</option>
                                    <option value="other">Other Commercial Property</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="property-purpose">Property Purpose</label>
                                <select id="property-purpose" name="propertyPurpose">
                                    <option value="">Select purpose</option>
                                    <option value="owner-occupy">Owner Occupier (Business Use)</option>
                                    <option value="investment">Investment Property</option>
                                    <option value="development">Property Development</option>
                                    <option value="refinance">Refinance Existing Property</option>
                                </select>
                            </div>
                            <div class="form-group full-width">
                                <label for="property-description">Property Description & Location</label>
                                <textarea id="property-description" name="propertyDescription" rows="2" placeholder="Please describe the property and its location (suburb/region if identified)"></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Business Financial Overview -->
                    <div class="form-section">
                        <h3>Business Financial Overview</h3>
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="annual-revenue">Annual Revenue (Approximate) *</label>
                                <select id="annual-revenue" name="annualRevenue" required>
                                    <option value="">Select revenue range</option>
                                    <option value="under-250k">Under $250,000</option>
                                    <option value="250k-500k">$250,000 - $500,000</option>
                                    <option value="500k-1m">$500,000 - $1,000,000</option>
                                    <option value="1m-2m">$1,000,000 - $2,000,000</option>
                                    <option value="2m-5m">$2,000,000 - $5,000,000</option>
                                    <option value="5m-10m">$5,000,000 - $10,000,000</option>
                                    <option value="10m+">$10,000,000+</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="profit-margin">Approximate Profit Margin</label>
                                <select id="profit-margin" name="profitMargin">
                                    <option value="">Select profit margin</option>
                                    <option value="under-10">Under 10%</option>
                                    <option value="10-20">10-20%</option>
                                    <option value="20-30">20-30%</option>
                                    <option value="30-40">30-40%</option>
                                    <option value="40+">40%+</option>
                                    <option value="unsure">Unsure</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="current-debts">Existing Business Debts</label>
                                <select id="current-debts" name="currentDebts">
                                    <option value="">Select debt level</option>
                                    <option value="none">No existing business debts</option>
                                    <option value="minimal">Minimal debts (Under $50K)</option>
                                    <option value="moderate">Moderate debts ($50K-$200K)</option>
                                    <option value="significant">Significant debts ($200K-$500K)</option>
                                    <option value="substantial">Substantial debts ($500K+)</option>
                                    <option value="refinancing">Looking to refinance existing debts</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="security-available">Security Available</label>
                                <select id="security-available" name="securityAvailable">
                                    <option value="">Select security type</option>
                                    <option value="residential-property">Residential property available</option>
                                    <option value="commercial-property">Commercial property available</option>
                                    <option value="equipment-assets">Equipment/business assets</option>
                                    <option value="cash-deposit">Cash deposit available</option>
                                    <option value="multiple-assets">Multiple asset types</option>
                                    <option value="unsecured">Prefer unsecured finance</option>
                                    <option value="unsure">Unsure what's available</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="gst-registered">GST Registration Status</label>
                                <select id="gst-registered" name="gstRegistered">
                                    <option value="">Select GST status</option>
                                    <option value="yes">Yes - GST Registered</option>
                                    <option value="no">No - Not GST Registered</option>
                                    <option value="pending">Pending GST Registration</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="accountant-prepared">Accounts Prepared By</label>
                                <select id="accountant-prepared" name="accountantPrepared">
                                    <option value="">Select option</option>
                                    <option value="qualified-accountant">Qualified Accountant</option>
                                    <option value="bookkeeper">Bookkeeper</option>
                                    <option value="self-prepared">Self-Prepared</option>
                                    <option value="accounting-software">Accounting Software (Xero, MYOB, etc.)</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Preferred Contact Method -->
                    <div class="form-section">
                        <h3>Contact Preferences</h3>
                        <div class="contact-preferences">
                            <label class="radio-group">
                                <input type="radio" name="contactPreference" value="phone" checked>
                                <span>Phone call (fastest response)</span>
                            </label>
                            <label class="radio-group">
                                <input type="radio" name="contactPreference" value="email">
                                <span>Email with detailed quote and recommendations</span>
                            </label>
                            <label class="radio-group">
                                <input type="radio" name="contactPreference" value="both">
                                <span>Both phone and email</span>
                            </label>
                        </div>
                        
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="best-time">Best Time to Contact</label>
                                <select id="best-time" name="bestTime">
                                    <option value="">Select preferred time</option>
                                    <option value="early-morning">Early Morning (7AM-9AM)</option>
                                    <option value="morning">Morning (9AM-12PM)</option>
                                    <option value="afternoon">Afternoon (12PM-5PM)</option>
                                    <option value="evening">Early Evening (5PM-7PM)</option>
                                    <option value="anytime">Anytime during business hours</option>
                                </select>
                            </div>
                            <div class="form-group full-width">
                                <label for="additional-info">Additional Information</label>
                                <textarea id="additional-info" name="additionalInfo" rows="4" placeholder="Any additional information about your business, specific finance requirements, current challenges, or questions you'd like addressed in your quote..."></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Privacy & Submit -->
                    <div class="form-footer">
                        <div class="privacy-notice">
                            <label class="checkbox-group">
                                <input type="checkbox" name="privacyConsent" required>
                                <span>I consent to EVFBS collecting and using my information for quote generation and assessment purposes. All information will be treated confidentially in accordance with our <a href="/privacy" target="_blank">Privacy Policy</a> *</span>
                            </label>
                            <label class="checkbox-group">
                                <input type="checkbox" name="creditCheck">
                                <span>I consent to preliminary credit checks being conducted as part of the assessment process (optional)</span>
                            </label>
                            <label class="checkbox-group">
                                <input type="checkbox" name="marketingConsent">
                                <span>I would like to receive strategic finance insights and business growth tips via email (optional)</span>
                            </label>
                        </div>
                        
                        <div class="submit-section">
                            <button type="submit" class="primary-button large">Request Professional Quote</button>
                            <p class="response-guarantee">Professional response within 24 hours | Licensed finance brokers | Confidential assessment</p>
                        </div>
                    </div>
                </form>
            </div>
        </section>

        <!-- Trust Indicators & Process Info -->
        <section class="trust-section">
            <div class="container">
                <h2>Why Commercial Businesses Choose EVFBS</h2>
                <div class="trust-grid">
                    <div class="trust-card">
                        <div class="trust-icon">🛡️</div>
                        <h3>Licensed & Regulated</h3>
                        <p>Australian Credit Licence holder, fully ASIC compliant with professional indemnity insurance and regulatory oversight.</p>
                    </div>
                    <div class="trust-card">
                        <div class="trust-icon">⚡</div>
                        <h3>Commercial Trades Specialist</h3>
                        <p>Deep expertise in commercial trades, civil contractors, and industrial businesses. We understand your industry's unique challenges.</p>
                    </div>
                    <div class="trust-card">
                        <div class="trust-icon">🎯</div>
                        <h3>Strategic Assessment</h3>
                        <p>Comprehensive analysis using AI-enhanced financial intelligence to provide optimal finance structuring and terms.</p>
                    </div>
                    <div class="trust-card">
                        <div class="trust-icon">🔒</div>
                        <h3>Confidential Process</h3>
                        <p>All information is treated with strict confidentiality. Secure data handling and professional discretion guaranteed.</p>
                    </div>
                    <div class="trust-card">
                        <div class="trust-icon">💰</div>
                        <h3>Transparent Pricing</h3>
                        <p>Clear fee structure with no hidden costs. Competitive rates and transparent terms in all quote recommendations.</p>
                    </div>
