            <div class="text-secondary-dark font-semibold mb-2">Total Funding Facilitated</div>
            <div class="text-gray-600 text-sm">Across equipment, property, and working capital solutions</div>
          </div>
          <div class="text-center card-padding-lg bg-white rounded-xl shadow-lg">
            <div class="text-4xl font-bold text-primary-orange mb-2">340+</div>
            <div class="text-secondary-dark font-semibold mb-2">Successful Approvals</div>
            <div class="text-gray-600 text-sm">Commercial trades and industrial businesses</div>
          </div>
          <div class="text-center card-padding-lg bg-white rounded-xl shadow-lg">
            <div class="text-4xl font-bold text-primary-orange mb-2">97%</div>
            <div class="text-secondary-dark font-semibold mb-2">Client Satisfaction</div>
            <div class="text-gray-600 text-sm">Professional service delivery rating</div>
          </div>
          <div class="text-center card-padding-lg bg-white rounded-xl shadow-lg">
            <div class="text-4xl font-bold text-primary-orange mb-2">35%</div>
            <div class="text-secondary-dark font-semibold mb-2">Average Growth</div>
            <div class="text-gray-600 text-sm">Business capacity increase post-funding</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Equipment Finance Case Studies -->
    <section class="section-content">
      <div class="container-default">
        <h2 class="heading-secondary text-center mb-16">Equipment Finance Success Stories</h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
