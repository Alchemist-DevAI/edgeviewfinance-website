              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Commercial Property Case Studies -->
    <section class="section-content bg-neutral-light">
      <div class="container-default">
        <h2 class="heading-secondary text-center mb-16">Commercial Property Finance Success Stories</h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
