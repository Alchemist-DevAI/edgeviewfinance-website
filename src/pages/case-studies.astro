---
// EVFBS Case Studies Page - Commercial Finance Success Stories
// Optimized for "Ben the Business Builder" ICP
import Agency11Layout from '../layouts/Agency11Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const siteData = {
  title: "Commercial Finance Case Studies | EVFBS Success Stories Australia",
  description: "Real commercial finance success stories from Australian trades, civil contractors, and industrial businesses. Equipment finance, commercial property, working capital, and invoice financing case studies with proven results.",
  keywords: "commercial finance case studies, equipment finance success stories, business loan examples, trade finance results, commercial property finance, working capital solutions Australia"
};
---

<Agency11Layout title={siteData.title} description={siteData.description} keywords={siteData.keywords}>
  
  <!-- Case Studies Schema Markup -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "@id": "https://edgeviewfinance.com.au/case-studies#webpage",
      "name": "Commercial Finance Case Studies",
      "description": "Real commercial finance success stories from Australian trades, civil contractors, and industrial businesses",
      "url": "https://edgeviewfinance.com.au/case-studies",
      "mainEntity": [
        {
          "@type": "CaseStudy",
          "name": "Excavation Contractor Equipment Finance",
          "description": "Commercial excavation contractor secured $320K equipment finance for fleet expansion",
          "about": {
            "@type": "Service",
            "name": "Equipment Finance",
            "provider": {
              "@type": "FinancialService",
              "name": "Edgeview Finance Business Solutions"
            }
          },
          "result": "40% increase in project capacity and $180K additional annual revenue"
        },
        {
          "@type": "CaseStudy", 
          "name": "Workshop Property Acquisition",
          "description": "Established plumbing contractor secured commercial property finance for workshop purchase",
          "about": {
            "@type": "Service",
            "name": "Commercial Property Finance",
            "provider": {
              "@type": "FinancialService", 
              "name": "Edgeview Finance Business Solutions"
            }
          },
          "result": "$850K workshop acquisition with improved operational efficiency"
        },
        {
          "@type": "CaseStudy",
          "name": "Civil Contractor Working Capital",
          "description": "Infrastructure contractor secured working capital facility for project cash flow management",
          "about": {
            "@type": "Service",
            "name": "Working Capital Solutions",
            "provider": {
              "@type": "FinancialService",
              "name": "Edgeview Finance Business Solutions"
            }
          },
          "result": "Smooth cash flow management enabling $2.1M project completion"
        }
      ],
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://edgeviewfinance.com.au"
          },
          {
            "@type": "ListItem", 
            "position": 2,
            "name": "Case Studies",
            "item": "https://edgeviewfinance.com.au/case-studies"
          }
        ]
      }
    }
    </script>
  
  <!-- Open Graph for Social Sharing -->
  <meta property="og:title" content={siteData.title} slot="head" />
  <meta property="og:description" content={siteData.description} slot="head" />
  <meta property="og:type" content="website" slot="head" />
  <meta property="og:url" content="https://edgeviewfinance.com.au/case-studies" slot="head" />
  <meta property="og:locale" content="en_AU" slot="head" />

  <Header />
  <main>
    <!-- Hero Section -->
    <section class="section-hero hero-section">
      <div class="container-default">
        <div class="text-center">
          <div class="breadcrumb text-white/80 mb-4">
            <a href="/" class="text-white hover:text-white">Home</a> > Case Studies
          </div>
          <h1 class="heading-primary text-white mb-6">Commercial Finance Success Stories</h1>
          <p class="hero-subtitle text-xl lg:text-2xl font-light mb-8 text-gray-100 max-w-4xl mx-auto">
            Real results from Australian business builders who've transformed their operations through strategic commercial finance solutions. 
            Discover how equipment finance, commercial property, working capital, and invoice financing have driven measurable business growth.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center button-gap mb-8">
            <a href="/get-quote" class="btn-primary btn-large">Start Your Success Story</a>
            <a href="/contact" class="btn-secondary btn-large text-white border-white hover:bg-white hover:text-secondary-dark">Discuss Your Requirements</a>
          </div>
          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center flex-wrap text-gray-100">
            <span class="flex items-center gap-2">✓ Real Client Outcomes</span>
            <span class="flex items-center gap-2">✓ Confidential Case Studies</span>
            <span class="flex items-center gap-2">✓ Proven Results</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Overview Stats -->
    <section class="section-content bg-neutral-light">
      <div class="container-default">
        <h2 class="heading-secondary text-center mb-16">Strategic Finance Impact Across Australian Businesses</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center card-padding-lg bg-white rounded-xl shadow-lg">
