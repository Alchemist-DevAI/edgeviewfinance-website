                  <div class="text-center card-padding-sm bg-neutral-light rounded-lg">
                    <div class="text-2xl font-bold text-primary-orange">40%</div>
                    <div class="text-xs text-gray-600">Increase in project capacity</div>
                  </div>
                  <div class="text-center card-padding-sm bg-neutral-light rounded-lg">
                    <div class="text-2xl font-bold text-primary-orange">$180K</div>
                    <div class="text-xs text-gray-600">Additional annual revenue</div>
                  </div>
                  <div class="text-center card-padding-sm bg-neutral-light rounded-lg">
                    <div class="text-2xl font-bold text-primary-orange">6 months</div>
                    <div class="text-xs text-gray-600">ROI achievement timeline</div>
                  </div>
                </div>
              </div>
              
              <div class="bg-neutral-light card-padding-sm rounded-lg border-l-4 border-primary-orange">
                <blockquote class="italic body-medium text-gray-700 mb-2">
