                <ul class="space-y-1 mb-3">
                  <li class="flex items-start">
                    <span class="text-primary-orange font-bold mr-2">✓</span>
                    <span class="body-medium text-gray-700">New 30-tonne excavator: $185,000</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-primary-orange font-bold mr-2">✓</span>
                    <span class="body-medium text-gray-700">Articulated dump truck: $95,000</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-primary-orange font-bold mr-2">✓</span>
                    <span class="body-medium text-gray-700">Compaction equipment: $40,000</span>
